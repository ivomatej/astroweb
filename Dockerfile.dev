# Dockerfile.dev — Astro dev server with HMR
#
# This image is for local development. It runs `astro dev` and watches
# files mounted from the host. The container `node_modules` is kept
# in a named volume so it doesn't conflict with the host's lockfile.

FROM node:22-alpine

WORKDIR /app

# Astro dev server listens on 4321 by default
EXPOSE 4321

# Install dependencies first to leverage Docker layer cache.
# package.json + package-lock.json are copied at build time;
# `npm ci` is reproducible from the lockfile.
COPY package.json package-lock.json ./
RUN npm ci

# The actual source code is mounted at runtime via docker-compose,
# so we don't COPY it here. This avoids rebuilding the image on every
# code change.

CMD ["npm", "run", "dev"]
