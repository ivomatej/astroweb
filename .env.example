# Astroweb env template — copy to .env and fill in.
# .env is gitignored; .env.example is committed for documentation.

# ----- Backend (Contenta API) -----
#
# Dev (Astro běží v Docker container `recenzer-astro-dev`, API běží na hostu):
#   CONTENTA_API_URL=http://host.docker.internal:3000/api/v1
#
# Dev (Astro npm run dev přímo z hosta, API taky na hostu):
#   CONTENTA_API_URL=http://localhost:3000/api/v1
#
# Prod (Cloudflare Pages build → backend na Hetzner s Cloudflare-fronted SSL):
#   CONTENTA_API_URL=https://api.contenta.cz/api/v1
#
CONTENTA_API_URL=http://host.docker.internal:3000/api/v1

# X-Site-Key — per-site API token for the recenzer.cz frontend.
# Generated by the backend seed (look for "🔑 API key for site recenzer:"
# in the seed log) or rotate via admin endpoint.
RECENZER_API_KEY=
