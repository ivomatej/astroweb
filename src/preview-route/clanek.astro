---
/**
 * Admin draft preview — SSR, on-demand. NOT part of the production (Cloudflare
 * Pages) static build: this file lives outside `src/pages` and is wired in only
 * by `astro.config.preview.mjs` (the Node-adapter preview deployment). It
 * renders an unpublished article through the exact same <ArticleView> tree as
 * production, so editors see real output, not an approximation.
 *
 * Auth: the signed `token` query param (issued by the admin) — no site key.
 */
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleView from "../components/article/ArticleView.astro";
import { fetchPreviewArticle, type PreviewResult } from "../lib/preview-api";

const slug = Astro.params.slug ?? "";
const token = Astro.url.searchParams.get("token") ?? "";

let result: PreviewResult;
if (!slug || !token) {
  result = { ok: false, status: 400, message: "Chybí parametr slug nebo token." };
} else {
  result = await fetchPreviewArticle(slug, token);
}

const pageTitle = result.ok
  ? `Náhled: ${result.article.title.replace(/<[^>]+>/g, "")}`
  : "Náhled článku";
---

<BaseLayout title={pageTitle} noIndex>
  <div class="preview-banner" role="status">
    <span class="preview-dot" aria-hidden="true"></span>
    <span class="preview-label">Náhled konceptu</span>
    <span class="preview-sub">Takto bude článek vypadat na webu. Stránka není veřejná ani indexovaná.</span>
  </div>

  {result.ok ? (
    <ArticleView article={result.article} />
  ) : (
    <div class="preview-error">
      <h1>Náhled se nepodařilo načíst</h1>
      <p>{result.message}</p>
      <p class="preview-error-code">Kód: {result.status}</p>
    </div>
  )}
</BaseLayout>

<style>
  .preview-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 1rem;
    background: #1f2937;
    color: #fff;
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 12.5px;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .preview-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #f59e0b;
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.25);
    flex-shrink: 0;
  }

  .preview-label {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .preview-sub {
    color: #cbd5e1;
    font-size: 11.5px;
  }

  .preview-error {
    max-width: 640px;
    margin: 4rem auto;
    padding: 2rem 1.25rem;
    text-align: center;
  }

  .preview-error h1 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
  }

  .preview-error-code {
    margin-top: 1rem;
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 12px;
    color: #64748b;
  }
</style>
