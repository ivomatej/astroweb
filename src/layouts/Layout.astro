---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Osobní stránka" } = Astro.props;
const pathname = Astro.url.pathname;
const isActive = (href: string): boolean =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Hlavní">
        <a href="/" class="brand">~/ivomatej</a>
        <ul class="nav-links">
          <li><a href="/" aria-current={isActive("/") ? "page" : undefined}>Domů</a></li>
          <li><a href="/about" aria-current={isActive("/about") ? "page" : undefined}>O mně</a></li>
          <li><a href="/contact" aria-current={isActive("/contact") ? "page" : undefined}>Kontakt</a></li>
        </ul>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} ivomatej · Postaveno na Astro</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0d1117;
    --bg-elev: #161b22;
    --border: #30363d;
    --text: #e6edf3;
    --text-muted: #9da7b3;
    --accent: #7aa2f7;
    --accent-hover: #a4c1ff;
    --radius: 12px;
    --max-width: 720px;
    --font-sans:
      ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
      "Helvetica Neue", Arial, sans-serif;
    --font-mono:
      ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo, Consolas, monospace;
  }

  @media (prefers-color-scheme: light) {
    :root {
      --bg: #ffffff;
      --bg-elev: #f6f8fa;
      --border: #d0d7de;
      --text: #1f2328;
      --text-muted: #59636e;
      --accent: #0969da;
      --accent-hover: #0550ae;
    }
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    background-color: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a:hover,
  a:focus-visible {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  h1,
  h2,
  h3 {
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 2.75rem);
  }

  p {
    margin: 0 0 1rem;
    color: var(--text-muted);
  }

  .site-header {
    border-bottom: 1px solid var(--border);
    background-color: var(--bg-elev);
  }

  .nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .brand {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--text);
  }

  .brand:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.25rem;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .nav-links a[aria-current="page"] {
    color: var(--text);
    font-weight: 600;
  }

  .container {
    flex: 1;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.25rem;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 1.25rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .site-footer p {
    margin: 0;
  }

  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background-color: var(--bg-elev);
    color: var(--text);
    font-weight: 500;
  }

  .btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  .btn-primary {
    background-color: var(--accent);
    border-color: var(--accent);
    color: #ffffff;
  }

  .btn-primary:hover {
    background-color: var(--accent-hover);
    border-color: var(--accent-hover);
    color: #ffffff;
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
