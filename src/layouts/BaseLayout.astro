---
import "../styles/global.css";
import Masthead from "../components/site/Masthead.astro";
import Footer from "../components/site/Footer.astro";
import CookieConsent from "../components/site/CookieConsent.astro";
import type { FooterCategoryContext } from "../types/site";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  footerCategoryContext?: FooterCategoryContext;
  /**
   * Opt this page into the global newsletter band above the footer.
   *
   * Default: OFF. The promo box is generic boilerplate when rendered
   * on every page, and HCU raters flag exactly that pattern. Only opt
   * in where the visitor has high engagement intent (homepage, article
   * body). Trust / legal / author / utility pages get nothing.
   */
  showNewsletterBand?: boolean;
}

const {
  title,
  description = "Recenzer — nezávislý průvodce nákupem.",
  canonical,
  ogImage,
  noIndex = false,
  footerCategoryContext,
  showNewsletterBand = false,
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;

// Umami analytika (ADR-008) — self-hosted, cookieless. Per-doména websiteId +
// společný scriptUrl z CF Pages env (PUBLIC_*, zapečené do buildu). Cookieless →
// načítá se VŽDY, bez consent gatingu. Bez env se tracker prostě nevloží.
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const umamiScriptUrl = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/*
      PRELOAD KRITICKÝCH FONTŮ — co nejvýše v <head>, aby browser
      začal stahovat dřív, než dorazí ke <link> na CSS.
      Crossorigin je u fontů povinné.
    */}
    <link
      rel="preload"
      href="/fonts/Figtree-VariableFont_wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/JetBrainsMono-VariableFont_wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    {/*
      DNS-PREFETCH pro affiliate destinace.
      Bez fetchu jen DNS — minimální cena, ale ušetří 50–150 ms,
      pokud uživatel klikne na produktový odkaz.
    */}
    <link rel="dns-prefetch" href="https://www.heureka.cz" />
    <link rel="dns-prefetch" href="https://www.alza.cz" />
    <link rel="dns-prefetch" href="https://www.datart.cz" />

    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    {/*
      Auto-discovery feeds — RSS čtečky a LLM crawlery (Perplexity, ChatGPT)
      najdou feedy podle <link rel="alternate"> v HTML.
    */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Recenzer.cz — RSS feed všech článků"
      href="/rss.xml"
    />
    <link
      rel="alternate"
      type="application/atom+xml"
      title="Recenzer.cz — Atom feed aktualizací"
      href="/aktualizace.xml"
    />

    <meta name="color-scheme" content="light" />

    {/*
      Umami (ADR-008) — cookieless analytika, načítá se vždy (bez souhlasu).
      websiteId per doména (cz/.sk) + scriptUrl z CF Pages env.
    */}
    {umamiWebsiteId && umamiScriptUrl && (
      <script is:inline defer src={umamiScriptUrl} data-website-id={umamiWebsiteId}></script>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Přeskočit na obsah</a>

    <Masthead />

    <main id="main">
      <slot />
    </main>

    <Footer
      categoryContext={footerCategoryContext}
      showNewsletterBand={showNewsletterBand}
    />

    <CookieConsent />
  </body>
</html>
