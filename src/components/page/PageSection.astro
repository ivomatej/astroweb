---
interface Props {
  /** Optional anchor id for in-page navigation. */
  id?: string;
  eyebrow?: string;
  title?: string;
  lede?: string;
  /** Visual variant: default (transparent), warm (bg-warm), dark (ink). */
  variant?: "default" | "warm" | "dark";
}

const { id, eyebrow, title, lede, variant = "default" } = Astro.props;
---

<section id={id} class:list={["page-section", `variant-${variant}`]}>
  <div class="page-section-inner">
    {
      (eyebrow || title || lede) && (
        <header class="page-section-head">
          {eyebrow && <p class="page-section-eyebrow">{eyebrow}</p>}
          {title && <h2 class="page-section-title" set:html={title} />}
          {lede && <p class="page-section-lede" set:html={lede} />}
        </header>
      )
    }
    <div class="page-section-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .page-section {
    border-bottom: 1px solid var(--line);
  }

  .page-section.variant-warm { background: var(--bg-warm); }
  .page-section.variant-dark {
    background: var(--ink);
    color: rgba(255, 255, 255, 0.85);
  }

  .page-section-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--gutter);
  }

  .page-section-head {
    margin-bottom: 2rem;
    max-width: 70ch;
  }

  .page-section-eyebrow {
    font-family: var(--mono);
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--p-700);
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .page-section.variant-dark .page-section-eyebrow {
    color: var(--p-300);
  }

  .page-section-title {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--ink);
    line-height: 1.15;
    margin: 0 0 0.75rem;
  }

  .page-section.variant-dark .page-section-title {
    color: #fff;
  }

  .page-section-title :global(em) {
    font-style: italic;
    color: var(--p-700);
  }

  .page-section.variant-dark .page-section-title :global(em) {
    color: var(--p-300);
  }

  .page-section-lede {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  .page-section.variant-dark .page-section-lede {
    color: rgba(255, 255, 255, 0.7);
  }

  .page-section-lede :global(strong) {
    color: var(--ink);
    font-weight: 700;
  }

  .page-section.variant-dark .page-section-lede :global(strong) {
    color: #fff;
  }
</style>
