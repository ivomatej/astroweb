---
import { site } from "../../config/site";
import MegaMenu from "./MegaMenu.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string): boolean =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

{/*
  Sentinel above the masthead. Sits at the absolute top of the document
  and is used by IntersectionObserver to detect scroll direction WITHOUT
  attaching a scroll listener — the latter hurts INP on long pages.
*/}
<div class="masthead-sentinel" aria-hidden="true"></div>

{/*
  Backdrop shown while any mega panel is open. Pure-CSS visibility
  driven by body:has(.nav-item.has-mega:hover|focus-within|.is-open).
  Sits below the masthead/panel z-index so they stay crisp on top.
*/}
<div class="page-backdrop" aria-hidden="true"></div>

<header class="masthead" data-masthead>
  <div class="masthead-inner">
    <a href="/" class="brand" aria-label={`${site.brand.name} — domů`}>
      <span class="brand-name">{site.brand.name}</span>
    </a>

    <nav class="nav" aria-label="Hlavní">
      <ul class="nav-list" role="list">
        {
          site.primaryNav.map((link, i) => {
            const triggerId = `mega-trigger-${i}`;
            const hasMega = !!link.mega;
            return (
              <li
                class:list={["nav-item", { "has-mega": hasMega }]}
                data-nav-item
              >
                <a
                  href={link.href}
                  class:list={[{ active: isActive(link.href) }]}
                  aria-current={isActive(link.href) ? "page" : undefined}
                  aria-haspopup={hasMega ? "true" : undefined}
                  aria-expanded={hasMega ? "false" : undefined}
                  id={hasMega ? triggerId : undefined}
                >
                  {link.label}
                  {hasMega && (
                    <svg class="nav-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  )}
                </a>
                {hasMega && link.mega && (
                  <MegaMenu panel={link.mega} labelledBy={triggerId} />
                )}
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="masthead-right">
      <a class="search-icon-link" href="/hledat/" aria-label="Otevřít hledání">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </a>

      <a class="newsletter-cta" href="/newsletter/">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
          <polyline points="22,6 12,13 2,6" />
        </svg>
        <span>Newsletter</span>
      </a>

      <a class="account-cta" href="/ucet/" aria-label="Přihlásit se / Můj účet">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
        <span>Účet</span>
      </a>
    </div>
  </div>
</header>

<style>
  .masthead-sentinel {
    /*
     * 1 px marker above the header used by IntersectionObserver to
     * detect "user is at top of page". Painted with the same purple
     * as the masthead so it visually merges into the bar instead of
     * showing a thin white seam against the body background.
     */
    height: 1px;
    width: 100%;
    background: var(--p-800);
  }

  /*
   * Backdrop shown when ANY mega panel is open (hover, focus-within
   * or .is-open). Sits at z 30 — above page content, below the panel
   * (z 40) and the masthead (z 50). Uses :has() so it's pure CSS.
   * backdrop-filter blurs the page behind, regardless of dark/light
   * theme of the underlying content.
   */
  .page-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 19, 30, 0.32);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    z-index: 30;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease-out;
  }

  body:has(.nav-item.has-mega.is-open) .page-backdrop {
    opacity: 1;
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .page-backdrop { transition: none; }
  }

  .masthead {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--p-800);
    color: #fff;
    position: sticky;
    top: 0;
    z-index: 50;
    transition: transform 0.22s ease-out;
    will-change: transform;
  }

  /* Hidden state — applied by JS when the user scrolls DOWN past the sentinel. */
  .masthead.is-hidden {
    transform: translateY(-100%);
  }

  @media (prefers-reduced-motion: reduce) {
    .masthead { transition: none; }
  }

  .masthead-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: stretch;       /* let nav stretch to full height */
    gap: 2rem;
    min-height: 56px;           /* baseline masthead height */
  }

  /* Items that aren't the nav still need to be vertically centered. */
  .brand,
  .masthead-right {
    align-self: center;
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    text-decoration: none;
    color: #fff;
  }

  .brand:hover .brand-name {
    color: var(--p-200);
  }

  .brand-name {
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.035em;
    line-height: 1;
    transition: color 0.15s ease;
  }

  .nav {
    display: flex;
    align-items: stretch;
    margin-left: 1.25rem;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: stretch;
    gap: 1.75rem;
  }

  /*
   * .nav-item stretches to the FULL masthead height so the geometric
   * hover area covers the gap between the link text and the bottom of
   * the masthead. Previous version was inline-flex sized to content
   * → mouse moving down to the panel left the .nav-item box mid-way
   * and the panel closed. This fixes that.
   *
   * position: static keeps the absolutely-positioned .mega-panel
   * anchored to the .masthead (the sticky positioned ancestor), not
   * to each individual .nav-item.
   */
  .nav-item {
    position: static;
    display: flex;
    align-items: center;
  }

  .nav a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    padding: 1rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .nav a:hover,
  .nav a:focus-visible {
    color: #fff;
  }

  .nav a.active {
    color: #fff;
    border-bottom-color: var(--p-300);
  }

  .nav-chev {
    width: 11px;
    height: 11px;
    color: rgba(255, 255, 255, 0.55);
    transition: transform 0.18s, color 0.15s;
  }

  .nav-item.is-open .nav-chev {
    color: #fff;
    transform: rotate(180deg);
  }

  /*
   * Mega-panel show / hide — JS is the SOLE source of truth.
   *
   * Earlier versions tried CSS :hover (got stuck in Astro dev mode
   * due to dev-toolbar shadow DOM pointer events) and then mixed
   * :focus-within (still got stuck because focus inside the panel
   * kept the rule matching). The deterministic answer is: only
   * .is-open controls visibility. JS owns the state.
   *
   * :global() bypasses Astro scoping since the panel element lives in
   * MegaMenu's scope, not Masthead's.
   */
  .nav-item.has-mega.is-open > :global(.mega-panel) {
    display: block;
  }

  .masthead-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /*
   * Search trigger — icon-only link to /hledat/. No inline input in the
   * masthead; user types the query on the search page itself.
   */
  .search-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .search-icon-link:hover,
  .search-icon-link:focus-visible {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.22);
    color: #fff;
    outline: none;
  }

  .search-icon-link svg {
    width: 16px;
    height: 16px;
  }

  /*
   * Newsletter CTA — primary pill (filled white).
   */
  .newsletter-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    background: #fff;
    color: var(--p-800);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid #fff;
    transition: background 0.15s, color 0.15s, transform 0.15s;
  }

  .newsletter-cta:hover,
  .newsletter-cta:focus-visible {
    background: var(--p-100);
    color: var(--p-900);
    transform: translateY(-1px);
    outline: none;
  }

  .newsletter-cta svg {
    width: 13px;
    height: 13px;
  }

  /*
   * Account CTA — secondary pill (outlined). Leads to /ucet/ which
   * will host the login form for non-authenticated visitors and the
   * account dashboard for signed-in users.
   */
  .account-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    background: transparent;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.35);
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
  }

  .account-cta:hover,
  .account-cta:focus-visible {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.55);
    color: #fff;
    transform: translateY(-1px);
    outline: none;
  }

  .account-cta svg {
    width: 14px;
    height: 14px;
  }

  @media (max-width: 960px) {
    .nav { display: none; }
  }

  /*
   * Phones — labels in Newsletter/Account would push the masthead over
   * one row. Collapse both to icon-only circular buttons matching the
   * search icon.
   */
  @media (max-width: 720px) {
    .newsletter-cta,
    .account-cta {
      gap: 0;
      padding: 0;
      width: 36px;
      height: 36px;
      justify-content: center;
    }
    .newsletter-cta span,
    .account-cta span {
      display: none;
    }
    .newsletter-cta svg,
    .account-cta svg {
      width: 15px;
      height: 15px;
    }
  }
</style>

<script is:inline>
  /*
   * Sticky-header hide-on-scroll.
   *
   * Goal: when the user scrolls DOWN past the top of the page, slide the
   * masthead out of view. When they scroll UP, slide it back. While the
   * sentinel at the very top of the document is visible (= user is at
   * the top of the page) the header is always shown.
   *
   * IntersectionObserver does the cheap top-of-page detection (no
   * per-frame work). Direction detection uses a passive scroll listener
   * wrapped in requestAnimationFrame and a small delta threshold — that
   * keeps the JS off the main thread between scrolls so INP stays clean.
   */
  (function () {
    const header   = document.querySelector("[data-masthead]");
    const sentinel = document.querySelector(".masthead-sentinel");
    if (!header || !sentinel || !("IntersectionObserver" in window)) return;

    let atTop  = true;
    let lastY  = window.scrollY || 0;
    let ticking = false;

    new IntersectionObserver(
      (entries) => {
        for (const e of entries) atTop = e.isIntersecting;
        if (atTop) header.classList.remove("is-hidden");
      },
      { threshold: 0 },
    ).observe(sentinel);

    document.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const y = window.scrollY || 0;
          if (!atTop) {
            if (y > lastY + 8 && y > 80) header.classList.add("is-hidden");
            else if (y < lastY - 8)      header.classList.remove("is-hidden");
          }
          lastY = y;
          ticking = false;
        });
      },
      { passive: true },
    );
  })();

  /*
   * Mega-menu keyboard / outside-click handling.
   *
   * Mouse hover is pure CSS (.has-mega:hover > .mega-panel { display: block }).
   * Keyboard users get :focus-within for free when Tab lands on the trigger.
   * What we wire here manually:
   *
   *   - aria-expanded mirror on the trigger anchor while the parent
   *     li.has-mega is open (hover OR is-open class).
   *   - ESC closes a panel that was opened via .is-open (keyboard
   *     scenario) and returns focus to the trigger.
   *   - Clicking outside the nav while a panel is is-open closes it.
   *
   * No click-to-toggle handler — clicking the trigger should follow
   * the link to the category page like a normal nav anchor.
   */
  (function () {
    const items = document.querySelectorAll(".nav-item.has-mega");
    if (!items.length) return;

    // 180 ms is enough for the cursor to cross the masthead → panel
    // seam without flicker, short enough that an accidental
    // mouseleave actually closes the panel quickly.
    const CLOSE_DELAY = 180;

    function closeAll() {
      items.forEach((it) => {
        it.classList.remove("is-open");
        const trigger = it.querySelector("a[aria-haspopup]");
        if (trigger) trigger.setAttribute("aria-expanded", "false");
      });
    }

    items.forEach((it) => {
      const trigger = it.querySelector("a[aria-haspopup]");
      const panel   = it.querySelector(".mega-panel");
      if (!trigger) return;

      let closeTimer = 0;

      function open() {
        clearTimeout(closeTimer);
        // Close any sibling panel that might be open.
        items.forEach((other) => {
          if (other !== it) other.classList.remove("is-open");
        });
        it.classList.add("is-open");
        trigger.setAttribute("aria-expanded", "true");
      }

      function closeNow() {
        clearTimeout(closeTimer);
        it.classList.remove("is-open");
        trigger.setAttribute("aria-expanded", "false");
      }

      function scheduleClose() {
        clearTimeout(closeTimer);
        closeTimer = window.setTimeout(closeNow, CLOSE_DELAY);
      }

      function cancelClose() {
        clearTimeout(closeTimer);
      }

      // Mouseenter / mouseleave fire when the cursor crosses the
      // GEOMETRIC box of the element. The mega-panel sits below the
      // masthead in absolute position so it's geometrically separate
      // from .nav-item — we have to listen on both. Quick traversal
      // (nav-item → panel or panel → nav-item) cancels the close.
      it.addEventListener("mouseenter", open);
      it.addEventListener("mouseleave", scheduleClose);

      if (panel) {
        panel.addEventListener("mouseenter", cancelClose);
        panel.addEventListener("mouseleave", scheduleClose);
      }

      // Keyboard path — focus moves into trigger or any descendant
      // (panel link). Closing on focusout-outside is immediate.
      it.addEventListener("focusin", open);
      it.addEventListener("focusout", (e) => {
        if (!it.contains(e.relatedTarget)) closeNow();
      });
    });

    // ESC closes any open panel and returns focus to the trigger.
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      const focused = document.activeElement && document.activeElement.closest(".nav-item.has-mega");
      const open    = document.querySelector(".nav-item.has-mega.is-open");
      if (!open && !focused) return;
      closeAll();
      if (focused) {
        const trigger = focused.querySelector("a[aria-haspopup]");
        if (trigger) trigger.focus();
      }
    });

    // Click anywhere outside the nav closes panels immediately.
    document.addEventListener("click", (e) => {
      const insideNav = e.target.closest && e.target.closest(".nav-item.has-mega");
      if (!insideNav) closeAll();
    });
  })();
</script>
