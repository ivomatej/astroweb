---
import { site } from "../../config/site";

const pathname = Astro.url.pathname;
const isActive = (href: string): boolean =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="masthead">
  <div class="masthead-inner">
    <a href="/" class="brand" aria-label={`${site.brand.name} — domů`}>
      <span class="brand-name">{site.brand.name}</span>
    </a>

    <nav class="nav" aria-label="Hlavní">
      {
        site.primaryNav.map((link) => (
          <a
            href={link.href}
            class:list={[{ active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="masthead-right">
      <button type="button" class="search-pill" aria-label="Hledat">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <span>Hledat recenzi…</span>
        <kbd>⌘K</kbd>
      </button>

      <a href="/ucet/" class="masthead-account" aria-label="Uživatelský účet">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
        <span>Účet</span>
      </a>
    </div>
  </div>
</header>

<style>
  .masthead {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--p-800);
    color: #fff;
  }

  .masthead-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.85rem var(--gutter);
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    text-decoration: none;
    color: #fff;
  }

  .brand:hover .brand-name {
    color: var(--p-200);
  }

  .brand-name {
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.035em;
    line-height: 1;
    transition: color 0.15s ease;
  }

  .nav {
    display: flex;
    gap: 1.75rem;
    margin-left: 1.25rem;
  }

  .nav a {
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    padding: 5px 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .nav a:hover,
  .nav a:focus-visible {
    color: #fff;
  }

  .nav a.active {
    color: #fff;
    border-bottom-color: var(--p-300);
  }

  .masthead-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .search-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    font-size: 13px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.15s, border-color 0.15s;
  }

  .search-pill:hover,
  .search-pill:focus-visible {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .search-pill svg {
    width: 14px;
    height: 14px;
  }

  .search-pill kbd {
    font-family: var(--mono);
    font-size: 11px;
    padding: 1px 5px;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.7);
  }

  .masthead-account {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: var(--r-sm);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .masthead-account:hover,
  .masthead-account:focus-visible {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.28);
  }

  .masthead-account svg {
    width: 14px;
    height: 14px;
  }

  @media (max-width: 960px) {
    .nav { display: none; }
    .search-pill span { display: none; }
    .search-pill kbd { display: none; }
  }

  @media (max-width: 560px) {
    .masthead-account span { display: none; }
  }
</style>
