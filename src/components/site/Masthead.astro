---
import { site } from "../../config/site";

const pathname = Astro.url.pathname;
const isActive = (href: string): boolean =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

{/*
  Sentinel above the masthead. Sits at the absolute top of the document
  and is used by IntersectionObserver to detect scroll direction WITHOUT
  attaching a scroll listener — the latter hurts INP on long pages.
*/}
<div class="masthead-sentinel" aria-hidden="true"></div>

<header class="masthead" data-masthead>
  <div class="masthead-inner">
    <a href="/" class="brand" aria-label={`${site.brand.name} — domů`}>
      <span class="brand-name">{site.brand.name}</span>
    </a>

    <nav class="nav" aria-label="Hlavní">
      {
        site.primaryNav.map((link) => (
          <a
            href={link.href}
            class:list={[{ active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="masthead-right">
      {/*
        Desktop: full search form with visible input.
        Mobile: hidden in favor of the icon-only link below — keeps the
        header compact so H1 stays above the fold.
      */}
      <form
        class="search-pill"
        role="search"
        action="/hledat/"
        method="get"
        aria-label="Vyhledávání na webu"
      >
        <button type="submit" class="search-pill-btn" aria-label="Hledat">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
        </button>
        <label for="masthead-search-q" class="visually-hidden">Hledaný výraz</label>
        <input
          id="masthead-search-q"
          type="search"
          name="q"
          placeholder="Hledat recenzi…"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
        />
      </form>

      <a class="search-icon-link" href="/hledat/" aria-label="Otevřít hledání">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </a>

      <a class="newsletter-cta" href="/newsletter/">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
          <polyline points="22,6 12,13 2,6" />
        </svg>
        <span>Newsletter</span>
      </a>
    </div>
  </div>
</header>

<style>
  .masthead-sentinel {
    /* Zero-height marker just above the header. */
    height: 1px;
    width: 100%;
  }

  .masthead {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--p-800);
    color: #fff;
    position: sticky;
    top: 0;
    z-index: 50;
    transition: transform 0.22s ease-out;
    will-change: transform;
  }

  /* Hidden state — applied by JS when the user scrolls DOWN past the sentinel. */
  .masthead.is-hidden {
    transform: translateY(-100%);
  }

  @media (prefers-reduced-motion: reduce) {
    .masthead { transition: none; }
  }

  .masthead-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.85rem var(--gutter);
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    text-decoration: none;
    color: #fff;
  }

  .brand:hover .brand-name {
    color: var(--p-200);
  }

  .brand-name {
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.035em;
    line-height: 1;
    transition: color 0.15s ease;
  }

  .nav {
    display: flex;
    gap: 1.75rem;
    margin-left: 1.25rem;
  }

  .nav a {
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    padding: 5px 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .nav a:hover,
  .nav a:focus-visible {
    color: #fff;
  }

  .nav a.active {
    color: #fff;
    border-bottom-color: var(--p-300);
  }

  .masthead-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .search-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.3rem 0.4rem 0.3rem 0.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.15s, border-color 0.15s;
    min-width: 220px;
  }

  .search-pill:hover,
  .search-pill:focus-within {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .search-pill-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.78);
    cursor: pointer;
  }

  .search-pill-btn:hover,
  .search-pill-btn:focus-visible {
    color: #fff;
    background: rgba(255, 255, 255, 0.14);
    outline: none;
  }

  .search-pill-btn svg {
    width: 14px;
    height: 14px;
  }

  .search-pill input[type="search"] {
    flex: 1;
    min-width: 0;
    padding: 0.3rem 0.4rem;
    background: transparent;
    border: 0;
    color: #fff;
    font-size: 13px;
    font-family: inherit;
  }

  .search-pill input[type="search"]::placeholder {
    color: rgba(255, 255, 255, 0.55);
  }

  .search-pill input[type="search"]:focus {
    outline: none;
  }

  .search-pill input[type="search"]::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /*
   * Icon-only fallback for mobile, hidden by default on desktop where
   * the full input form is shown instead.
   */
  .search-icon-link {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .search-icon-link:hover,
  .search-icon-link:focus-visible {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.22);
    color: #fff;
    outline: none;
  }

  .search-icon-link svg {
    width: 16px;
    height: 16px;
  }

  /*
   * Newsletter CTA — a single, deliberate signup destination in the
   * header. Replaces the universal "subscribe everywhere" promo strip.
   * Hidden on phones, where chrome real estate is precious.
   */
  .newsletter-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    background: #fff;
    color: var(--p-800);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid #fff;
    transition: background 0.15s, color 0.15s, transform 0.15s;
  }

  .newsletter-cta:hover,
  .newsletter-cta:focus-visible {
    background: var(--p-100);
    color: var(--p-900);
    transform: translateY(-1px);
    outline: none;
  }

  .newsletter-cta svg {
    width: 13px;
    height: 13px;
  }

@media (max-width: 960px) {
    .nav { display: none; }
    .search-pill { min-width: 0; }
    .search-pill input[type="search"] { width: 160px; flex: 0 0 auto; }
  }

  /*
   * Phones — drop the full search form in favor of a compact icon link
   * to /hledat/. Reclaims ~180 px of masthead width that was eaten by
   * a feature only ~10 % of users touch from the header.
   */
  @media (max-width: 720px) {
    .search-pill { display: none; }
    .search-icon-link { display: inline-flex; }
    .newsletter-cta { display: none; }
  }
</style>

<script is:inline>
  /*
   * Sticky-header hide-on-scroll.
   *
   * Goal: when the user scrolls DOWN past the top of the page, slide the
   * masthead out of view. When they scroll UP, slide it back. While the
   * sentinel at the very top of the document is visible (= user is at
   * the top of the page) the header is always shown.
   *
   * IntersectionObserver does the cheap top-of-page detection (no
   * per-frame work). Direction detection uses a passive scroll listener
   * wrapped in requestAnimationFrame and a small delta threshold — that
   * keeps the JS off the main thread between scrolls so INP stays clean.
   */
  (function () {
    const header   = document.querySelector("[data-masthead]");
    const sentinel = document.querySelector(".masthead-sentinel");
    if (!header || !sentinel || !("IntersectionObserver" in window)) return;

    let atTop  = true;
    let lastY  = window.scrollY || 0;
    let ticking = false;

    new IntersectionObserver(
      (entries) => {
        for (const e of entries) atTop = e.isIntersecting;
        if (atTop) header.classList.remove("is-hidden");
      },
      { threshold: 0 },
    ).observe(sentinel);

    document.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const y = window.scrollY || 0;
          if (!atTop) {
            if (y > lastY + 8 && y > 80) header.classList.add("is-hidden");
            else if (y < lastY - 8)      header.classList.remove("is-hidden");
          }
          lastY = y;
          ticking = false;
        });
      },
      { passive: true },
    );
  })();
</script>
