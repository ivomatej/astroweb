---
/**
 * Single mega-menu panel. Rendered once per primary-nav item that has
 * a `mega` payload. Visibility (open/close) is driven by classes
 * toggled by Masthead's hover/focus/click JS — the component itself
 * is hidden by default with display:none and only becomes visible
 * when its parent <li.has-mega> is hovered or has class `is-open`.
 */
import type { MegaMenuPanel, MegaMenuIcon } from "../../types/site";

interface Props {
  panel: MegaMenuPanel;
  labelledBy?: string;
}

const { panel, labelledBy } = Astro.props;

// Plain SVG icon set — referenced by string key from data so the panel
// definitions stay free of JSX/SVG noise.
function iconPath(icon: MegaMenuIcon): string {
  switch (icon) {
    case "appliance":
      // washing machine outline
      return '<rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="13" r="5"/><circle cx="12" cy="13" r="2"/><line x1="7" y1="5" x2="7" y2="5.01"/>';
    case "tool":
      // hammer outline
      return '<path d="m15 12-8.5 8.5a2.12 2.12 0 1 1-3-3L12 9"/><path d="m17.64 15 3.36-3.36-1.41-1.41-3.36 3.36"/><path d="M18 9 9 18"/>';
    case "leaf":
      return '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.6 17.04-8.2 17.04z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>';
    case "car":
      return '<path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9l-3.6-1-2-3.8C14.6 5.6 14 5 13.3 5h-2.6c-.7 0-1.3.6-1.6 1.3L7 10l-3.6 1c-.8.2-1.5 1-1.5 1.9V16c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/>';
    case "service":
      return '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/>';
    case "guide":
      return '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>';
    case "news":
      return '<path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8z"/>';
    default:
      return '';
  }
}
---

<div
  class="mega-panel"
  role="region"
  aria-labelledby={labelledBy}
>
  <div class="mega-inner">
    <div class="mega-grid">
      {
        panel.sections.map((section) => (
          <div class="mega-section">
            <div class="mega-section-head">
              <span class="mega-section-ic" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={iconPath(section.icon)} />
              </span>
              <h3 class="mega-section-title">{section.title}</h3>
            </div>
            <ul class="mega-section-links">
              {section.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
            {section.showMore && (
              <a class="mega-section-more" href={section.showMore.href}>
                {section.showMore.label}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            )}
          </div>
        ))
      }
    </div>

    {
      panel.brands && panel.brands.length > 0 && (
        <div class="mega-brands">
          {panel.brandsLabel && <span class="mega-brands-label">{panel.brandsLabel}</span>}
          <ul class="mega-brands-list">
            {panel.brands.map((brand) => (
              <li>
                <a href={brand.href}>{brand.name}</a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</div>

<style>
  /*
   * Mega-panel — wide dropdown beneath the masthead. The visibility is
   * driven by [hidden] toggled from Masthead JS (and a CSS-only hover
   * fallback in case JS doesn't load). When .has-mega:hover or
   * .has-mega.is-open is matched, we override the hidden attribute.
   */
  .mega-panel {
    display: none;
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    z-index: 40;
    background: #fff;
    color: var(--ink);
    border-top: 1px solid var(--line);
    box-shadow: 0 14px 40px -18px rgba(15, 19, 30, 0.28);
  }

  .mega-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1.75rem var(--gutter) 1.5rem;
  }

  .mega-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem 2rem;
  }

  @media (max-width: 1180px) {
    .mega-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 1024px) {
    .mega-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mega-section {
    min-width: 0;
  }

  .mega-section-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.45rem;
    border-bottom: 1px dashed var(--line);
  }

  .mega-section-ic {
    display: inline-flex;
    width: 26px;
    height: 26px;
    border-radius: 8px;
    background: var(--p-50);
    color: var(--p-700);
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .mega-section-ic svg {
    width: 14px;
    height: 14px;
  }

  .mega-section-title {
    font-size: 14px;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.005em;
    margin: 0;
    line-height: 1.25;
  }

  .mega-section-links {
    list-style: none;
    padding: 0;
    margin: 0 0 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
  }

  .mega-section-links a {
    display: block;
    padding: 0.18rem 0;
    font-size: 13.5px;
    color: var(--ink-soft);
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.12s;
  }

  .mega-section-links a:hover,
  .mega-section-links a:focus-visible {
    color: var(--p-700);
    text-decoration: underline;
    text-underline-offset: 2px;
    outline: none;
  }

  .mega-section-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--p-700);
    text-decoration: none;
  }

  .mega-section-more:hover,
  .mega-section-more:focus-visible {
    color: var(--p-900);
    outline: none;
  }

  .mega-section-more svg {
    width: 12px;
    height: 12px;
  }

  /* ============ Bottom brand row ============ */
  .mega-brands {
    margin-top: 1.5rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.5rem;
  }

  .mega-brands-label {
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    font-weight: 700;
  }

  .mega-brands-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
  }

  .mega-brands-list a {
    display: inline-block;
    padding: 6px 12px;
    background: var(--bg-warm);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.12s, background 0.12s, color 0.12s;
  }

  .mega-brands-list a:hover,
  .mega-brands-list a:focus-visible {
    border-color: var(--p-400);
    background: var(--p-50);
    color: var(--p-700);
    outline: none;
  }
</style>
