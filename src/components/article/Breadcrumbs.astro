---
import type { BreadcrumbItem } from "../../types/article";

interface Props {
  items: BreadcrumbItem[];
  /**
   * Optional context kicker (e.g. "Hloubková analýza · Elektronářadí")
   * rendered on the right side of the breadcrumb row. Audit point:
   * the kicker used to sit on its own line above the H1 — wasted
   * vertical space when the breadcrumb row had empty right gutter.
   */
  kicker?: string;
}

const { items, kicker } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Drobečková navigace">
  <ol>
    {
      items.map((item, i) => (
        <li>
          {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
          {i < items.length - 1 && <span class="sep" aria-hidden="true">›</span>}
        </li>
      ))
    }
  </ol>
  {kicker && <span class="breadcrumbs-kicker">{kicker}</span>}
</nav>

<style>
  .breadcrumbs {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1rem var(--gutter) 0;
    font-size: 13px;
    color: var(--muted);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
  }

  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
  }

  /*
   * Kicker sits inline next to the breadcrumb items (left aligned).
   * Earlier version used justify-content: space-between and threw the
   * pill to the far-right edge, which made it look like it belonged
   * to the sidebar TOC underneath. Inline keeps it visually tied to
   * the breadcrumb context.
   */
  .breadcrumbs-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--p-700);
    font-weight: 700;
    background: var(--p-50);
    padding: 2px 9px;
    border-radius: 999px;
    white-space: nowrap;
    line-height: 1.6;
  }

  /* Subtle separator dot between breadcrumb tail and kicker. */
  .breadcrumbs-kicker::before {
    content: "·";
    color: var(--muted-2);
    margin-right: 0.7rem;
    margin-left: -0.15rem;
    font-weight: 400;
  }

  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .breadcrumbs a {
    color: var(--muted);
    text-decoration: none;
  }

  .breadcrumbs a:hover,
  .breadcrumbs a:focus-visible {
    color: var(--p-700);
  }

  .breadcrumbs li:last-child span:not(.sep) {
    color: var(--ink);
    font-weight: 500;
  }

  .sep {
    color: var(--muted-2);
  }
</style>
