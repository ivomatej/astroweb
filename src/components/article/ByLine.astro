---
import type { Person, ByLineDates } from "../../types/article";

interface Props {
  author: Person;
  garant?: Person;
  dates: ByLineDates;
}

const { author, garant, dates } = Astro.props;

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}

const publishedHuman = formatCzechDate(dates.publishedAt);
const updatedHuman = dates.updatedAt ? formatCzechDate(dates.updatedAt) : undefined;
---

{/*
  3-column byline strip:
    Col 1 — Publikováno / Aktualizováno / Doba čtení, stacked
    Col 2 — Author
    Col 3 — Odborný garant (only rendered if provided)

  Each column is equal-width. No vertical dividers or extra eyebrows
  — clean rows, just label + value per meta line.
*/}
<div class:list={["byline", { "has-garant": !!garant }]}>
  <div class="byline-col byline-meta">
    <div class="byline-meta-row">
      <span class="byline-meta-label">Publikováno</span>
      <strong class="byline-meta-value">
        <time datetime={dates.publishedAt}>{publishedHuman}</time>
      </strong>
    </div>

    {
      updatedHuman && (
        <div class="byline-meta-row">
          <span class="byline-meta-label">Aktualizováno</span>
          <strong class="byline-meta-value">
            <time datetime={dates.updatedAt}>{updatedHuman}</time>
          </strong>
        </div>
      )
    }

    <div class="byline-meta-row">
      <span class="byline-meta-label">Doba čtení</span>
      <strong class="byline-meta-value">{dates.readingTimeMin} min</strong>
    </div>
  </div>

  <div class="byline-col byline-person">
    <div class:list={["byline-avatar", "author", { "has-photo": !!author.photoUrl }]}>
      {
        author.photoUrl ? (
          <img src={author.photoUrl} alt={author.name} />
        ) : (
          <span>{author.initials ?? author.name.slice(0, 2)}</span>
        )
      }
    </div>
    <div class="byline-text">
      <div class="byline-label">Autor</div>
      <div class="byline-name">
        <a href={`/autor/${author.slug}/`}>{author.name}</a>
      </div>
      <div class="byline-cred">{author.role}</div>
    </div>
  </div>

  {
    garant && (
      <div class="byline-col byline-person">
        <div class:list={["byline-avatar", "garant", { "has-photo": !!garant.photoUrl }]}>
          {
            garant.photoUrl ? (
              <img src={garant.photoUrl} alt={garant.name} />
            ) : (
              <span>{garant.initials ?? garant.name.slice(0, 2)}</span>
            )
          }
        </div>
        <div class="byline-text">
          <div class="byline-label">Odborný garant</div>
          <div class="byline-name">
            <a href="#garant">{garant.name}</a>
          </div>
          <div class="byline-cred">{garant.role}</div>
        </div>
      </div>
    )
  }
</div>

<style>
  .byline {
    margin: 1.5rem 0;
    padding: 1.1rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem 2rem;
    align-items: center;
  }

  .byline.has-garant {
    grid-template-columns: 1fr 1fr 1fr;
  }

  @media (max-width: 720px) {
    .byline,
    .byline.has-garant {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .byline-col {
    min-width: 0;
  }

  /* ============ Meta column ============
   * One row per meta item: label on the left, value bold on the right.
   * No icons / no uppercase eyebrows — keeps the strip visually quiet
   * so the people columns get the focus.
   */
  .byline-meta {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-size: 13.5px;
    color: var(--muted);
  }

  .byline-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    line-height: 1.35;
  }

  .byline-meta-label {
    color: var(--muted);
  }

  .byline-meta-value {
    color: var(--ink);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  /* ============ Person column (autor / garant) ============ */
  .byline-person {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .byline-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .byline-avatar.author {
    background: var(--p-100);
    color: var(--p-700);
  }

  .byline-avatar.garant {
    background: var(--amber-bg);
    color: var(--amber);
  }

  .byline-avatar.has-photo {
    background: transparent;
  }

  .byline-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .byline-text {
    min-width: 0;
  }

  .byline-label {
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    font-weight: 600;
  }

  .byline-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
  }

  .byline-name a {
    color: var(--ink);
    text-decoration: none;
  }

  .byline-name a:hover,
  .byline-name a:focus-visible {
    color: var(--p-700);
  }

  .byline-cred {
    font-size: 12.5px;
    color: var(--muted);
    margin-top: 2px;
    line-height: 1.35;
  }
</style>
