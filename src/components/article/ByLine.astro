---
import type { Person, ByLineDates } from "../../types/article";

interface Props {
  author: Person;
  garant?: Person;
  dates: ByLineDates;
}

const { author, garant, dates } = Astro.props;

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}

const publishedHuman = formatCzechDate(dates.publishedAt);
const updatedHuman = dates.updatedAt ? formatCzechDate(dates.updatedAt) : undefined;
---

<div class="byline">
  <div class="byline-people">
    <div class="byline-person">
      <div class:list={["byline-avatar", "author", { "has-photo": !!author.photoUrl }]}>
        {
          author.photoUrl ? (
            <img src={author.photoUrl} alt={author.name} />
          ) : (
            <span>{author.initials ?? author.name.slice(0, 2)}</span>
          )
        }
      </div>
      <div class="byline-text">
        <div class="byline-label">Autor</div>
        <div class="byline-name">
          <a href={`/autor/${author.slug}/`}>{author.name}</a>
        </div>
        <div class="byline-cred">{author.role}</div>
      </div>
    </div>

    {
      garant && (
        <div class="byline-person">
          <div class:list={["byline-avatar", "garant", { "has-photo": !!garant.photoUrl }]}>
            {
              garant.photoUrl ? (
                <img src={garant.photoUrl} alt={garant.name} />
              ) : (
                <span>{garant.initials ?? garant.name.slice(0, 2)}</span>
              )
            }
          </div>
          <div class="byline-text">
            <div class="byline-label">Odborný garant</div>
            <div class="byline-name">
              <a href="#garant">{garant.name}</a>
            </div>
            <div class="byline-cred">{garant.role}</div>
          </div>
        </div>
      )
    }
  </div>

  <div class="byline-meta">
    <span class="byline-meta-row">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
      </svg>
      Publikováno: <strong><time datetime={dates.publishedAt}>{publishedHuman}</time></strong>
    </span>

    {
      updatedHuman && (
        <span class="byline-meta-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="23 4 23 10 17 10" />
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
          </svg>
          Aktualizováno:
          <span class="upd-tag">
            <time datetime={dates.updatedAt}>{updatedHuman}</time>
          </span>
        </span>
      )
    }

    <span class="byline-meta-row">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      Doba čtení: <strong>{dates.readingTimeMin} min</strong>
    </span>
  </div>
</div>

<style>
  .byline {
    margin: 1.5rem 0;
    padding: 1.25rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .byline-people {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .byline-person {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .byline-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .byline-avatar.author {
    background: var(--p-100);
    color: var(--p-700);
  }

  .byline-avatar.garant {
    background: var(--amber-bg);
    color: var(--amber);
  }

  .byline-avatar.has-photo {
    background: transparent;
  }

  .byline-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .byline-label {
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    font-weight: 600;
  }

  .byline-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
  }

  .byline-name a {
    color: var(--ink);
    text-decoration: none;
  }

  .byline-name a:hover,
  .byline-name a:focus-visible {
    color: var(--p-700);
  }

  .byline-cred {
    font-size: 12.5px;
    color: var(--muted);
    margin-top: 1px;
  }

  .byline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.75rem;
    font-size: 13.5px;
    color: var(--muted);
  }

  .byline-meta-row {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .byline-meta-row svg {
    width: 14px;
    height: 14px;
    color: var(--muted-2);
  }

  .byline-meta-row strong {
    color: var(--ink);
    font-weight: 600;
  }

  .upd-tag {
    padding: 1px 8px;
    background: var(--green-bg);
    color: var(--green);
    border-radius: 999px;
    font-size: 12.5px;
    font-weight: 600;
  }
</style>
