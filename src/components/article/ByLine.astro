---
import type { Person, ByLineDates } from "../../types/article";

interface Props {
  author: Person;
  garant?: Person;
  dates: ByLineDates;
}

const { author, garant, dates } = Astro.props;

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}

const publishedHuman = formatCzechDate(dates.publishedAt);
const updatedHuman = dates.updatedAt ? formatCzechDate(dates.updatedAt) : undefined;

/*
 * Editorial rule (see docs/editorial-rules.md):
 *
 * Either Publikováno OR Aktualizováno is shown in the byline header,
 * never both. Switch decided by dates.significantUpdate:
 *   - false / undefined → show Publikováno (default for fresh articles)
 *   - true              → show Aktualizováno (post-significant-edit)
 *
 * The original publishedAt is still emitted in the JSON-LD on the
 * article page and stays visible in the History section.
 */
const showAsUpdated = dates.significantUpdate === true && !!updatedHuman;
---

{/*
  3-column byline strip:
    Col 1 — Publikováno / Aktualizováno / Doba čtení, stacked
    Col 2 — Author
    Col 3 — Odborný garant (only rendered if provided)

  Each column is equal-width. No vertical dividers or extra eyebrows
  — clean rows, just label + value per meta line.
*/}
<div class:list={["byline", { "has-garant": !!garant }]}>
  <div class="byline-col byline-meta">
    {
      showAsUpdated ? (
        <span class="byline-meta-row">
          <svg class="byline-meta-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="23 4 23 10 17 10" />
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
          </svg>
          Aktualizováno:
          <span class="upd-tag">
            <time datetime={dates.updatedAt}>{updatedHuman}</time>
          </span>
        </span>
      ) : (
        <span class="byline-meta-row">
          <svg class="byline-meta-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
          </svg>
          Publikováno: <strong><time datetime={dates.publishedAt}>{publishedHuman}</time></strong>
        </span>
      )
    }

    <span class="byline-meta-row">
      <svg class="byline-meta-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      Doba čtení: <strong>{dates.readingTimeMin} min</strong>
    </span>
  </div>

  <div class="byline-col byline-person">
    <div class:list={["byline-avatar", "author", { "has-photo": !!author.photoUrl }]}>
      {
        author.photoUrl ? (
          <img src={author.photoUrl} alt={author.name} />
        ) : (
          <span>{author.initials ?? author.name.slice(0, 2)}</span>
        )
      }
      <div class="byline-popover author-popover" role="tooltip" aria-hidden="true">
        <div class="bp-head">
          <div class:list={["bp-avatar", "author", { "has-photo": !!author.photoUrl }]}>
            {
              author.photoUrl ? (
                <img src={author.photoUrl} alt={author.name} />
              ) : (
                <span>{author.initials ?? author.name.slice(0, 2)}</span>
              )
            }
          </div>
          <div class="bp-head-text">
            <div class="bp-name">{author.name}</div>
            <div class="bp-role">{author.role}</div>
          </div>
        </div>
        <div class="bp-bio" set:html={author.bioHtml} />
        {author.credentials && author.credentials.length > 0 && (
          <ul class="bp-creds">
            {author.credentials.slice(0, 3).map((cred) => <li>{cred}</li>)}
          </ul>
        )}
        <a class="bp-link" href={`/autor/${author.slug}/`}>
          Otevřít profil autora
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
    <div class="byline-text">
      <div class="byline-label">Autor</div>
      <div class="byline-name">
        <a href={`/autor/${author.slug}/`}>{author.name}</a>
      </div>
      <div class="byline-cred">{author.role}</div>
    </div>
  </div>

  {
    garant && (
      <div class="byline-col byline-person">
        <div class:list={["byline-avatar", "garant", { "has-photo": !!garant.photoUrl }]}>
          {
            garant.photoUrl ? (
              <img src={garant.photoUrl} alt={garant.name} />
            ) : (
              <span>{garant.initials ?? garant.name.slice(0, 2)}</span>
            )
          }
          <div class="byline-popover garant-popover" role="tooltip" aria-hidden="true">
            <div class="bp-head">
              <div class:list={["bp-avatar", "garant", { "has-photo": !!garant.photoUrl }]}>
                {
                  garant.photoUrl ? (
                    <img src={garant.photoUrl} alt={garant.name} />
                  ) : (
                    <span>{garant.initials ?? garant.name.slice(0, 2)}</span>
                  )
                }
              </div>
              <div class="bp-head-text">
                <div class="bp-name">{garant.name}</div>
                <div class="bp-role">{garant.role}</div>
              </div>
            </div>
            <div class="bp-bio" set:html={garant.bioHtml} />
            {garant.credentials && garant.credentials.length > 0 && (
              <ul class="bp-creds">
                {garant.credentials.slice(0, 3).map((cred) => <li>{cred}</li>)}
              </ul>
            )}
            <a class="bp-link" href={`/autor/${garant.slug}/`}>
              Otevřít profil garanta
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>
        </div>
        <div class="byline-text">
          <div class="byline-label">Odborný garant</div>
          <div class="byline-name">
            <a href="#garant">{garant.name}</a>
          </div>
          <div class="byline-cred">{garant.role}</div>
        </div>
      </div>
    )
  }
</div>

<style>
  /*
   * Meta column is narrower than the person columns (≈ 0.85 fr vs
   * 1.15 fr each). Author / Garant get a bit more room because their
   * content — full name + role + photo — is wider than three short
   * "label · value" rows.
   */
  .byline {
    margin: 1.5rem 0;
    padding: 1.1rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 1.25rem 2rem;
    align-items: center;
  }

  .byline.has-garant {
    grid-template-columns: 0.85fr 1.15fr 1.15fr;
  }

  @media (max-width: 720px) {
    .byline,
    .byline.has-garant {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .byline-col {
    min-width: 0;
  }

  /* ============ Meta column ============
   * Inline row: [icon] Label: <bold value>  — matches the original
   * compact style. The Aktualizováno value is wrapped in a green pill
   * (.upd-tag) so the most volatile date pops visually.
   */
  .byline-meta {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 13.5px;
    color: var(--muted);
  }

  .byline-meta-row {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    line-height: 1.35;
  }

  .byline-meta-ic {
    width: 14px;
    height: 14px;
    color: var(--muted-2);
    flex-shrink: 0;
  }

  .byline-meta-row strong {
    color: var(--ink);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .upd-tag {
    padding: 1px 8px;
    background: var(--green-bg);
    color: var(--green-text);
    border-radius: 999px;
    font-size: 12.5px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  /* ============ Person column (autor / garant) ============ */
  .byline-person {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .byline-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
    overflow: visible;        /* let popover escape avatar bounds */
    position: relative;        /* popover positions to this */
    cursor: help;              /* signals "hover for more" */
  }

  .byline-avatar > img,
  .byline-avatar > span {
    border-radius: 50%;
    overflow: hidden;
    width: 100%;
    height: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .byline-avatar > img {
    object-fit: cover;
  }

  .byline-avatar.author {
    background: var(--p-100);
    color: var(--p-700);
  }

  .byline-avatar.garant {
    background: var(--amber-bg);
    color: var(--amber);
  }

  .byline-avatar.has-photo {
    background: transparent;
  }

  /* ============ Hover popover ============
   * Visible only on hover / focus of the avatar. Distinct visual from
   * the reference screenshot: card hugs the avatar's left edge, uses a
   * thick left border tinted in the role color (purple for author,
   * amber for garant), and the inline head puts avatar + name + role
   * on one row instead of stacked.
   */
  .byline-popover {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    z-index: 50;
    width: min(360px, 90vw);
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid var(--line);
    border-left: 4px solid var(--p-500);
    border-radius: var(--r-lg);
    box-shadow: 0 18px 44px -16px rgba(15, 19, 30, 0.28);
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition: opacity 0.15s ease-out, transform 0.15s ease-out;
    cursor: default;
  }

  .garant-popover {
    border-left-color: var(--amber);
  }

  .byline-avatar:hover .byline-popover,
  .byline-avatar:focus-within .byline-popover {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Tiny invisible bridge between avatar and popover so the cursor
     doesn't fall off the avatar while moving down to the card. */
  .byline-avatar::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 12px;
    pointer-events: none;
  }
  .byline-avatar:hover::after,
  .byline-avatar:focus-within::after {
    pointer-events: auto;
  }

  /* Hover popover hidden on touch / mobile — tap would show it and
     then nothing closes it cleanly. Keyboard focus on small screens
     would also be ambiguous. */
  @media (hover: none), (max-width: 720px) {
    .byline-popover { display: none; }
  }

  .bp-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px dashed var(--line);
    margin-bottom: 0.7rem;
  }

  .bp-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
  }
  .bp-avatar.author  { background: var(--p-100);   color: var(--p-700); }
  .bp-avatar.garant  { background: var(--amber-bg); color: var(--amber); }
  .bp-avatar.has-photo { background: transparent; }
  .bp-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .bp-name {
    font-size: 15px;
    font-weight: 800;
    color: var(--ink);
    line-height: 1.2;
  }

  .bp-role {
    font-size: 12.5px;
    color: var(--muted);
    margin-top: 1px;
  }

  .bp-bio {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }

  .bp-bio :global(p) { margin: 0 0 0.5rem; }
  .bp-bio :global(p:last-child) { margin-bottom: 0; }
  .bp-bio :global(strong) { color: var(--ink); }

  .bp-creds {
    list-style: none;
    padding: 0;
    margin: 0.7rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .bp-creds li {
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--p-700);
    background: var(--p-50);
    padding: 2px 8px;
    border-radius: 999px;
    font-weight: 700;
  }

  .garant-popover .bp-creds li {
    color: var(--amber-text);
    background: var(--amber-bg);
  }

  .bp-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.8rem;
    padding-top: 0.7rem;
    border-top: 1px dashed var(--line);
    width: 100%;
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: var(--p-700);
    text-decoration: none;
  }

  .garant-popover .bp-link {
    color: var(--amber-text);
  }

  .bp-link:hover,
  .bp-link:focus-visible {
    color: var(--p-900);
    outline: none;
  }

  .garant-popover .bp-link:hover,
  .garant-popover .bp-link:focus-visible {
    color: var(--amber);
  }

  .bp-link svg {
    width: 12px;
    height: 12px;
  }

  @media (prefers-reduced-motion: reduce) {
    .byline-popover { transition: none; }
  }

  .byline-text {
    min-width: 0;
  }

  .byline-label {
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    font-weight: 600;
  }

  .byline-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
  }

  .byline-name a {
    color: var(--ink);
    text-decoration: none;
  }

  .byline-name a:hover,
  .byline-name a:focus-visible {
    color: var(--p-700);
  }

  .byline-cred {
    font-size: 12.5px;
    color: var(--muted);
    margin-top: 2px;
    line-height: 1.35;
  }
</style>
