---
import type { HistoryEntry } from "../../types/article";
import PostSectionHead from "./PostSectionHead.astro";

interface Props {
  history: HistoryEntry[];
}

const { history } = Astro.props;

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}

const kindLabels: Record<HistoryEntry["kind"], string> = {
  publish: "První publikace",
  major: "Major",
  minor: "Minor",
  content: "Obsah",
  correction: "Oprava",
};
---

<section class="post-section history-section" id="historie">
  <PostSectionHead
    eyebrow="Transparentnost"
    title="Historie změn článku"
    icon="history"
  />
  <p class="post-section-lede">
    Úplná chronologie revizí článku — {history.length} záznam{history.length === 1 ? "" : history.length < 5 ? "y" : "ů"} od první publikace.
  </p>
  <ol class="history-compact">
    {
      history.map((entry) => (
        <li class="history-row">
          <span class="history-date-compact">
            <time datetime={entry.date}>{formatCzechDate(entry.date)}</time>
          </span>
          <span class:list={["history-tag", entry.kind]}>{kindLabels[entry.kind]}</span>
          <span class="history-title-compact">{entry.title}</span>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .post-section { margin: 2.5rem 0; }

  .post-section-lede {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--muted);
    margin-bottom: 1rem;
    max-width: 70ch;
  }

  .history-compact {
    list-style: none;
    padding: 0;
    margin: 0;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--bg);
  }

  .history-row {
    display: grid;
    grid-template-columns: 120px 90px 1fr;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--line-soft);
    align-items: center;
    font-size: 13.5px;
  }

  .history-row:last-child {
    border-bottom: 0;
  }

  .history-date-compact {
    color: var(--muted);
    font-family: var(--mono);
    font-size: 12.5px;
  }

  .history-tag {
    display: inline-flex;
    justify-content: center;
    padding: 2px 8px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    border-radius: 4px;
    align-self: center;
  }

  .history-tag.major { background: var(--accent-soft); color: var(--accent-text); }
  .history-tag.minor { background: var(--p-50); color: var(--p-700); }
  .history-tag.content { background: var(--amber-bg); color: var(--amber); }
  .history-tag.publish { background: var(--green-bg); color: var(--green); }
  .history-tag.correction { background: var(--red-bg); color: var(--red); }

  .history-title-compact {
    color: var(--ink);
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .history-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .history-tag {
      justify-self: flex-start;
    }
  }
</style>
