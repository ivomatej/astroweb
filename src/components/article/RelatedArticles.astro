---
import type { RelatedArticle } from "../../types/article";
import PostSectionHead from "./PostSectionHead.astro";

interface Props {
  items: RelatedArticle[];
}

const { items } = Astro.props;

const featured = items.find((item) => item.featured);
const rows = items.filter((item) => !item.featured);

const tagLabels: Record<RelatedArticle["tag"], string> = {
  navod: "Návod",
  srovnani: "Srovnání",
  tema: "Téma",
  top: "TOP",
  test: "Test",
};
---

<section class="post-section related-articles">
  <PostSectionHead
    eyebrow="Pokračujte ve výběru"
    title="Související články"
    icon="cube"
  />

  <div class="related-list">
    {
      featured && (
        <a href={featured.href} class="related-feat">
          <div class="related-feat-img">
            <svg viewBox="0 0 800 450" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <pattern id="stripes-feat" patternUnits="userSpaceOnUse" width="14" height="14" patternTransform="rotate(45)">
                  <rect width="14" height="14" fill="var(--p-100)" />
                  <line x1="0" y1="0" x2="0" y2="14" stroke="var(--p-300)" stroke-width="1" />
                </pattern>
              </defs>
              <rect width="800" height="450" fill="url(#stripes-feat)" />
            </svg>
            {featured.featuredEyebrow && (
              <div class="related-feat-tag">{featured.featuredEyebrow}</div>
            )}
          </div>
          <div class="related-feat-body">
            <div class="related-feat-title">{featured.title}</div>
            <p class="related-feat-desc">{featured.description}</p>
            <div class="related-feat-meta">
              {featured.featuredAuthor && <span>{featured.featuredAuthor}</span>}
              {featured.featuredAuthor && featured.featuredDate && <span class="dot">·</span>}
              {featured.featuredDate && <span>{featured.featuredDate}</span>}
              {featured.readingTimeMin && (
                <>
                  <span class="dot">·</span>
                  <span>⏱ {featured.readingTimeMin} min</span>
                </>
              )}
            </div>
          </div>
        </a>
      )
    }

    {
      rows.length > 0 && (
        <ol class="related-rows">
          {rows.map((row, i) => (
            <li>
              <a href={row.href} class="related-row">
                <span class="rr-num">{String(i + 2).padStart(2, "0")}</span>
                <div class="rr-body">
                  <span class:list={["rr-tag", row.tag]}>{tagLabels[row.tag]}</span>
                  <span class="rr-title">{row.title}</span>
                  <span class="rr-desc">{row.description}</span>
                </div>
                {row.readingTimeMin && <span class="rr-meta">{row.readingTimeMin} min</span>}
              </a>
            </li>
          ))}
        </ol>
      )
    }
  </div>
</section>

<style>
  .post-section {
    margin: 2.5rem 0;
  }

  .related-list {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.5rem;
  }

  .related-feat {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    color: var(--ink);
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }

  .related-feat:hover,
  .related-feat:focus-visible {
    border-color: var(--p-400);
    transform: translateY(-2px);
  }

  .related-feat-img {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--p-50);
    overflow: hidden;
  }

  .related-feat-img svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .related-feat-tag {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    padding: 4px 10px;
    background: var(--p-900);
    color: #fff;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    border-radius: var(--r-sm);
  }

  .related-feat-body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .related-feat-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.25;
    margin-bottom: 0.5rem;
  }

  .related-feat-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.55;
    margin-bottom: 0.85rem;
    flex: 1;
  }

  .related-feat-meta {
    font-size: 12.5px;
    color: var(--muted-2);
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .related-feat-meta .dot {
    color: var(--muted-2);
  }

  .related-rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    padding: 0.85rem 1rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s, background 0.15s;
  }

  .related-row:hover,
  .related-row:focus-visible {
    border-color: var(--p-400);
    background: var(--p-50);
  }

  .rr-num {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--muted-2);
    line-height: 1;
    padding-top: 4px;
  }

  .rr-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .rr-tag {
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: 3px;
    align-self: flex-start;
  }

  .rr-tag.navod { background: var(--p-100); color: var(--p-700); }
  .rr-tag.srovnani { background: var(--amber-bg); color: var(--amber); }
  .rr-tag.tema { background: var(--green-bg); color: var(--green); }
  .rr-tag.top { background: var(--accent-soft); color: var(--accent-text); }
  .rr-tag.test { background: var(--red-bg); color: var(--red); }

  .rr-title {
    font-size: 14.5px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
  }

  .rr-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.45;
  }

  .rr-meta {
    font-size: 12px;
    color: var(--muted-2);
    align-self: center;
    white-space: nowrap;
  }

  @media (max-width: 880px) {
    .related-list {
      grid-template-columns: 1fr;
    }
  }
</style>
