---
import type { ArticleSectionData } from "../../types/article";

interface Props {
  section: ArticleSectionData;
}

const { section } = Astro.props;
---

<section class="section" id={section.id}>
  <h2 data-num={section.num}>{section.title}</h2>
  <div class="section-body" set:html={section.bodyHtml}></div>
</section>

<style>
  .section {
    margin: 3rem 0 3.5rem;
    scroll-margin-top: 5rem;
  }

  .section h2 {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-size: clamp(1.55rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.18;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 1.4rem;
    padding-bottom: 0.9rem;
    background-image: linear-gradient(
      to right,
      var(--accent) 0 36px,
      transparent 36px 44px,
      var(--line) 44px 100%
    );
    background-repeat: no-repeat;
    background-position: left bottom;
    background-size: 100% 3px;
  }

  .section h2[data-num]::before {
    content: attr(data-num);
    flex-shrink: 0;
    font-family: var(--mono);
    font-size: 0.62em;
    font-weight: 700;
    color: var(--p-600);
    letter-spacing: 0.05em;
  }
</style>
