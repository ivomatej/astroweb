---
import type { AffiliateDisclosure } from "../../types/article";

interface Props {
  disclosure: AffiliateDisclosure;
}

const { disclosure } = Astro.props;

if (!disclosure.enabled) return null;
---

<div class="affiliate-disclosure">
  <div class="ad-ic" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <circle cx="12" cy="12" r="10" />
      <line x1="12" y1="8" x2="12" y2="12" />
      <line x1="12" y1="16" x2="12.01" y2="16" />
    </svg>
  </div>
  <div class="ad-body">
    <div class="ad-title">{disclosure.title}</div>
    <p class="ad-text" set:html={disclosure.bodyHtml}></p>
    {
      disclosure.link && (
        <a class="ad-link" href={disclosure.link.href}>
          {disclosure.link.label}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      )
    }
  </div>
</div>

<style>
  .affiliate-disclosure {
    margin: 1.5rem 0;
    padding: 1.25rem;
    background: var(--accent-soft);
    border: 1px solid rgba(255, 79, 0, 0.16);
    border-radius: var(--r-lg);
    display: flex;
    gap: 1rem;
  }

  .ad-ic {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #fff;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ad-ic svg {
    width: 16px;
    height: 16px;
  }

  .ad-title {
    font-size: 12.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 0.4rem;
  }

  .ad-text {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 0.6rem;
  }

  .ad-text :global(strong) {
    color: var(--ink);
    font-weight: 700;
  }

  .ad-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
  }

  .ad-link svg {
    width: 12px;
    height: 12px;
  }

  .ad-link:hover,
  .ad-link:focus-visible {
    color: var(--ink);
  }
</style>
