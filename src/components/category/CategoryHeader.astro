---
import type { Category } from "../../types/category";

interface Props {
  category: Category;
  articleCount: number;
}

const { category, articleCount } = Astro.props;
---

<header class:list={["cat-page-head", `accent-${category.accent}`]}>
  <div class="cat-page-inner">
    <p class="cat-page-eyebrow">Rubrika</p>
    <h1 class="cat-page-title">{category.name}</h1>
    <p class="cat-page-tagline">{category.tagline}</p>
    <p class="cat-page-desc">{category.description}</p>

    <div class="cat-page-meta">
      <span class="cat-page-count">
        <strong>{articleCount}</strong>
        {articleCount === 1 ? "článek" : articleCount < 5 ? "články" : "článků"}
      </span>
      {
        category.freshCount && (
          <span class="cat-page-fresh">
            <span class="dot" aria-hidden="true" /> {category.freshCount}{" "}
            {category.freshCount === 1
              ? "nový za posledních 90 dní"
              : category.freshCount < 5
                ? "nové za posledních 90 dní"
                : "nových za posledních 90 dní"}
          </span>
        )
      }
    </div>

    {
      category.topics.length > 0 && (
        <ul class="cat-page-topics">
          {category.topics.map((topic) => (
            <li>{topic}</li>
          ))}
        </ul>
      )
    }
  </div>
</header>

<style>
  .cat-page-head {
    border-bottom: 1px solid var(--line);
  }

  .cat-page-head.accent-purple { --accent-bg: var(--p-50);    --accent-fg: var(--p-700); }
  .cat-page-head.accent-amber  { --accent-bg: var(--amber-bg); --accent-fg: var(--amber); }
  .cat-page-head.accent-green  { --accent-bg: var(--green-bg); --accent-fg: var(--green); }
  .cat-page-head.accent-red    { --accent-bg: var(--red-bg);   --accent-fg: var(--red); }
  .cat-page-head.accent-blue   { --accent-bg: #e8eeff;         --accent-fg: #1e40af; }

  .cat-page-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--gutter);
  }

  .cat-page-eyebrow {
    font-family: var(--mono);
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-fg);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .cat-page-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }

  .cat-page-tagline {
    font-size: clamp(1.1rem, 1.6vw, 1.3rem);
    font-weight: 600;
    color: var(--ink-soft);
    line-height: 1.4;
    margin-bottom: 1rem;
  }

  .cat-page-desc {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 70ch;
    margin-bottom: 1.5rem;
  }

  .cat-page-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 13.5px;
    margin-bottom: 1.25rem;
  }

  .cat-page-count {
    color: var(--muted);
  }

  .cat-page-count strong {
    font-family: var(--mono);
    color: var(--ink);
    font-weight: 800;
    font-size: 1.1em;
    margin-right: 0.2rem;
  }

  .cat-page-fresh {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--accent-fg);
    font-weight: 600;
  }

  .cat-page-fresh .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-fg);
    box-shadow: 0 0 0 3px var(--accent-bg);
  }

  .cat-page-topics {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .cat-page-topics li {
    padding: 4px 11px;
    background: var(--accent-bg);
    color: var(--accent-fg);
    font-size: 12.5px;
    font-weight: 600;
    border-radius: 999px;
  }
</style>
