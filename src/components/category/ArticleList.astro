---
import type { ArticleCard } from "../../data/featured";

interface Props {
  articles: ArticleCard[];
  /** Optional heading shown above the list. */
  heading?: string;
  /** Optional subhead. */
  subhead?: string;
}

const { articles, heading, subhead } = Astro.props;

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}
---

<section class="art-list-section" aria-labelledby={heading ? "art-list-title" : undefined}>
  <div class="art-list-inner">
    {
      heading && (
        <header class="art-list-head">
          <h2 id="art-list-title" class="art-list-title">{heading}</h2>
          {subhead && <p class="art-list-sub">{subhead}</p>}
        </header>
      )
    }

    {
      articles.length === 0 ? (
        <p class="art-list-empty">
          V této rubrice zatím nemáme publikované články. Pracujeme na tom.
        </p>
      ) : (
        <ul class="art-list">
          {
            articles.map((article) => (
              <li>
                <a href={article.href} class:list={["art-card", `accent-${article.accent}`]}>
                  <div class="art-card-media">
                    {
                      article.coverSrc ? (
                        <img src={article.coverSrc} alt="" loading="lazy" decoding="async" />
                      ) : (
                        <div class="art-card-pattern">
                          <span>{article.coverPlaceholder ?? article.category}</span>
                        </div>
                      )
                    }
                    {article.badge && <span class="art-card-badge">{article.badge}</span>}
                  </div>
                  <div class="art-card-body">
                    <h3 class="art-card-title" set:html={article.title} />
                    <p class="art-card-perex">{article.perex}</p>
                    <div class="art-card-meta">
                      <span>{article.author}</span>
                      <span class="sep" aria-hidden="true">·</span>
                      <span>
                        <time datetime={article.date}>{formatCzechDate(article.date)}</time>
                      </span>
                      <span class="sep" aria-hidden="true">·</span>
                      <span>⏱ {article.readingTimeMin} min</span>
                    </div>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      )
    }
  </div>
</section>

<style>
  .art-list-section {
    background: var(--bg);
  }

  .art-list-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3rem) var(--gutter) clamp(3rem, 5vw, 4rem);
  }

  .art-list-head {
    margin-bottom: 1.5rem;
  }

  .art-list-title {
    font-size: clamp(1.3rem, 2.5vw, 1.65rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.2;
  }

  .art-list-sub {
    margin-top: 0.4rem;
    font-size: 14px;
    color: var(--muted);
  }

  .art-list-empty {
    padding: 2rem;
    text-align: center;
    color: var(--muted);
    font-size: 15px;
    background: var(--bg-warm);
    border: 1px dashed var(--line);
    border-radius: var(--r-lg);
  }

  .art-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 960px) {
    .art-list { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .art-list { grid-template-columns: 1fr; }
  }

  /* ---------- Card ---------- */

  .art-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--ink);
    height: 100%;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .art-card.accent-purple { --accent-bg: var(--p-50);    --accent-fg: var(--p-700); }
  .art-card.accent-amber  { --accent-bg: var(--amber-bg); --accent-fg: var(--amber); }
  .art-card.accent-green  { --accent-bg: var(--green-bg); --accent-fg: var(--green); }
  .art-card.accent-red    { --accent-bg: var(--red-bg);   --accent-fg: var(--red); }
  .art-card.accent-blue   { --accent-bg: #e8eeff;         --accent-fg: #1e40af; }

  .art-card:hover,
  .art-card:focus-visible {
    border-color: var(--accent-fg);
    transform: translateY(-3px);
    box-shadow: 0 14px 28px -16px rgba(46, 20, 102, 0.2);
    color: var(--ink);
  }

  .art-card-media {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--accent-bg);
    overflow: hidden;
  }

  .art-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .art-card-pattern {
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(45deg, var(--accent-bg) 0 10px, transparent 10px 20px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    text-align: center;
  }

  .art-card-pattern span {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-fg);
    font-weight: 600;
    max-width: 30ch;
  }

  .art-card-badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    padding: 3px 9px;
    background: rgba(15, 19, 30, 0.85);
    color: #fff;
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    border-radius: var(--r-sm);
    backdrop-filter: blur(4px);
  }

  .art-card-body {
    padding: 1.25rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .art-card-title {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    color: var(--ink);
    line-height: 1.3;
    margin: 0;
  }

  .art-card-title :global(em) {
    font-style: italic;
    color: var(--accent-fg);
  }

  .art-card-perex {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.55;
    margin: 0;
  }

  .art-card-meta {
    margin-top: auto;
    padding-top: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--muted-2);
  }

  .art-card-meta .sep {
    color: var(--muted-2);
  }
</style>
