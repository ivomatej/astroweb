---
import { getFeaturedArticleCards } from "../../data/featured";

const featuredArticles = getFeaturedArticleCards();
const hero = featuredArticles.find((a) => a.featured);
const rest = featuredArticles.filter((a) => !a.featured);

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}
---

<section class="feat-section" aria-labelledby="feat-title">
  <header class="feat-head">
    <div>
      <p class="feat-eyebrow">Nejnovější testy a hloubkové analýzy</p>
      <h2 id="feat-title" class="feat-title">Doporučujeme přečíst</h2>
    </div>
    <a href="/nejnovejsi/" class="feat-all-link">
      Všechny články
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
  </header>

  <div class="feat-grid">
    {
      hero && (
        <a href={hero.href} class:list={["feat-card", "hero", `accent-${hero.accent}`]}>
          <div class="feat-card-media">
            {
              hero.coverSrc ? (
                <img src={hero.coverSrc} alt="" loading="lazy" decoding="async" />
              ) : (
                <div class="feat-card-pattern">
                  <span>{hero.coverPlaceholder ?? hero.category}</span>
                </div>
              )
            }
            {hero.badge && <span class="feat-badge">{hero.badge}</span>}
          </div>
          <div class="feat-card-body">
            <p class="feat-card-cat">{hero.category}</p>
            <h3 class="feat-card-title" set:html={hero.title} />
            <p class="feat-card-perex">{hero.perex}</p>
            <div class="feat-card-meta">
              <span>{hero.author}</span>
              <span class="sep" aria-hidden="true">·</span>
              <span>
                <time datetime={hero.date}>{formatCzechDate(hero.date)}</time>
              </span>
              <span class="sep" aria-hidden="true">·</span>
              <span>⏱ {hero.readingTimeMin} min</span>
            </div>
          </div>
        </a>
      )
    }

    <div class="feat-secondary">
      {
        rest.map((article) => (
          <a href={article.href} class:list={["feat-card", "compact", `accent-${article.accent}`]}>
            <div class="feat-card-media">
              {
                article.coverSrc ? (
                  <img src={article.coverSrc} alt="" loading="lazy" decoding="async" />
                ) : (
                  <div class="feat-card-pattern">
                    <span>{article.coverPlaceholder ?? article.category}</span>
                  </div>
                )
              }
              {article.badge && <span class="feat-badge">{article.badge}</span>}
            </div>
            <div class="feat-card-body">
              <p class="feat-card-cat">{article.category}</p>
              <h3 class="feat-card-title">{article.title}</h3>
              <p class="feat-card-perex">{article.perex}</p>
              <div class="feat-card-meta">
                <span>{article.author}</span>
                <span class="sep" aria-hidden="true">·</span>
                <span>⏱ {article.readingTimeMin} min</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .feat-section {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--gutter);
  }

  .feat-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .feat-eyebrow {
    font-family: var(--mono);
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--p-700);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .feat-title {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--ink);
    line-height: 1.15;
  }

  .feat-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--p-700);
    text-decoration: none;
  }

  .feat-all-link svg {
    width: 13px;
    height: 13px;
  }

  .feat-all-link:hover,
  .feat-all-link:focus-visible {
    color: var(--p-900);
  }

  /* ---------- Grid ---------- */

  .feat-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1rem;
  }

  .feat-secondary {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (max-width: 960px) {
    .feat-grid {
      grid-template-columns: 1fr;
    }
    .feat-secondary {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 720px) {
    .feat-secondary {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Card base ---------- */

  .feat-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .feat-card.accent-purple { --accent-bg: var(--p-50);    --accent-fg: var(--p-700); }
  .feat-card.accent-amber  { --accent-bg: var(--amber-bg); --accent-fg: var(--amber); }
  .feat-card.accent-green  { --accent-bg: var(--green-bg); --accent-fg: var(--green); }
  .feat-card.accent-red    { --accent-bg: var(--red-bg);   --accent-fg: var(--red); }
  .feat-card.accent-blue   { --accent-bg: #e8eeff;         --accent-fg: #1e40af; }

  .feat-card:hover,
  .feat-card:focus-visible {
    border-color: var(--accent-fg);
    transform: translateY(-3px);
    box-shadow: 0 14px 28px -16px rgba(46, 20, 102, 0.2);
    color: var(--ink);
  }

  /* ---------- Hero card ---------- */

  .feat-card.hero .feat-card-media {
    aspect-ratio: 16 / 10;
  }

  .feat-card.hero .feat-card-title {
    font-size: clamp(1.35rem, 2vw, 1.7rem);
  }

  .feat-card.hero .feat-card-perex {
    font-size: 14.5px;
  }

  /* ---------- Compact card ---------- */

  .feat-card.compact {
    flex-direction: row;
  }

  .feat-card.compact .feat-card-media {
    flex: 0 0 38%;
    min-width: 0;
  }

  .feat-card.compact .feat-card-body {
    padding: 1rem 1.25rem;
  }

  .feat-card.compact .feat-card-title {
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .feat-card.compact .feat-card-perex {
    font-size: 13px;
  }

  @media (max-width: 960px) {
    .feat-card.compact {
      flex-direction: column;
    }
    .feat-card.compact .feat-card-media {
      flex: 0 0 auto;
      aspect-ratio: 16 / 10;
    }
  }

  /* ---------- Media ---------- */

  .feat-card-media {
    position: relative;
    overflow: hidden;
    background: var(--accent-bg);
    aspect-ratio: 16 / 10;
  }

  .feat-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feat-card-pattern {
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(45deg, var(--accent-bg) 0 10px, transparent 10px 20px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    text-align: center;
  }

  .feat-card-pattern span {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-fg);
    font-weight: 600;
    max-width: 30ch;
  }

  .feat-badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    padding: 3px 9px;
    background: rgba(15, 19, 30, 0.85);
    color: #fff;
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    border-radius: var(--r-sm);
    backdrop-filter: blur(4px);
  }

  /* ---------- Body ---------- */

  .feat-card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .feat-card-cat {
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-fg);
    font-weight: 700;
    margin: 0;
  }

  .feat-card-title {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.25;
    margin: 0;
  }

  .feat-card-title :global(em) {
    font-style: italic;
    color: var(--accent-fg);
  }

  .feat-card-perex {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.55;
    margin: 0;
  }

  .feat-card-meta {
    margin-top: auto;
    padding-top: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--muted-2);
  }

  .feat-card-meta .sep {
    color: var(--muted-2);
  }
</style>
