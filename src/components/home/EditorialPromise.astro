---
interface PromiseCard {
  href: string;
  icon: "lab" | "shield" | "doc" | "verify" | "search";
  title: string;
  description: string;
}

const cards: PromiseCard[] = [
  {
    href: "/metodika/",
    icon: "lab",
    title: "Metodika testů",
    description:
      "12 měřených parametrů, 7 disciplín, opakované měření 5× na model. Vše veřejně.",
  },
  {
    href: "/eticky-kodex/",
    icon: "shield",
    title: "Etický kodex",
    description:
      "6 pilířů editoriální etiky. Žádné placené hodnocení, žádné dárky od výrobců.",
  },
  {
    href: "/overovani-faktu/",
    icon: "verify",
    title: "Ověřování faktů",
    description:
      "Fact-checking ve 3 krocích. Každý článek prochází kontrolou odborného garanta.",
  },
  {
    href: "/duveryhodne-zdroje/",
    icon: "search",
    title: "Důvěryhodné zdroje",
    description:
      "342 citovaných zdrojů — normy, studie, granty, rozhovory s experty.",
  },
];
---

<section class="promise" aria-labelledby="promise-title">
  <div class="promise-inner">
    <header class="promise-head">
      <div>
        <p class="promise-eyebrow">Editorial standards</p>
        <h2 id="promise-title" class="promise-title">
          Proč Recenzeru můžete věřit
        </h2>
        <p class="promise-sub">
          Provozujeme nezávislou testovací laboratoř v Brně. Žádný model
          netestujeme „na ruku" — všechny jdou přes stejnou metodiku, stejné
          měřidla, stejné disciplíny. Výsledky publikujeme i tehdy, když nejsou
          příznivé pro značky, které u nás bývají oblíbené.
        </p>
      </div>
    </header>

    <ul class="promise-grid">
      {
        cards.map((card) => (
          <li>
            <a href={card.href} class="promise-card">
              <div class="promise-card-ic" aria-hidden="true">
                {card.icon === "lab" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 2v7.31" />
                    <path d="M14 9.3V2" />
                    <path d="M8.5 2h7" />
                    <path d="M14 9.3a6.5 6.5 0 1 1-4 0" />
                  </svg>
                )}
                {card.icon === "shield" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  </svg>
                )}
                {card.icon === "doc" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                  </svg>
                )}
                {card.icon === "verify" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="9 12 11 14 15 10" />
                  </svg>
                )}
                {card.icon === "search" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                  </svg>
                )}
              </div>
              <div class="promise-card-title">{card.title}</div>
              <p class="promise-card-desc">{card.description}</p>
              <span class="promise-card-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .promise {
    background: var(--bg-warm);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .promise-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(3rem, 5vw, 4rem) var(--gutter);
  }

  .promise-head {
    margin-bottom: 2rem;
    max-width: 60ch;
  }

  .promise-eyebrow {
    font-family: var(--mono);
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--p-700);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .promise-title {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--ink);
    line-height: 1.15;
    margin-bottom: 0.85rem;
  }

  .promise-sub {
    font-size: 15px;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  .promise-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.85rem;
  }

  @media (max-width: 980px) {
    .promise-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .promise-grid {
      grid-template-columns: 1fr;
    }
  }

  .promise-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r);
    text-decoration: none;
    color: var(--ink);
    height: 100%;
    transition: border-color 0.2s, transform 0.2s;
  }

  .promise-card:hover,
  .promise-card:focus-visible {
    border-color: var(--p-400);
    transform: translateY(-2px);
  }

  .promise-card-ic {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: var(--p-50);
    color: var(--p-700);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.35rem;
  }

  .promise-card-ic svg {
    width: 18px;
    height: 18px;
  }

  .promise-card-title {
    font-size: 14.5px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.25;
  }

  .promise-card-desc {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
  }

  .promise-card-arrow {
    margin-top: auto;
    padding-top: 0.5rem;
    color: var(--p-600);
    font-size: 1.1rem;
    align-self: flex-end;
  }
</style>
