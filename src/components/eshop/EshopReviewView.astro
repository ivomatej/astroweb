---
/**
 * Shared visual composition for an eshop-review detail. Extracted from
 * `src/pages/recenze-eshopu/[slug].astro` so the public page and the admin
 * draft-preview route render the review identically.
 *
 * `otherEshops` depends on the build-time published list, which is empty in the
 * preview deployment — that's fine, the section hides itself when empty. The
 * `founded`/`ownership`/`specialization` facts and `realTests` are fixture-only
 * (backend doesn't provide them) so they render only when present.
 */
import type { EshopReview } from "../../data/eshops";

interface Props {
  eshop: EshopReview;
  otherEshops?: EshopReview[];
}

const { eshop, otherEshops = [] } = Astro.props;

const verdictTone: Record<string, string> = {
  "doporučujeme": "green",
  "doporučujeme s výhradami": "amber",
  "nedoporučujeme": "red",
};

const facts = [
  eshop.founded ? { label: "Provoz od", value: eshop.founded } : null,
  eshop.ownership ? { label: "Vlastnictví", value: eshop.ownership } : null,
  eshop.specialization ? { label: "Sortiment", value: eshop.specialization } : null,
].filter((f): f is { label: string; value: string } => f !== null);
---

<!-- HERO -->
<header class={`esh-hero esh-tone-${verdictTone[eshop.verdict]}`}>
  <div class="inner esh-hero-grid">
    <div class="esh-logo-block">
      <div class="esh-logo" aria-hidden="true">
        <span>{eshop.name.slice(0, 2).toUpperCase()}</span>
      </div>
      <div class={`esh-score-card esh-score-${verdictTone[eshop.verdict]}`}>
        <span class="score-label">Naše skóre</span>
        <strong class="score-value">{eshop.overallScore}</strong>
        <span class="score-max">/ 100</span>
        <span class={`score-verdict score-verdict-${verdictTone[eshop.verdict]}`}>{eshop.verdict}</span>
      </div>
    </div>
    <div class="esh-info">
      <h1>{eshop.name}</h1>
      <a href={eshop.website} rel="noopener" target="_blank" class="esh-domain">
        {eshop.domain}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          <polyline points="15 3 21 3 21 9" />
          <line x1="10" y1="14" x2="21" y2="3" />
        </svg>
      </a>
      <p class="esh-tagline">{eshop.tagline}</p>
      {
        facts.length > 0 && (
          <dl class="esh-facts">
            {facts.map((f) => (
              <div>
                <dt>{f.label}</dt>
                <dd>{f.value}</dd>
              </div>
            ))}
          </dl>
        )
      }
    </div>
  </div>
</header>

<!-- METRICS -->
<section class="esh-metrics">
  <div class="inner">
    <header class="section-head">
      <p class="eyebrow">Hodnocení v 6 dimenzích</p>
      <h2>Co a jak jsme měřili</h2>
      <p class="lead">
        Skóre 0–5 v každé dimenzi. Měřeno reálnými testy — objednávkami, reklamacemi, chat / telefonní podporou.
      </p>
    </header>
    <ul class="metrics-grid">
      {
        eshop.metrics.map((m) => (
          <li class="metric-card">
            <header>
              <h3>{m.name}</h3>
              <div class="metric-score">
                <strong>{m.score.toFixed(1)}</strong>
                <span>/ 5</span>
              </div>
            </header>
            <div class="metric-bar-wrap">
              <div class="metric-bar" style={`width: ${(m.score / 5) * 100}%;`} />
            </div>
            <p>{m.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<!-- PROS / CONS -->
<section class="esh-pros-cons">
  <div class="inner pc-grid">
    <div class="pc-card pc-pros">
      <h2>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12" />
        </svg>
        Plusy
      </h2>
      <ul>
        {eshop.pros.map((p) => <li>{p}</li>)}
      </ul>
    </div>
    <div class="pc-card pc-cons">
      <h2>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
        Mínusy
      </h2>
      <ul>
        {eshop.cons.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </div>
</section>

<!-- BEST FOR / NOT FOR -->
<section class="esh-verdict-section">
  <div class="inner verdict-grid">
    <div class="verdict-card verdict-best">
      <span class="verdict-eyebrow">Doporučujeme pokud</span>
      <p>{eshop.bestFor}</p>
    </div>
    <div class="verdict-card verdict-not">
      <span class="verdict-eyebrow">Nedoporučujeme pokud</span>
      <p>{eshop.notFor}</p>
    </div>
  </div>
</section>

<!-- REAL TESTS -->
{
  eshop.realTests && eshop.realTests.length > 0 && (
    <section class="esh-tests">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">Reálné testy</p>
          <h2>Co konkrétně jsme zkusili</h2>
          <p class="lead">
            Žádné teorie. Tady jsou konkrétní objednávky, reklamace a kontakty s podporou, které jsme za posledních 12 měsíců provedli.
          </p>
        </header>
        <ol class="tests-list">
          {eshop.realTests.map((t, i) => (
            <li>
              <span class="test-num">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <h3>{t.title}</h3>
                <p>{t.result}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )
}

<!-- OTHER -->
{otherEshops.length > 0 && (
  <section class="esh-other">
    <div class="inner">
      <h2>Další recenze e-shopů</h2>
      <ul class="other-list">
        {otherEshops.map((e) => (
          <li>
            <a href={`/recenze-eshopu/${e.slug}/`}>
              <strong>{e.name}</strong>
              <span>{e.overallScore} / 100</span>
              <span class={`verdict-${verdictTone[e.verdict]}`}>{e.verdict}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="other-all">
        <a href="/recenze-eshopu/">Všechny recenze e-shopů</a>
      </p>
    </div>
  </section>
)}

<style>
  .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
  .section-head { max-width: 65ch; margin: 0 0 2rem; }
  .eyebrow {
    font-family: var(--mono); font-size: 11.5px; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--p-700); font-weight: 700; margin: 0 0 0.5rem;
  }
  .section-head h2 {
    font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.025em;
    color: var(--ink); line-height: 1.2; margin-bottom: 0.6rem;
  }
  .section-head .lead { font-size: 15px; line-height: 1.6; color: var(--muted); margin: 0; }

  /* HERO */
  .esh-hero {
    background:
      radial-gradient(900px circle at 90% 0%, rgba(21, 128, 61, 0.12), transparent 55%),
      var(--bg);
    border-bottom: 1px solid var(--line);
  }
  .esh-tone-amber {
    background:
      radial-gradient(900px circle at 90% 0%, rgba(180, 83, 9, 0.12), transparent 55%),
      var(--bg);
  }
  .esh-tone-red {
    background:
      radial-gradient(900px circle at 90% 0%, rgba(185, 28, 28, 0.12), transparent 55%),
      var(--bg);
  }
  .esh-hero .inner { padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
  .esh-hero-grid {
    display: grid; grid-template-columns: 220px 1fr; gap: 2rem;
    align-items: start;
  }
  @media (max-width: 700px) { .esh-hero-grid { grid-template-columns: 1fr; } }

  .esh-logo {
    width: 200px; height: 200px; border-radius: 28px;
    background: linear-gradient(135deg, var(--p-100), var(--p-200));
    color: var(--p-700);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--sans); font-weight: 800; font-size: 3.5rem;
    letter-spacing: -0.04em; margin-bottom: 1rem;
  }
  @media (max-width: 700px) { .esh-logo { width: 140px; height: 140px; font-size: 2.5rem; } }

  .esh-score-card {
    padding: 1.25rem; background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-lg);
    text-align: center;
    display: flex; flex-direction: column; gap: 0.3rem; align-items: center;
  }
  .esh-score-green { border-color: var(--green); }
  .esh-score-amber { border-color: var(--amber); }
  .esh-score-red { border-color: var(--red); }
  .score-label {
    font-family: var(--mono); font-size: 0.68rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted); font-weight: 700;
  }
  .score-value {
    font-family: var(--sans); font-size: 2.6rem; font-weight: 800;
    color: var(--p-700); letter-spacing: -0.025em; line-height: 1;
  }
  .esh-score-green .score-value { color: var(--green); }
  .esh-score-amber .score-value { color: var(--amber); }
  .esh-score-red .score-value { color: var(--red); }
  .score-max { font-family: var(--mono); font-size: 0.85rem; color: var(--muted); }
  .score-verdict {
    margin-top: 0.4rem;
    font-family: var(--mono); font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0.2rem 0.6rem; border-radius: 99px;
  }
  .score-verdict-green { background: var(--green-bg); color: var(--green); }
  .score-verdict-amber { background: var(--amber-bg); color: var(--amber); }
  .score-verdict-red { background: var(--red-bg); color: var(--red); }

  .esh-info h1 {
    font-family: var(--sans); font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800; letter-spacing: -0.025em; color: var(--ink);
    line-height: 1; margin: 0 0 0.5rem;
  }
  .esh-domain {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--mono); font-size: 1rem; color: var(--p-700);
    text-decoration: none; border-bottom: 1px dashed var(--p-300);
    margin-bottom: 1rem;
  }
  .esh-domain svg { width: 14px; height: 14px; }
  .esh-tagline {
    font-size: 1.1rem; line-height: 1.55; color: var(--ink-soft);
    margin: 0 0 1.5rem; max-width: 60ch;
  }
  .esh-facts {
    margin: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.6rem;
  }
  .esh-facts > div {
    padding: 0.7rem 0.95rem; background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-sm);
  }
  .esh-facts dt {
    font-family: var(--mono); font-size: 0.65rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted); margin-bottom: 0.2rem;
  }
  .esh-facts dd {
    margin: 0; font-size: 0.9rem; color: var(--ink); font-weight: 600;
  }

  /* METRICS */
  .esh-metrics { background: var(--bg-warm); border-bottom: 1px solid var(--line); }
  .metrics-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.85rem;
  }
  @media (max-width: 800px) { .metrics-grid { grid-template-columns: 1fr; } }
  .metric-card {
    padding: 1.5rem; background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-lg);
  }
  .metric-card header {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 1rem; margin-bottom: 0.85rem;
  }
  .metric-card h3 {
    margin: 0; font-size: 1.05rem; font-weight: 700; color: var(--ink);
  }
  .metric-score strong {
    font-family: var(--sans); font-size: 1.5rem; font-weight: 800;
    color: var(--ink); letter-spacing: -0.02em;
  }
  .metric-score span { font-family: var(--mono); font-size: 0.78rem; color: var(--muted); }
  .metric-bar-wrap {
    height: 8px; background: var(--line-soft); border-radius: 99px; overflow: hidden;
    margin-bottom: 0.85rem;
  }
  .metric-bar {
    height: 100%; background: linear-gradient(90deg, var(--p-500), var(--p-700));
    border-radius: 99px;
  }
  .metric-card p {
    margin: 0; font-size: 0.9rem; line-height: 1.6; color: var(--text);
  }

  /* PROS / CONS */
  .esh-pros-cons { background: var(--bg); border-bottom: 1px solid var(--line); }
  .pc-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;
  }
  @media (max-width: 700px) { .pc-grid { grid-template-columns: 1fr; } }
  .pc-card {
    padding: 1.75rem; border-radius: var(--r-lg); border: 1px solid var(--line);
  }
  .pc-pros { background: var(--green-bg); border-color: rgba(21, 128, 61, 0.2); }
  .pc-cons { background: var(--red-bg); border-color: rgba(185, 28, 28, 0.2); }
  .pc-card h2 {
    display: flex; align-items: center; gap: 0.5rem;
    margin: 0 0 1rem; font-size: 1.25rem; font-weight: 800; letter-spacing: -0.015em;
  }
  .pc-pros h2 { color: var(--green); }
  .pc-cons h2 { color: var(--red); }
  .pc-card h2 svg { width: 22px; height: 22px; }
  .pc-card ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .pc-card li {
    position: relative; padding-left: 1.5rem;
    line-height: 1.55; color: var(--text); font-size: 0.92rem;
  }
  .pc-pros li::before {
    content: "✓"; position: absolute; left: 0;
    color: var(--green); font-weight: 800;
  }
  .pc-cons li::before {
    content: "✕"; position: absolute; left: 0;
    color: var(--red); font-weight: 800;
  }

  /* VERDICT (best for / not for) */
  .esh-verdict-section { background: var(--bg-warm); border-bottom: 1px solid var(--line); }
  .verdict-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;
  }
  @media (max-width: 700px) { .verdict-grid { grid-template-columns: 1fr; } }
  .verdict-card {
    padding: 1.5rem 1.75rem; background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-lg);
  }
  .verdict-best { border-left: 4px solid var(--green); }
  .verdict-not { border-left: 4px solid var(--red); }
  .verdict-eyebrow {
    display: block; font-family: var(--mono);
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
    font-weight: 700; margin-bottom: 0.55rem;
  }
  .verdict-best .verdict-eyebrow { color: var(--green); }
  .verdict-not .verdict-eyebrow { color: var(--red); }
  .verdict-card p {
    margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--text);
  }

  /* TESTS */
  .esh-tests { background: var(--bg); border-bottom: 1px solid var(--line); }
  .tests-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.85rem;
  }
  .tests-list li {
    display: grid; grid-template-columns: 56px 1fr; gap: 1.25rem;
    padding: 1.25rem 1.5rem; background: var(--bg-warm);
    border: 1px solid var(--line); border-left: 3px solid var(--p-500);
    border-radius: var(--r-lg);
  }
  @media (max-width: 540px) { .tests-list li { grid-template-columns: 1fr; gap: 0.5rem; } }
  .test-num {
    font-family: var(--mono); font-size: 1.6rem; font-weight: 800;
    color: var(--p-300); line-height: 1;
  }
  .tests-list h3 {
    margin: 0 0 0.4rem; font-size: 1.05rem; font-weight: 700; color: var(--ink);
  }
  .tests-list p {
    margin: 0; line-height: 1.6; color: var(--text); font-size: 0.92rem;
  }

  /* OTHER */
  .esh-other { background: var(--bg-warm); }
  .esh-other h2 {
    font-family: var(--sans); font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    font-weight: 800; color: var(--ink); margin: 0 0 1.25rem; letter-spacing: -0.02em;
  }
  .other-list {
    list-style: none; padding: 0; margin: 0 0 1.25rem;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.65rem;
  }
  @media (max-width: 700px) { .other-list { grid-template-columns: 1fr; } }
  .other-list li a {
    display: flex; flex-direction: column; gap: 0.3rem;
    padding: 1rem 1.25rem; background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r);
    text-decoration: none; color: inherit;
    transition: border-color 0.15s ease;
  }
  .other-list li a:hover { border-color: var(--p-300); }
  .other-list strong { color: var(--ink); font-weight: 700; font-size: 1rem; }
  .other-list span:not(strong) {
    font-family: var(--mono); font-size: 0.78rem; color: var(--muted);
  }
  .verdict-green { color: var(--green) !important; font-weight: 700 !important; }
  .verdict-amber { color: var(--amber) !important; font-weight: 700 !important; }
  .verdict-red { color: var(--red) !important; font-weight: 700 !important; }
  .other-all { text-align: center; margin: 0; }
  .other-all a {
    color: var(--p-700); text-decoration: none;
    border-bottom: 1px dashed var(--p-300); font-weight: 600;
  }
</style>
