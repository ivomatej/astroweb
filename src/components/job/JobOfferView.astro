---
/**
 * Shared visual composition for a job offer detail. Extracted from
 * `src/pages/kariera/[slug].astro` so the public page and the admin
 * draft-preview route render the offer identically.
 *
 * `relatedJobs` powers the "Další pozice" footer; it depends on the
 * build-time published list, which is empty in the preview deployment —
 * that's fine, the offer itself (the thing being edited) comes live via
 * the token.
 */
import { jobTypeMeta, type JobOffer } from "../../data/jobs";

interface Props {
  job: JobOffer;
  relatedJobs?: JobOffer[];
}

const { job, relatedJobs = [] } = Astro.props;

const meta = jobTypeMeta[job.type];

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}

const employmentLabel = {
  ft: "Plný úvazek (HPP)",
  pt: "Částečný úvazek",
  freelance: "Smluvní spolupráce (faktura)",
  intern: "Stáž",
};
---

<!-- ============ HERO ============ -->
<header class={`job-hero tone-${meta.tone}`}>
  <div class="inner">
    <span class={`job-type job-type-${meta.tone}`}>{meta.label}</span>
    <h1 class="job-title">{job.title}</h1>
    <p class="job-summary">{job.summary}</p>

    <div class="job-meta-row">
      <div class="meta-item">
        <span class="meta-label">Úvazek</span>
        <strong>{employmentLabel[job.employment]}</strong>
      </div>
      <div class="meta-item">
        <span class="meta-label">Lokalita</span>
        <strong>{job.location}</strong>
      </div>
      <div class="meta-item">
        <span class="meta-label">Honorář</span>
        <strong>{job.compensation}</strong>
      </div>
      <div class="meta-item">
        <span class="meta-label">Zveřejněno</span>
        <strong><time datetime={job.postedAt}>{formatCzechDate(job.postedAt)}</time></strong>
      </div>
      {
        job.closingAt && (
          <div class="meta-item meta-deadline">
            <span class="meta-label">Uzávěrka</span>
            <strong>
              <time datetime={job.closingAt}>{formatCzechDate(job.closingAt)}</time>
            </strong>
          </div>
        )
      }
    </div>

    <div class="job-cta-row">
      <a href={`mailto:${job.contactEmail}?subject=${encodeURIComponent(`Pozice: ${job.title}`)}`} class="btn-apply">
        Reagovat e-mailem
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      <a href="/kariera/" class="btn-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="15 18 9 12 15 6" />
        </svg>
        Všechny pozice
      </a>
    </div>
  </div>
</header>

<!-- ============ BODY (2 sloupce: hlavní obsah + sticky apply card) ============ -->
<section class="job-section">
  <div class="inner job-grid">
    <article class="job-body">
      <!-- Description -->
      <div class="job-block">
        <h2>O pozici</h2>
        <div class="job-prose" set:html={job.descriptionHtml} />
      </div>

      <!-- Requirements -->
      <div class="job-block">
        <h2>Co od vás očekáváme</h2>
        <ul class="job-list req-list">
          {job.requirements.map((r) => <li set:html={r} />)}
        </ul>
      </div>

      {
        job.niceToHave && job.niceToHave.length > 0 && (
          <div class="job-block">
            <h2>Výhodou je (ale ne nutné)</h2>
            <ul class="job-list bonus-list">
              {job.niceToHave.map((n) => (
                <li set:html={n} />
              ))}
            </ul>
          </div>
        )
      }

      <!-- Offers -->
      <div class="job-block">
        <h2>Co nabízíme</h2>
        <ul class="job-list offers-list">
          {job.offers.map((o) => <li set:html={o} />)}
        </ul>
      </div>

      <!-- Apply section -->
      <div class="job-block apply-block" id="apply">
        <h2>Jak se hlásit</h2>
        <p>
          Pošlete na <a href={`mailto:${job.contactEmail}?subject=${encodeURIComponent(`Pozice: ${job.title}`)}`}>{job.contactEmail}</a>:
        </p>
        <ol class="apply-steps">
          <li>
            <strong>CV nebo LinkedIn profil</strong> — stačí jedno
          </li>
          <li>
            <strong>3 ukázky vaší práce</strong> — články, kód, redaktorské úpravy podle typu pozice
          </li>
          <li>
            <strong>2–3 věty, proč právě tato pozice</strong> — žádný motivační dopis
          </li>
        </ol>
        <p class="apply-note">
          <strong>Odpovídáme do 5 pracovních dnů</strong>, ať už pozitivně nebo negativně. Žádné „budeme se vám ozývat".
        </p>
      </div>
    </article>

    <aside class="job-aside">
      <div class="aside-card">
        <span class="aside-eyebrow">Kontaktní osoba</span>
        <strong class="aside-manager">{job.hiringManager}</strong>
        <a href={`mailto:${job.contactEmail}?subject=${encodeURIComponent(`Pozice: ${job.title}`)}`} class="aside-email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
          {job.contactEmail}
        </a>

        <hr />

        <span class="aside-eyebrow">Stručně</span>
        <ul class="aside-quick">
          <li><span>Úvazek</span> <strong>{employmentLabel[job.employment]}</strong></li>
          <li><span>Lokalita</span> <strong>{job.location}</strong></li>
          <li><span>Honorář</span> <strong>{job.compensation}</strong></li>
          {job.closingAt && (
            <li>
              <span>Uzávěrka</span>
              <strong><time datetime={job.closingAt}>{formatCzechDate(job.closingAt)}</time></strong>
            </li>
          )}
        </ul>

        <hr />

        <a href="#apply" class="aside-apply">
          Přejít na podání žádosti
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </a>
      </div>
    </aside>
  </div>
</section>

<!-- ============ RELATED LINKS ============ -->
<section class="job-related">
  <div class="inner">
    <header class="section-head">
      <h2>Další pozice</h2>
    </header>
    <ul class="related-list">
      {
        relatedJobs
          .filter((j) => j.slug !== job.slug)
          .slice(0, 3)
          .map((j) => (
            <li>
              <a href={`/kariera/${j.slug}/`} class="related-card">
                <span class={`related-tag related-tag-${jobTypeMeta[j.type].tone}`}>{jobTypeMeta[j.type].label}</span>
                <strong>{j.title}</strong>
                <span class="related-badge">{j.shortBadge}</span>
              </a>
            </li>
          ))
      }
    </ul>
    <p class="related-all">
      <a href="/kariera/">Všechny otevřené pozice</a>
    </p>
  </div>
</section>

<style>
  .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
  .section-head { max-width: 65ch; margin: 0 0 1.5rem; }
  .section-head h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.7rem); font-weight: 800;
    color: var(--ink); margin: 0; letter-spacing: -0.02em;
  }

  /* HERO */
  .job-hero {
    background:
      radial-gradient(900px circle at 90% 0%, rgba(149, 114, 240, 0.14), transparent 55%),
      radial-gradient(700px circle at 10% 110%, rgba(99, 50, 204, 0.08), transparent 55%),
      var(--bg);
    border-bottom: 1px solid var(--line);
  }
  .job-hero.tone-amber {
    background:
      radial-gradient(900px circle at 90% 0%, rgba(180, 83, 9, 0.12), transparent 55%),
      var(--bg);
  }
  .job-hero.tone-green {
    background:
      radial-gradient(900px circle at 90% 0%, rgba(21, 128, 61, 0.12), transparent 55%),
      var(--bg);
  }
  .job-hero.tone-red {
    background:
      radial-gradient(900px circle at 90% 0%, rgba(185, 28, 28, 0.12), transparent 55%),
      var(--bg);
  }
  .job-hero .inner { padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }

  .job-type {
    display: inline-block; font-family: var(--mono);
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em;
    font-weight: 700; padding: 0.25rem 0.6rem; border-radius: 99px;
    background: var(--p-50); color: var(--p-700); margin-bottom: 1rem;
  }
  .job-type-amber { background: var(--amber-bg); color: var(--amber); }
  .job-type-green { background: var(--green-bg); color: var(--green); }
  .job-type-red { background: var(--red-bg); color: var(--red); }
  .job-type-muted { background: var(--bg-warm); color: var(--muted); border: 1px solid var(--line); }

  .job-title {
    font-family: var(--sans); font-size: clamp(1.6rem, 3.8vw, 2.6rem);
    font-weight: 800; letter-spacing: -0.025em; color: var(--ink);
    line-height: 1.1; margin: 0 0 0.85rem; max-width: 24ch;
  }
  .job-summary {
    font-size: 1.1rem; line-height: 1.55; color: var(--ink-soft);
    margin: 0 0 1.5rem; max-width: 60ch;
  }

  .job-meta-row {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.75rem; margin-bottom: 1.5rem; max-width: 720px;
  }
  .meta-item {
    padding: 0.85rem 1rem; background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-sm);
  }
  .meta-deadline { border-color: var(--amber); background: var(--amber-bg); }
  .meta-label {
    display: block; font-family: var(--mono);
    font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted); margin-bottom: 0.2rem;
  }
  .meta-item strong { color: var(--ink); font-weight: 700; font-size: 0.92rem; }
  .meta-deadline strong { color: var(--amber); }

  .job-cta-row {
    display: flex; gap: 0.6rem; flex-wrap: wrap;
  }
  .btn-apply, .btn-back {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.85rem 1.4rem; border-radius: var(--r);
    font-size: 0.95rem; font-weight: 700; text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .btn-apply { background: var(--accent); color: #fff; border: 1px solid var(--accent); }
  .btn-apply:hover { background: #ff6600; transform: translateY(-1px); }
  .btn-apply svg { width: 14px; height: 14px; }
  .btn-back {
    background: var(--bg); color: var(--ink); border: 1px solid var(--line);
  }
  .btn-back:hover { border-color: var(--p-400); color: var(--p-700); }
  .btn-back svg { width: 14px; height: 14px; }

  /* BODY */
  .job-section { background: var(--bg-warm); border-bottom: 1px solid var(--line); }
  .job-grid {
    display: grid; grid-template-columns: 1fr 320px; gap: 2rem;
    align-items: start;
  }
  @media (max-width: 900px) { .job-grid { grid-template-columns: 1fr; } }

  .job-body { display: flex; flex-direction: column; gap: 1rem; }
  .job-block {
    padding: 1.75rem; background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-lg);
  }
  .job-block h2 {
    font-family: var(--sans); font-size: 1.25rem; font-weight: 800;
    color: var(--ink); margin: 0 0 1rem; letter-spacing: -0.015em;
  }
  .job-prose :global(p) {
    margin: 0 0 0.85rem; line-height: 1.7; color: var(--text);
  }
  .job-prose :global(p:last-child) { margin-bottom: 0; }
  .job-prose :global(strong) { color: var(--ink); font-weight: 600; }

  .job-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.55rem;
  }
  .job-list li {
    position: relative; padding-left: 1.6rem;
    font-size: 0.95rem; line-height: 1.6; color: var(--text);
  }
  .job-list li :global(strong) { color: var(--ink); font-weight: 600; }
  .req-list li::before {
    content: "✓"; position: absolute; left: 0;
    color: var(--green); font-weight: 800; font-size: 1.05rem; line-height: 1.5;
  }
  .bonus-list li::before {
    content: "★"; position: absolute; left: 0;
    color: var(--amber); font-weight: 800; line-height: 1.5;
  }
  .offers-list li::before {
    content: "→"; position: absolute; left: 0;
    color: var(--p-700); font-weight: 800; line-height: 1.5;
  }

  .apply-block { border-color: var(--p-300); background: var(--p-50); }
  .apply-block h2 { color: var(--p-700); }
  .apply-block p {
    margin: 0 0 1rem; line-height: 1.65; color: var(--text);
  }
  .apply-block p a {
    color: var(--p-700); font-weight: 700;
    text-decoration: none; border-bottom: 1px dashed var(--p-400);
  }
  .apply-steps {
    list-style: none; padding: 0; margin: 0 0 1rem;
    counter-reset: apply;
    display: flex; flex-direction: column; gap: 0.55rem;
  }
  .apply-steps li {
    counter-increment: apply; position: relative;
    padding: 0.75rem 1rem 0.75rem 3rem;
    background: var(--bg); border: 1px solid var(--line);
    border-radius: var(--r-sm); font-size: 0.92rem; line-height: 1.55;
  }
  .apply-steps li::before {
    content: counter(apply); position: absolute;
    left: 0.75rem; top: 50%; transform: translateY(-50%);
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--p-700); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono); font-weight: 700; font-size: 0.85rem;
  }
  .apply-steps li strong { color: var(--ink); font-weight: 700; }
  .apply-note {
    margin: 0 !important; padding: 0.85rem 1.1rem;
    background: var(--green-bg); border-left: 3px solid var(--green);
    border-radius: var(--r-sm); color: var(--text); font-size: 0.92rem;
  }
  .apply-note strong { color: var(--green); font-weight: 700; }

  /* ASIDE (sticky) */
  .job-aside { position: sticky; top: 1rem; }
  @media (max-width: 900px) { .job-aside { position: static; } }

  .aside-card {
    padding: 1.5rem; background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-lg);
    display: flex; flex-direction: column; gap: 0.6rem;
  }
  .aside-eyebrow {
    font-family: var(--mono); font-size: 0.68rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted); font-weight: 700;
  }
  .aside-manager {
    font-size: 1rem; font-weight: 700; color: var(--ink);
  }
  .aside-email {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--mono); font-size: 0.85rem;
    color: var(--p-700); text-decoration: none;
    padding: 0.55rem 0.75rem; background: var(--p-50);
    border-radius: var(--r-sm);
    word-break: break-all;
  }
  .aside-email:hover { background: var(--p-100); }
  .aside-email svg { width: 14px; height: 14px; flex-shrink: 0; }
  .aside-card hr {
    border: none; border-top: 1px dashed var(--line);
    margin: 0.25rem 0;
  }
  .aside-quick {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .aside-quick li {
    display: flex; justify-content: space-between; gap: 0.5rem;
    align-items: baseline; font-size: 0.85rem; color: var(--muted);
  }
  .aside-quick strong { color: var(--ink); font-weight: 600; text-align: right; }
  .aside-apply {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.4rem; padding: 0.85rem 1rem;
    background: var(--accent); color: #fff; border-radius: var(--r-sm);
    font-size: 0.9rem; font-weight: 700; text-decoration: none;
    transition: background 0.15s ease;
  }
  .aside-apply:hover { background: #ff6600; }
  .aside-apply svg { width: 14px; height: 14px; }

  /* RELATED */
  .job-related { background: var(--bg); }
  .related-list {
    list-style: none; padding: 0; margin: 0 0 1.25rem;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;
  }
  @media (max-width: 800px) { .related-list { grid-template-columns: 1fr; } }
  .related-card {
    display: flex; flex-direction: column; gap: 0.45rem;
    padding: 1.1rem 1.2rem; background: var(--bg-warm);
    border: 1px solid var(--line); border-radius: var(--r);
    text-decoration: none; color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .related-card:hover { border-color: var(--p-300); transform: translateY(-2px); }
  .related-tag {
    align-self: flex-start; font-family: var(--mono);
    font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em;
    padding: 0.15rem 0.5rem; border-radius: 99px; font-weight: 700;
    background: var(--p-50); color: var(--p-700);
  }
  .related-tag-amber { background: var(--amber-bg); color: var(--amber); }
  .related-tag-green { background: var(--green-bg); color: var(--green); }
  .related-tag-red { background: var(--red-bg); color: var(--red); }
  .related-tag-muted { background: var(--bg); color: var(--muted); border: 1px solid var(--line); }

  .related-card strong {
    color: var(--ink); font-size: 0.95rem; font-weight: 700; line-height: 1.4;
  }
  .related-badge {
    font-family: var(--mono); font-size: 0.72rem; color: var(--muted);
  }
  .related-all { text-align: center; margin: 0; }
  .related-all a {
    color: var(--p-700); text-decoration: none;
    border-bottom: 1px dashed var(--p-300); font-weight: 600;
  }
</style>
