---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleView from "../../components/article/ArticleView.astro";

import { articles, getArticleBySlug } from "../../data/articles";

export function getStaticPaths() {
  return articles
    .filter((a) => a.status === "published")
    .map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getArticleBySlug(slug!);

if (!article) {
  return Astro.redirect("/404");
}

/*
 * JSON-LD for Article schema.org.
 *
 * Both datePublished and dateModified are emitted whenever the
 * article has an updatedAt — regardless of the byline rule (which
 * may hide Publikováno from the header after a significant update).
 * Google / LLM crawlers still see the full date history here.
 *
 * See docs/editorial-rules.md for the byline visibility rule.
 */
const canonicalUrl = article.seo.canonical
  ?? `https://www.recenzer.cz/clanek/${article.slug}/`;
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title.replace(/<[^>]+>/g, ""),
  description: article.seo.description,
  url: canonicalUrl,
  datePublished: article.dates.publishedAt,
  ...(article.dates.updatedAt && { dateModified: article.dates.updatedAt }),
  author: {
    "@type": "Person",
    name: article.author.name,
    url: `https://www.recenzer.cz/autor/${article.author.slug}/`,
  },
  ...(article.garant && {
    reviewedBy: {
      "@type": "Person",
      name: article.garant.name,
      url: `https://www.recenzer.cz/autor/${article.garant.slug}/`,
    },
  }),
  publisher: {
    "@type": "Organization",
    name: "Recenzer.cz",
    url: "https://www.recenzer.cz/",
  },
  ...(article.cover.src && {
    image: `https://www.recenzer.cz${article.cover.src}`,
  }),
};

/*
 * Article page order.
 *
 * Main column:
 *   1. Breadcrumb
 *   2. H1 + perex (ArticleHeader)
 *   3. ByLine (autor + garant + dates) — sits just under the perex
 *      so the headline + intro reads together as one block, then the
 *      byline answers "kdo a kdy"
 *   4. Hero image
 *   5. ⚡ TLDR
 *   6. Inline TOC (mobile/tablet; desktop has the sidebar duplicate)
 *   7. Affiliate + Product acquisition in <details open> accordion
 *   8. Article body sections (H2 ↓)
 *   9. NextCta · Methodology · Rating · History · GarantSection ·
 *      RelatedArticles · CommentsSection · ReportErrorSection
 *  10. MakingSection (full-width)
 *
 * Right sidebar (desktop ≥1024 px, anchored at top, NOT sticky):
 *   • Table of contents with scroll-spy
 *   • Trust badges (TrustRow) — moved here from main column so they
 *     don't compete with body content for vertical space
 *   • Share row (copy link / e-mail / print)
 */
---

<BaseLayout
  title={article.seo.title ?? `${article.title.replace(/<[^>]+>/g, "")} | Recenzer`}
  description={article.seo.description}
  canonical={article.seo.canonical}
  ogImage={article.seo.ogImage}
  noIndex={article.seo.noIndex}
  showNewsletterBand
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />

  <ArticleView article={article} />
</BaseLayout>
