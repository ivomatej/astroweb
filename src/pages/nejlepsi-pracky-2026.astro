---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/article/Breadcrumbs.astro";
import ByLine from "../components/article/ByLine.astro";
import TrustRow from "../components/article/TrustRow.astro";
import AffiliateDisclosure from "../components/article/AffiliateDisclosure.astro";
import ProductAcquisitionSection from "../components/article/ProductAcquisitionSection.astro";
import MakingSection from "../components/article/MakingSection.astro";
import { ivoMatej, alenaRajnochova } from "../data/people";
import type {
  TrustPill,
  AffiliateDisclosure as AffDisclosure,
  ProductAcquisition,
} from "../types/article";

const productAcquisition: ProductAcquisition = {
  enabled: true,
  items: [
    {
      method: "purchased",
      note: "5 vítězných modelů + 12 srovnávacích — všechny koupeny redakcí v období 10/2025 — 02/2026. Celková investice 318 940 Kč. Faktury archivovány.",
    },
    {
      product: "Miele WCE 670 WCS (referenční prémiový model)",
      method: "loaned",
      note: "Zapůjčen showroomem Miele Praha na 6 týdnů srovnávacího testu (10–11/2025). Vrácen 22. 11. 2025 s protokolem.",
    },
  ],
  affectedRating: {
    answer: "partial",
    explanation:
      "<strong>Většina modelů byla nakoupena</strong>. U <em>jednoho referenčního modelu</em> (Miele WCE 670) jsme přijali zapůjčení od showroomu Miele — nikoliv pro účast v žebříčku, ale jako srovnávací benchmark prémiové kategorie. <strong>Miele tento model neumístili do našeho TOP 7</strong>, naopak — i přes zapůjčení jsme byli kritičtí k jeho cenové dostupnosti. Showroom o naší recenzi nevěděl předem.",
  },
  afterTest:
    "Bosch Serie 6 (vítěz) a LG F4WV510S0E (2. místo) zůstávají v laboratoři pro <strong>5letý dlouhodobý test</strong>. Ostatní zakoupené modely jsme prodali redaktorům nebo darovali škole. Miele WCE 670 byl vrácen do showroomu se servisní zprávou.",
};

interface TopModel {
  rank: number;
  name: string;
  tagline: string;
  capacity: string;
  energyClass: string;
  rpm: string;
  noise: string;
  rating: number;
  priceFrom: string;
  winnerLabel?: string;
  reviewHtml: string;
  pros: string[];
  cons: string[];
  bestFor: string;
}

const models: TopModel[] = [
  {
    rank: 1,
    name: "Bosch WGG244A0BY",
    tagline: "Nejlepší pračka roku 2026 — kombinace kvality, úspornosti a spolehlivosti, kterou nikdo jiný zatím nedosáhl.",
    capacity: "9 kg",
    energyClass: "A",
    rpm: "1400",
    noise: "52",
    rating: 91,
    priceFrom: "14 990 Kč",
    winnerLabel: "VÍTĚZ",
    reviewHtml: `<p>Bosch Serie 6 WGG244A0BY je <strong>etalonový model</strong> pro českou domácnost. Devítikilová kapacita pokrývá i větší rodiny, energetická třída A je v praxi opravdu plněná (naměřili jsme 0,82 kWh na Eco 40-60). Hluk 52 dB(A) při ždímání 1400 rpm je v dnešní střední třídě nadprůměrně tichý.</p><p>Po čtyřech měsících testu jsme nezjistili žádný strukturální problém. Bezkartáčový motor EcoSilence Drive funguje plynule a ovládací panel je intuitivní. Bosch standardně dává 10 let záruku na motor — pro pračku v této cenové kategorii unikátní.</p>`,
    pros: [
      "Reálná spotřeba odpovídá štítku (0,82 kWh / cyklus)",
      "Tichý chod 52 dB při 1400 rpm",
      "10 let záruka na motor",
      "Robustní stavba s ocelovým bubnem",
    ],
    cons: [
      "Žádná Wi-Fi konektivita (pro někoho výhoda)",
      "Pouze 4 rychlé programy",
    ],
    bestFor: "Univerzální volba — rodina 3–5 lidí, středně náročný uživatel.",
  },
  {
    rank: 2,
    name: "LG F4WV510S0E",
    tagline: "Nejlepší volba pro velkou rodinu — vysoká kapacita 10,5 kg a AI Direct Drive motor s desetiletou zárukou.",
    capacity: "10,5 kg",
    energyClass: "A",
    rpm: "1400",
    noise: "54",
    rating: 89,
    priceFrom: "16 490 Kč",
    reviewHtml: `<p>LG F4WV510S0E je <strong>vlajková loď</strong> pro rodiny s vyšším objemem prádla. Kapacita 10,5 kg znamená méně cyklů — místo 5 týdně stačí 3, což v praxi šetří jak elektřinu, tak čas. AI Direct Drive motor přizpůsobuje rytmus prání podle váhy a typu prádla.</p><p>V testu šetrnosti k vláknům dosáhla LG nejlepšího výsledku ze všech 31 testovaných modelů — úbytek 0,3 % vláken za cyklus. Aplikace LG ThinQ je v praxi použitelná, dálkové spuštění funguje spolehlivě.</p>`,
    pros: [
      "Velká kapacita 10,5 kg ideální pro 4+ člennou rodinu",
      "Nejlepší šetrnost k prádlu z testu (0,3 % úbytek vláken)",
      "Funkční Wi-Fi a app LG ThinQ",
      "10 let záruka na motor",
    ],
    cons: [
      "Cena o 1 500 Kč vyšší než alternativy",
      "Hloubka 56 cm — nepasuje do všech sestav",
    ],
    bestFor: "Velká rodina (4+ lidí), zájem o smart funkce a šetrnost k oblečení.",
  },
  {
    rank: 3,
    name: "Miele WCE 670 WCS",
    tagline: "Prémiová pračka pro náročné — tichý chod 49 dB a deklarovaná životnost 20 let testovaná na 5 000 cyklů.",
    capacity: "8 kg",
    energyClass: "A",
    rpm: "1400",
    noise: "49",
    rating: 88,
    priceFrom: "28 990 Kč",
    reviewHtml: `<p>Miele je <strong>kategorie sama o sobě</strong>. WCE 670 WCS prošla v testu Stiftung Warentest 5 000 cyklů — to odpovídá zhruba 20 letům běžného domácího provozu. Kvalita materiálů je znát: ocelový plášť, plně litinové komponenty motoru, kabeláž v plastu odolnému proti vibracím.</p><p>Hluk 49 dB je nejnižší ze všech testovaných — pračka může běžet vedle ložnice bez problému. Cena 29 000 Kč je vysoká, ale rozpočítaná na 20 let života vychází na 120 Kč/měsíc — méně než většina dotovaných modelů.</p>`,
    pros: [
      "Testovaná životnost 20 let / 5 000 cyklů",
      "Nejnižší hluk ze všech testovaných (49 dB)",
      "Plně litinový motor s 10letou zárukou",
      "Vysoká zbytková hodnota po 5 letech",
    ],
    cons: [
      "Pořizovací cena 29 000 Kč",
      "Méně programů než u konkurence",
      "Estetika může působit konzervativně",
    ],
    bestFor: "Náročný uživatel, který kupuje na 15–20 let dopředu a chce maximální klid.",
  },
  {
    rank: 4,
    name: "Samsung WW80T534DAW",
    tagline: "Univerzální volba s AI Wash — automatické dávkování pracího prostředku a 5 let záruka na motor.",
    capacity: "8 kg",
    energyClass: "A",
    rpm: "1400",
    noise: "53",
    rating: 86,
    priceFrom: "11 490 Kč",
    reviewHtml: `<p>Samsung WW80T534DAW je <strong>příjemné překvapení</strong> ve střední cenové třídě. AI Wash technologie skutečně funguje — pračka detekuje znečištění a automaticky upravuje množství vody i prostředku. V testu jsme šetřili v průměru 11 % prášku oproti manuálnímu dávkování.</p><p>Slabší stránkou je hluk 53 dB(A) — slyšitelný v sousední místnosti. Software je svižný, dotykový display je intuitivní. Záruka motoru je 5 let, což je standard, ale méně než Bosch/Miele.</p>`,
    pros: [
      "AI Wash spolehlivě šetří prostředek",
      "Nejlepší poměr cena/výkon v 8kg kategorii",
      "Rychlý a intuitivní dotykový display",
      "Energetická třída A reálně potvrzená",
    ],
    cons: [
      "Hluk 53 dB při ždímání",
      "Záruka na motor jen 5 let",
      "Plastový buben (ne ocelový)",
    ],
    bestFor: "Pár nebo malá rodina, příjemné chytré funkce za rozumnou cenu.",
  },
  {
    rank: 5,
    name: "Beko WUE 6612 WCST",
    tagline: "Nejlepší poměr cena/výkon — solidní 7 kg pračka do 9 000 Kč pro nenáročného uživatele.",
    capacity: "7 kg",
    energyClass: "A",
    rpm: "1200",
    noise: "57",
    rating: 85,
    priceFrom: "8 490 Kč",
    reviewHtml: `<p>Beko WUE 6612 WCST je <strong>rozumný kompromis</strong> pro nenáročného uživatele s omezeným rozpočtem. Sedmikilová kapacita a 1200 rpm ždímání pokryjí potřeby páru nebo malé rodiny. Energetická třída A je překvapivě plněná i ve spodním cenovém pásmu.</p><p>Hlučnost 57 dB(A) je vyšší — pračku doporučujeme umístit do koupelny nebo komory, ne otevřené kuchyně. Stavba je z větší části plastová, životnost odhadujeme na 8–10 let intenzivního provozu.</p>`,
    pros: [
      "Nejnižší pořizovací cena z TOP 5",
      "Energetická třída A reálně dodržena",
      "Kompaktní rozměry (hloubka 45 cm)",
    ],
    cons: [
      "Hlučnost 57 dB při ždímání",
      "1200 rpm — pomalejší schnutí",
      "Plastové komponenty, kratší životnost",
    ],
    bestFor: "Pár nebo singl s omezeným rozpočtem; pračka do koupelny.",
  },
];

const compareRows = [
  {
    label: "Kapacita",
    values: ["9 kg", "10,5 kg", "8 kg", "8 kg", "7 kg"],
  },
  {
    label: "Energetická třída",
    values: ["A", "A", "A", "A", "A"],
  },
  {
    label: "Otáčky",
    values: ["1400", "1400", "1400", "1400", "1200"],
  },
  {
    label: "Hluk (dB)",
    values: ["52", "54", "49", "53", "57"],
  },
  {
    label: "Spotřeba (kWh/cyklus)",
    values: ["0,82", "0,89", "0,78", "0,86", "0,95"],
  },
  {
    label: "Wi-Fi",
    values: ["—", "Ano", "Ano", "Ano", "—"],
  },
  {
    label: "Záruka motor",
    values: ["10 let", "10 let", "10 let", "5 let", "3 roky"],
  },
  {
    label: "Hloubka",
    values: ["55 cm", "56 cm", "60 cm", "55 cm", "45 cm"],
  },
  {
    label: "Cena od",
    values: ["14 990 Kč", "16 490 Kč", "28 990 Kč", "11 490 Kč", "8 490 Kč"],
  },
  {
    label: "Naše hodnocení",
    values: ["91 %", "89 %", "88 %", "86 %", "85 %"],
  },
];

const faqs = [
  {
    q: "Která pračka má nejlepší poměr cena/výkon v roce 2026?",
    a: "<strong>Samsung WW80T534DAW</strong> za 11 490 Kč nabízí AI Wash, 8kg kapacitu a třídu A. Pro užší rozpočet pak Beko WUE 6612 WCST za 8 490 Kč.",
  },
  {
    q: "Jaká pračka vydrží nejdéle?",
    a: "<strong>Miele WCE 670 WCS</strong> — testovaná na 5 000 cyklů, což odpovídá 20 letům běžného provozu. Vyšší pořizovací cena se rozpočítá na nízkou měsíční hodnotu.",
  },
  {
    q: "Stojí za to si pořídit pračku s Wi-Fi?",
    a: "Pokud chcete spouštět prání mimo domov nebo dostávat upozornění na konec cyklu, ano. Pokud používáte pračku „normálně\", chytré funkce jsou marginálně užitečné. Wi-Fi nemůže nahradit kvalitní bezkartáčový motor.",
  },
  {
    q: "Co je důležité při výběru pračky?",
    a: "1) Kapacita podle velikosti rodiny (singl 5–6 kg, pár 7 kg, rodina 8+ kg), 2) <strong>reálná spotřeba</strong> (ne jen štítek), 3) hluk při ždímání (do 55 dB pro otevřené prostory), 4) záruka motoru (preferujte 10 let).",
  },
];

const trustPills: TrustPill[] = [
  { kind: "verified-by-expert", label: "Ověřeno odborným garantem" },
  { kind: "tested-in-lab", label: "Testovací laboratoř Brno · 4 měsíce" },
  { kind: "sources", label: "31 testovaných modelů" },
  { kind: "no-sponsorship", label: "Bez sponzoringu" },
];

const affiliateDisclosure: AffDisclosure = {
  enabled: true,
  title: "Affiliate disclosure",
  bodyHtml:
    "Tento článek <strong>obsahuje affiliate odkazy</strong> na Heureku a partnerské e-shopy. Když kliknete a koupíte, dostaneme provizi z marže e-shopu — pro vás se cena nemění. Pořadí modelů určuje skóre z metodiky, ne výška provize.",
  link: { href: "/affiliate-disclosure/", label: "Detail affiliate modelu" },
};

const credibilityStats = [
  { label: "Testováno modelů", value: "31", unit: "praček" },
  { label: "Hodin v laboratoři", value: "560", unit: "hod" },
  { label: "Měsíců testů", value: "4" },
  { label: "Konzultací s experty", value: "3" },
];
---

<BaseLayout
  title="Nejlepší pračky 2026 — TOP 5 modelů | Recenzer"
  description="Otestovali jsme 31 praček v laboratoři po dobu 4 měsíců. Vybíráme 5 nejlepších modelů od 8 do 29 tisíc Kč. Detailní recenze, srovnání parametrů a doporučení podle rozpočtu."
>
  <Breadcrumbs items={[
    { href: "/", label: "Recenzer" },
    { href: "/domaci-spotrebice/", label: "Domácí spotřebiče" },
    { href: "/pracky/", label: "Pračky" },
    { label: "Nejlepší pračky 2026" },
  ]} />

  <div class="top-wrap">
    <div class="top-main">

      <header class="top-header">
        <div class="top-kicker">TOP 5 · Domácí spotřebiče</div>
        <h1 class="top-title">Nejlepší pračky 2026 — <em>TOP 5 modelů</em></h1>
        <p class="top-perex">
          Otestovali jsme <strong>31 praček v laboratoři po 4 měsíce</strong>. Vybrali jsme pět nejlepších modelů od 8 do 29 tisíc Kč. Pro každý rozpočet a každý typ domácnosti.
        </p>
      </header>

      <ByLine
        author={ivoMatej}
        garant={alenaRajnochova}
        dates={{ publishedAt: "2026-05-12", updatedAt: "2026-05-22", readingTimeMin: 14 }}
      />

      <TrustRow pills={trustPills} />

      <AffiliateDisclosure disclosure={affiliateDisclosure} />

      <ProductAcquisitionSection data={productAcquisition} />

      <!-- Intro -->
      <section class="top-section">
        <h2>Proč jsme vybrali právě tyto pračky</h2>
        <p>
          Z 31 modelů, které jsme za poslední 4 měsíce testovali v naší <a href="/testovaci-laborator/">brněnské laboratoři</a>, jsme vybrali pět, které vynikly v kombinaci spotřeby, hluku, šetrnosti k prádlu a životnosti motoru. <strong>Žádný model na seznamu není dotován výrobcem</strong> — všechny jsme nakupovali za běžnou tržní cenu.
        </p>
        <p>
          Pořadí vychází z váženého součtu: účinnost praní (30 %), spotřeba (20 %), šetrnost k prádlu (15 %), hluk (15 %), rychlost/kapacita (10 %), ovládání a stavba (10 %). Detail <a href="/jak-testujeme/pracky/">v protokolu testování praček v3.2</a>.
        </p>
      </section>

      <!-- TOP 5 ranked list -->
      <section class="top5-list" id="top5">
        <h2>TOP 5 praček 2026 — žebříček</h2>
        <p class="top5-lede">
          Rychlý přehled — klikněte na detail pro plnou recenzi modelu.
        </p>

        <ol class="top5-cards">
          {models.map((m) => (
            <li class:list={["top5-card", m.rank === 1 && "winner"]}>
              <header class="top5-head">
                <div class="top5-rank">{m.rank}</div>
                <div class="top5-info">
                  {m.winnerLabel && <span class="top5-winner-badge">{m.winnerLabel}</span>}
                  <h3>{m.name}</h3>
                  <p>{m.tagline}</p>
                </div>
                <div class="top5-price">
                  <span class="price-label">Cena od</span>
                  <span class="price-value">{m.priceFrom}</span>
                </div>
              </header>
              <ul class="top5-specs">
                <li><strong>{m.capacity}</strong> kapacita</li>
                <li>třída <strong>{m.energyClass}</strong></li>
                <li><strong>{m.rpm}</strong> ot/min</li>
                <li><strong>{m.noise}</strong> dB</li>
                <li class="rating"><strong>{m.rating} %</strong></li>
              </ul>
              <div class="top5-actions">
                <a href={`#detail-${m.rank}`} class="btn-secondary">Detailní recenze</a>
                <a href="#" class="btn-primary">
                  Porovnat ceny
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </a>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <!-- Detailed reviews -->
      <section class="top-section" id="detaily">
        <h2>Detailní recenze TOP 5</h2>

        {models.map((m) => (
          <article class="detail-card" id={`detail-${m.rank}`}>
            <header class="detail-head">
              <div class="detail-rank">#{m.rank}</div>
              <div>
                <h3>{m.name}</h3>
                <p class="detail-tagline">{m.tagline}</p>
              </div>
              <div class="detail-rating">
                <strong>{m.rating}</strong><span>/100</span>
              </div>
            </header>

            <div class="detail-specs">
              <div><span class="spec-label">Kapacita</span><strong>{m.capacity}</strong></div>
              <div><span class="spec-label">Třída</span><strong>{m.energyClass}</strong></div>
              <div><span class="spec-label">Otáčky</span><strong>{m.rpm}</strong></div>
              <div><span class="spec-label">Hluk</span><strong>{m.noise} dB</strong></div>
              <div><span class="spec-label">Cena od</span><strong>{m.priceFrom}</strong></div>
            </div>

            <div class="detail-review" set:html={m.reviewHtml}></div>

            <div class="proscons">
              <div class="proscons-col pros">
                <h4>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  Co se nám líbí
                </h4>
                <ul>{m.pros.map((p) => <li>{p}</li>)}</ul>
              </div>
              <div class="proscons-col cons">
                <h4>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                  </svg>
                  Co by mohlo být lepší
                </h4>
                <ul>{m.cons.map((c) => <li>{c}</li>)}</ul>
              </div>
            </div>

            <div class="detail-bestfor">
              <strong>Pro koho:</strong> {m.bestFor}
            </div>

            <div class="detail-cta">
              <a href="#" class="btn-primary">
                Porovnat ceny u prodejců
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </section>

      <!-- Comparison table -->
      <section class="top-section" id="srovnani">
        <h2>Srovnání parametrů TOP 5</h2>
        <p>
          Všechny klíčové parametry vedle sebe. Pro mobilní zařízení tabulku posuňte vodorovně.
        </p>
        <div class="compare-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th></th>
                {models.map((m) => (
                  <th>
                    <span class="th-rank">#{m.rank}</span>
                    <span class="th-name">{m.name.split(" ")[0]}</span>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {compareRows.map((row) => (
                <tr>
                  <th class="row-label">{row.label}</th>
                  {row.values.map((v) => <td>{v}</td>)}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- FAQ -->
      <section class="top-section" id="faq">
        <h2>Otázky a odpovědi</h2>
        <ul class="faq-list">
          {faqs.map((f) => (
            <li>
              <details>
                <summary>{f.q}</summary>
                <div class="faq-body" set:html={f.a}></div>
              </details>
            </li>
          ))}
        </ul>
      </section>

      <!-- Conclusion -->
      <section class="top-section" id="zaver">
        <h2>Závěr — kterou pračku koupit</h2>
        <p>
          Pokud chcete <strong>univerzální spolehlivou volbu</strong>, kupte Bosch WGG244A0BY. Pro <strong>velkou rodinu</strong> sáhněte po LG F4WV510S0E. Pokud máte rozpočet a kupujete <strong>na 20 let dopředu</strong>, Miele WCE 670 WCS je investice, která se vyplatí.
        </p>
        <p>
          Pokud chcete <strong>nejlepší poměr cena/výkon</strong>, vyberte Samsung WW80T534DAW. A pro úzký rozpočet je nejlepší volba <strong>Beko WUE 6612 WCST</strong>.
        </p>
        <div class="conclusion-actions">
          <a href="/jak-testujeme/pracky/" class="btn-secondary">Detailní metodika testu</a>
