---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../../components/page/PageBreadcrumbs.astro";
import BrandView from "../../components/brand/BrandView.astro";
import { brands, getBrandBySlug } from "../../data/brands";

export function getStaticPaths() {
  return brands.map((b) => ({ params: { slug: b.slug } }));
}

const { slug } = Astro.params;
const brand = getBrandBySlug(slug!);
if (!brand) return Astro.redirect("/znacky/");

// Doplňující značky pro related sekci
const relatedBrands = brands.filter((b) => b.slug !== brand.slug).slice(0, 3);
---

<BaseLayout
  title={`${brand.name} — profil značky a hodnocení | Recenzer.cz`}
  description={brand.tagline}
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { href: "/znacky/", label: "Značky" },
      { label: brand.name },
    ]}
  />

  <BrandView brand={brand} relatedBrands={relatedBrands} />
</BaseLayout>
