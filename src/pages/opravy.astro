    severity: "critical",
  },
];

// Typy a jejich štítky
const typeLabels: Record<CorrectionType, { label: string; color: string }> = {
  fact: { label: "Faktická chyba", color: "red" },
  spec: { label: "Parametr produktu", color: "amber" },
  price: { label: "Cena / dostupnost", color: "muted" },
  link: { label: "Nefunkční odkaz", color: "muted" },
  removal: { label: "Stažení modelu", color: "amber" },
  addition: { label: "Doplnění údaje", color: "purple" },
  style: { label: "Stylistika", color: "muted" },
  retraction: { label: "Stažení článku", color: "red" },
};

// Vypočítané statistiky
const totalCorrections = corrections.length;
const criticalCount = corrections.filter((c) => c.severity === "critical").length;
const reportedByReaders = corrections.filter(
  (c) => c.reporter && !c.reporter.toLowerCase().includes("interní") && !c.reporter.toLowerCase().includes("autor") && !c.reporter.toLowerCase().includes("garant") && !c.reporter.toLowerCase().includes("editorka") && !c.reporter.toLowerCase().includes("redaktor") && !c.reporter.toLowerCase().includes("technik"),
).length;

// Skupiny podle roku
const byYear: Record<string, Correction[]> = {};
corrections.forEach((c) => {
  const year = c.date.slice(0, 4);
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(c);
});
const years = Object.keys(byYear).sort((a, b) => b.localeCompare(a));

// Statistiky podle typu pro filter chips
const countByType: Record<CorrectionType, number> = {
  fact: 0,
  spec: 0,
  price: 0,
  link: 0,
  removal: 0,
  addition: 0,
  style: 0,
  retraction: 0,
};
corrections.forEach((c) => { countByType[c.type]++; });

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}

const stats = [
  { value: `${totalCorrections}`, label: "celkem oprav v archivu" },
  { value: `${reportedByReaders}`, label: "nahlásili čtenáři" },
  { value: `${criticalCount}`, label: "kritických oprav (s dopadem)" },
  { value: "100 %", label: "veřejně zaznamenáno" },
];
---

<BaseLayout
  title="Archiv oprav a errata — Recenzer.cz"
  description="Veřejný chronologický archiv všech oprav, doplnění a stažení článků na Recenzer.cz. Datum, typ opravy, dotčený článek, kdo nahlásil. Editoriální transparentnost v praxi."
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { label: "Archiv oprav" },
    ]}
  />

  <PageHero
    eyebrow="Editorial standards · errata archive"
    eyebrowIcon="check"
    title="Veřejný archiv<br/><em>oprav a errat</em>"
    subtitle="Žádná oprava článku se na Recenzer.cz neztratí. <strong>Každá změna od publikace</strong> — od překlepu po stažení celého článku — je trvale zaznamenaná v tomto chronologickém logu. Děkujeme všem čtenářům, kteří nás na chyby upozornili."
  />

  <!-- ============ STATS ============ -->
  <section class="stats-strip">
    <div class="inner">
      <ul>
        {
          stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ INTRO ============ -->
  <section class="errata-intro">
    <div class="inner">
      <div class="intro-grid">
        <div>
          <header class="section-head">
            <p class="eyebrow">Proč archiv vůbec máme</p>
            <h2>Oprava článku není ostudná</h2>
          </header>
          <p class="intro-text">
            Každý článek je výsledkem práce autora, garanta a editora — ale chyby se občas stanou. <strong>Co dělá redakci důvěryhodnou, není absence chyb, ale způsob, jak je opravuje.</strong>
          </p>
          <p class="intro-text">
            V tomto archivu najdete všech <strong>{totalCorrections} oprav</strong> publikovaných od ledna 2025. Od triviálních (špatná jednotka, překlep) až po závažné (stažení článku, chybný parametr s dopadem na bezpečnost).
          </p>
          <p class="intro-text">
            Pokud najdete v některém článku chybu, použijte
            <a href="/oprava-chyb/">formulář Nahlásit chybu</a> nebo napište přímo
            <a href="mailto:redakce@recenzer.cz">redakce@recenzer.cz</a>. Vaše jméno (nebo přezdívku) rádi přidáme do záznamu opravy.
          </p>
          <p class="intro-text">
            Hledáte spíš <strong>systémové chyby redakce</strong> — kde jsme se zmýlili na úrovni metodiky nebo etiky, ne jen v překlepu? Ty najdete na meta-stránce
            <a href="/nase-chyby/">Naše chyby</a>.
          </p>
        </div>
        <aside class="intro-aside">
          <h3>Jak číst tento archiv</h3>
          <ul>
            <li><strong>Datum</strong> — kdy byla oprava provedena (ne kdy byla nahlášena)</li>
            <li><strong>Typ</strong> — barevný štítek podle závažnosti</li>
            <li><strong>Článek</strong> — link na aktuální (opravenou) verzi</li>
            <li><strong>Změna</strong> — co se konkrétně opravilo</li>
            <li><strong>Reporter</strong> — kdo chybu odhalil</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============ FILTRY ============ -->
  <section class="errata-filters">
    <div class="inner">
      <div class="filter-row">
        <span class="filter-label">Filtrovat podle typu:</span>
        <button type="button" class="chip chip-active" data-filter-type="all">
          Vše <span class="chip-count">{totalCorrections}</span>
        </button>
        {
          (Object.keys(typeLabels) as CorrectionType[])
            .filter((t) => countByType[t] > 0)
            .map((t) => (
              <button type="button" class={`chip chip-${typeLabels[t].color}`} data-filter-type={t}>
                {typeLabels[t].label} <span class="chip-count">{countByType[t]}</span>
              </button>
            ))
        }
      </div>
    </div>
  </section>

  <!-- ============ ARCHIV (podle roku) ============ -->
  {
    years.map((year) => (
      <section class="errata-year">
        <div class="inner">
          <header class="year-head">
            <h2>{year}</h2>
            <span class="year-count">{byYear[year].length} {byYear[year].length === 1 ? "oprava" : byYear[year].length < 5 ? "opravy" : "oprav"}</span>
          </header>
          <ol class="corrections-list">
            {byYear[year].map((c) => (
              <li
                class={`correction-item correction-severity-${c.severity}`}
                data-type={c.type}
                data-category={c.category}
              >
                <div class="correction-date-wrap">
                  <time class="correction-date" datetime={c.date}>{formatCzechDate(c.date)}</time>
                  <span class={`correction-badge correction-badge-${typeLabels[c.type].color}`}>
                    {typeLabels[c.type].label}
                  </span>
                </div>
                <div class="correction-body">
                  <header class="correction-head">
                    <a href={c.articleHref} class="correction-article">{c.article}</a>
                    <span class="correction-category">{c.category}</span>
                  </header>
                  <p class="correction-change">{c.change}</p>
                  {c.reporter && (
                    <footer class="correction-reporter">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                      </svg>
                      <span>Nahlásil/upozornil: <strong>{c.reporter}</strong></span>
                    </footer>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </div>
      </section>
    ))
  }

  <!-- ============ POLICY ============ -->
  <section class="errata-policy">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Korekční politika</p>
        <h2>Pravidla, podle kterých provádíme opravy</h2>
        <p class="lead">
          Pět pravidel, která určují, jak postupujeme od přijetí podnětu po finální zveřejnění opravy.
        </p>
      </header>
      <ol class="policy-list">
        <li>
          <span class="policy-num">01</span>
          <div>
            <h3>Žádnou opravu nesmažeme</h3>
            <p>I když původní verze obsahovala chybu, zůstává v archivu. <strong>Smazat chybu by znamenalo přepsat historii.</strong> Tady evidujeme všechno — i interní omyly.</p>
          </div>
        </li>
        <li>
          <span class="policy-num">02</span>
          <div>
            <h3>Reportera vždy uvedeme (pokud chce)</h3>
            <p>Pokud nás čtenář upozorní na chybu, uvedeme ho do záznamu. Buď celé jméno, příjmení s iniciálou nebo přezdívkou — záleží na vás. Bez vašeho souhlasu uvedeme jen „Anonymní čtenář".</p>
          </div>
        </li>
        <li>
          <span class="policy-num">03</span>
          <div>
            <h3>Kritické chyby řešíme do 24 hodin</h3>
            <p>Chyba s dopadem na <strong>bezpečnost, zdraví nebo finanční rozhodnutí čtenáře</strong> má prioritu. Opravu provedeme do 24 hodin a v případě potřeby dočasně stáhneme článek do dořešení.</p>
          </div>
        </li>
        <li>
          <span class="policy-num">04</span>
          <div>
            <h3>Stažení článku je vzácné, ale možné</h3>
            <p>Pokud se ukáže, že článek obsahuje fundamentální chybu (např. nesprávná metodika testu, dezinformace), stáhneme ho. Opětovná publikace až po kompletním přepracování s vyznačením rozdílů v Historii revizí.</p>
          </div>
        </li>
        <li>
          <span class="policy-num">05</span>
          <div>
            <h3>Tento archiv má trvalý záznam</h3>
            <p>Archiv je <strong>versionovaný v Gitu</strong>. Každá oprava vytvoří commit, který je dohledatelný. I kdyby někdo (i my) chtěl historii smazat, repository obsahuje plnou stopu.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="errata-cta">
    <div class="inner">
      <div class="cta-card">
        <h2>Našli jste chybu?</h2>
        <p>
          Děkujeme. Stačí 2 minuty — vyplnit formulář nebo poslat e-mail. Opravu provedeme a vaše jméno přidáme do tohoto archivu (pokud budete chtít).
        </p>
        <div class="cta-actions">
          <a href="/oprava-chyb/" class="btn-primary">
            Nahlásit chybu (formulář)
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <a href="mailto:redakce@recenzer.cz?subject=Oprava v článku" class="btn-ghost">
            redakce@recenzer.cz
          </a>
          <a href="/sefredaktor/" class="btn-ghost">Eskalace na šéfredaktora</a>
        </div>
      </div>
      <p class="cta-meta">
        Archiv aktualizovaný <time datetime={lastUpdated}>{lastUpdated}</time> · Vedený od <strong>ledna 2025</strong> · Versionovaný v Gitu
      </p>
    </div>
  </section>

  <!-- ============ FILTER SCRIPT ============ -->
  <script is:inline>
    (function () {
      const chips = document.querySelectorAll("[data-filter-type]");
      const items = document.querySelectorAll(".correction-item");
      const years = document.querySelectorAll(".errata-year");

      function applyFilter(type) {
        items.forEach((item) => {
          const itemType = item.getAttribute("data-type");
          if (type === "all" || itemType === type) {
            item.style.display = "";
          } else {
            item.style.display = "none";
          }
        });
        // Hide year section if no visible items
        years.forEach((year) => {
          const visibleItems = year.querySelectorAll(".correction-item:not([style*='none'])");
          year.style.display = visibleItems.length > 0 ? "" : "none";
        });
      }

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          chips.forEach((c) => c.classList.remove("chip-active"));
          chip.classList.add("chip-active");
          applyFilter(chip.getAttribute("data-filter-type"));
        });
      });
    })();
  </script>

