---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";

const lastUpdated = "2026-05-21";

type CorrectionType =
  | "fact" // Faktická chyba (špatný údaj)
  | "spec" // Špatný parametr produktu
  | "price" // Cena / dostupnost
  | "link" // Nefunkční odkaz
  | "removal" // Stažení modelu (ukončení výroby, recall)
  | "addition" // Doplnění chybějícího údaje
  | "style" // Stylistická / gramatická
  | "retraction"; // Stažení celého článku / dementi

interface Correction {
  /** ISO datum opravy */
  date: string;
  /** Typ opravy */
  type: CorrectionType;
  /** Titulek dotčeného článku */
  article: string;
  /** Slug URL článku */
  articleHref: string;
  /** Kategorie pro filtr */
  category: string;
  /** Stručný popis opravy */
  change: string;
  /** Kdo opravu nahlásil / detekoval */
  reporter?: string;
  /** Závažnost — pro řazení a vizualizaci */
  severity: "critical" | "important" | "minor";
}

