<style>
  /* ============ PRODUCT HERO ============ */
  .product-hero {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2rem var(--gutter) 0;
  }

  .product-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .product-hero-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }

  .product-gallery-main {
    background: var(--bg-alt);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
    position: relative;
    overflow: hidden;
  }

  .product-gallery-placeholder {
    width: 160px;
    height: 160px;
    background: var(--bg);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted-2);
    border: 1px solid var(--line);
  }
  .product-gallery-placeholder svg { width: 80px; height: 80px; }

  .product-gallery-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    background: var(--accent);
    color: #fff;
    border-radius: 99px;
    font-family: var(--mono);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .product-gallery-badge svg { width: 11px; height: 11px; }

  .product-gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }

  .gallery-thumb {
    background: var(--bg-alt);
    border: 1.5px solid var(--line);
    border-radius: var(--r);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.15s ease;
    color: var(--muted-2);
  }
  .gallery-thumb:hover,
  .gallery-thumb.active {
    border-color: var(--p-500);
    background: var(--p-50);
    color: var(--p-700);
  }
  .gallery-thumb svg { width: 28px; height: 28px; }

  .product-info { min-width: 0; }

  .product-info-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .product-brand-link {
    background: var(--p-100);
    color: var(--p-700);
    padding: 0.25rem 0.6rem;
    border-radius: 99px;
    font-weight: 700;
    text-decoration: none;
  }
  .product-brand-link:hover { background: var(--p-200); }
  .product-category-link { color: var(--muted); }

  .product-info-title {
    font-family: var(--sans);
    font-size: clamp(1.85rem, 4vw, 2.6rem);
    line-height: 1.1;
    font-weight: 800;
    color: var(--ink);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .product-info-perex {
    font-size: 1.05rem;
    color: var(--text);
    line-height: 1.6;
    margin: 0 0 1.5rem;
  }
  .product-info-perex strong { color: var(--ink); font-weight: 600; }

  .product-rating-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem;
    background: var(--bg-warm);
    border-radius: var(--r);
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .product-rating-score { display: flex; align-items: baseline; gap: 0.2rem; }
  .product-rating-value {
    font-family: var(--sans);
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--ink);
    line-height: 1;
  }
  .product-rating-max { color: var(--muted); font-weight: 600; }
  .product-rating-info {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .product-rating-info strong { color: var(--ink); }

  .product-quick-specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 540px) {
    .product-quick-specs { grid-template-columns: repeat(2, 1fr); }
  }
  .quick-spec {
    padding: 0.7rem 0.85rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .quick-spec-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .quick-spec-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
  }
  .quick-spec-value small { font-weight: 400; color: var(--muted); }

  .product-price-box {
    padding: 1.25rem;
    background: linear-gradient(135deg, var(--p-700), var(--p-900));
    border-radius: var(--r);
    color: #fff;
  }
  .product-price-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.8;
    margin-bottom: 0.5rem;
  }
  .product-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    margin-bottom: 0.4rem;
  }
  .product-price-from { font-size: 0.95rem; opacity: 0.8; }
  .product-price-value {
    font-family: var(--sans);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }
  .product-price-stores {
    font-size: 0.8rem;
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .product-cta-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    border-radius: var(--r-sm);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .cta-btn svg { width: 14px; height: 14px; }
  .cta-btn:hover { transform: translateY(-1px); }
  .cta-btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .cta-btn-primary:hover { background: #ff6600; }
  .cta-btn-secondary {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }
  .cta-btn-secondary:hover { background: rgba(255, 255, 255, 0.25); }

  /* ============ META BAR ============ */
  .meta-bar {
    max-width: var(--max-w);
    margin: 2.5rem auto 0;
    padding: 0 var(--gutter);
  }
  .meta-bar-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-alt);
    border: 1px solid var(--line);
    border-radius: var(--r);
  }
  .meta-people {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .meta-person {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
  }
  .meta-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
  }
  .meta-avatar.author { background: var(--p-600); }
  .meta-avatar.garant { background: var(--amber); }
  .meta-person-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .meta-person-name {
    font-weight: 600;
    color: var(--ink);
    font-size: 0.95rem;
  }
  .meta-person:hover .meta-person-name { color: var(--p-700); }

  .meta-dates {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .meta-date-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .meta-date-item svg { width: 14px; height: 14px; }
  .meta-date-item strong { color: var(--ink); }
  .meta-date-item.updated svg { color: var(--green); }
  .meta-date-item.updated strong { color: var(--green); }

  /* ============ SECTION shared ============ */
  .section {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 4rem var(--gutter);
  }
  .section-header {
    margin-bottom: 2.25rem;
    max-width: 720px;
  }
  .section-header.center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  .section-eyebrow {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--p-700);
    margin-bottom: 0.5rem;
  }
  .section-title {
    font-family: var(--sans);
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.15;
    font-weight: 800;
    color: var(--ink);
    margin: 0 0 0.6rem;
    letter-spacing: -0.015em;
  }
  .section-subtitle {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ============ SCORE BREAKDOWN ============ */
  .score-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .score-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .score-grid { grid-template-columns: 1fr; }
  }
  .score-card {
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
  }
  .score-card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }
  .score-card-title {
    font-weight: 700;
    color: var(--ink);
    font-size: 1rem;
  }
  .score-card-value {
    font-family: var(--sans);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--ink);
  }
  .score-card-value small {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
  }
  .score-card-bar {
    height: 6px;
    background: var(--line-soft);
    border-radius: 99px;
    overflow: hidden;
    margin-bottom: 0.85rem;
  }
  .score-card-bar-fill {
    height: 100%;
    border-radius: 99px;
    background: var(--p-500);
  }
  .score-card-bar-fill-washing { background: linear-gradient(90deg, var(--p-500), var(--p-700)); }
  .score-card-bar-fill-energy { background: linear-gradient(90deg, var(--green), #0e6e36); }
  .score-card-bar-fill-noise { background: linear-gradient(90deg, var(--amber), #92400e); }
  .score-card-bar-fill-programs { background: linear-gradient(90deg, var(--p-400), var(--p-600)); }
  .score-card-bar-fill-design { background: linear-gradient(90deg, var(--accent), #cc4000); }
  .score-card-bar-fill-reliability { background: linear-gradient(90deg, var(--p-600), var(--p-900)); }

  .score-card-desc {
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.55;
    margin: 0;
  }

  /* ============ VERDICT ============ */
  .verdict-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  @media (max-width: 800px) {
    .verdict-grid { grid-template-columns: 1fr; }
  }
  .verdict-card {
    padding: 1.5rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
    border-left-width: 4px;
  }
  .verdict-card.recommended {
    border-color: #c2e8d0;
    border-left-color: var(--green);
    background: linear-gradient(180deg, var(--green-bg), var(--bg));
  }
  .verdict-card.skip {
    border-color: #f3c8c8;
    border-left-color: var(--red);
    background: linear-gradient(180deg, var(--red-bg), var(--bg));
  }
  .verdict-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .verdict-card-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
  }
  .verdict-card-icon svg { width: 18px; height: 18px; }
  .verdict-card.recommended .verdict-card-icon { background: var(--green); }
  .verdict-card.skip .verdict-card-icon { background: var(--red); }

  .verdict-card-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink);
  }
  .verdict-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .verdict-card-list li {
    padding: 0.7rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--text);
  }
  .verdict-card-list li:last-child { border-bottom: none; }
  .verdict-card-list li::before {
    position: absolute;
    left: 0;
    top: 0.7rem;
    font-weight: 800;
  }
  .verdict-card.recommended .verdict-card-list li::before {
    content: "✓";
    color: var(--green);
  }
  .verdict-card.skip .verdict-card-list li::before {
    content: "✕";
    color: var(--red);
  }
  .verdict-card-list li strong { color: var(--ink); font-weight: 700; }

  /* ============ SPECS TABLE ============ */
  .specs-section { background: var(--bg-alt); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .specs-table {
    max-width: var(--max-w-text);
    margin: 0 auto;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
    overflow: hidden;
  }
  .spec-group { border-bottom: 1px solid var(--line); }
  .spec-group:last-child { border-bottom: none; }
  .spec-group-title {
    padding: 0.9rem 1.25rem;
    background: var(--bg-warm);
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--p-700);
    font-weight: 700;
  }
  .spec-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--line-soft);
    font-size: 0.92rem;
  }
  .spec-row-label { color: var(--muted); }
  .spec-row-value { color: var(--ink); font-weight: 600; text-align: right; }
  .spec-row-value.highlight {
    color: var(--green);
    background: var(--green-bg);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  /* ============ DEEP DIVE ============ */
  .deep-dive-item {
    max-width: var(--max-w-text);
    margin: 0 auto 2rem;
    padding: 1.5rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
  }
  .deep-dive-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line-soft);
  }
  .deep-dive-title-block { flex: 1; min-width: 0; }
  .deep-dive-eyebrow {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.15rem;
  }
  .deep-dive-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
  }
  .deep-dive-rating {
    font-family: var(--sans);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--p-700);
    line-height: 1;
  }
  .deep-dive-rating small {
    font-size: 0.8rem;
    color: var(--muted);
    font-weight: 500;
  }
  .deep-dive-content p {
    margin: 0 0 0.85rem;
    line-height: 1.65;
    color: var(--text);
  }
  .deep-dive-content p:last-child { margin-bottom: 0; }
  .deep-dive-content strong { color: var(--ink); font-weight: 600; }

  /* ============ METHODOLOGY ============ */
  .methodology-section { background: var(--bg-alt); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .methodology-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .methodology-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .methodology-grid { grid-template-columns: 1fr; }
  }
  .methodology-card {
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
  }
  .methodology-card-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--p-700);
    margin-bottom: 0.3rem;
  }
  .methodology-card-title {
    font-weight: 700;
    color: var(--ink);
    font-size: 1rem;
    margin-bottom: 0.55rem;
  }
  .methodology-card-desc {
    font-size: 0.88rem;
    color: var(--text);
    line-height: 1.55;
  }
  .methodology-card-desc strong { color: var(--ink); font-weight: 600; }

  /* ============ PRICE COMPARISON ============ */
  .price-list {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
    overflow: hidden;
  }
  .price-row {
    display: grid;
    grid-template-columns: 1.5fr 2fr 1.4fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid var(--line-soft);
  }
  .price-row:last-of-type { border-bottom: none; }
  .price-row.best {
    background: linear-gradient(90deg, var(--green-bg), var(--bg));
    border-left: 4px solid var(--green);
  }
  @media (max-width: 800px) {
    .price-row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
  }
  .price-shop {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .price-shop-logo {
    width: 42px;
    height: 42px;
    border-radius: 8px;
    background: var(--p-700);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .price-shop-name {
    font-weight: 700;
    color: var(--ink);
  }
  .price-shop-name small {
    display: block;
    font-weight: 500;
    color: var(--muted);
    font-size: 0.78rem;
  }
  .price-availability { font-size: 0.85rem; color: var(--muted); }
  .price-availability small { display: block; margin-top: 0.2rem; }
  .price-status {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
  }
  .price-status.instock { background: var(--green-bg); color: var(--green); }
  .price-status.delayed { background: var(--amber-bg); color: var(--amber); }
  .price-value-block { text-align: right; }
  @media (max-width: 800px) {
    .price-value-block { text-align: left; }
  }
  .price-value {
    font-family: var(--sans);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--ink);
    line-height: 1;
  }
  .price-savings {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.78rem;
    color: var(--green);
    font-weight: 600;
  }
  .price-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.1rem;
    background: var(--accent);
    color: #fff;
    border-radius: var(--r-sm);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .price-btn svg { width: 14px; height: 14px; }
  .price-btn:hover { background: #ff6600; }

  .price-list-footer {
    padding: 1rem 1.25rem;
    background: var(--bg-warm);
    font-size: 0.85rem;
    color: var(--muted);
    text-align: center;
  }
  .price-list-footer strong { color: var(--ink); }
  .price-list-footer a { color: var(--p-700); }

  /* ============ USER REVIEWS ============ */
  .user-reviews-summary {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    align-items: center;
    padding: 1.5rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
    margin-bottom: 1.5rem;
  }
  @media (max-width: 700px) {
    .user-reviews-summary { grid-template-columns: 1fr; }
  }
  .user-reviews-big { text-align: center; }
  .user-reviews-big-value {
    font-family: var(--sans);
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--ink);
    line-height: 1;
  }
  .user-reviews-big-count {
    margin-top: 0.5rem;
    font-size: 0.88rem;
    color: var(--muted);
  }
  .reviews-distribution {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .distribution-row {
    display: grid;
    grid-template-columns: 40px 1fr 50px;
    gap: 0.6rem;
    align-items: center;
  }
  .distribution-stars {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--ink);
    font-weight: 600;
  }
  .distribution-bar-wrap {
    height: 8px;
    background: var(--line-soft);
    border-radius: 99px;
    overflow: hidden;
  }
  .distribution-bar {
    height: 100%;
    background: var(--p-500);
    border-radius: 99px;
  }
  .distribution-count {
    font-size: 0.8rem;
    color: var(--muted);
    text-align: right;
  }

  .reviews-quotes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .reviews-quotes-grid { grid-template-columns: 1fr; }
  }
  .review-quote {
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
  }
  .review-quote-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.7rem;
  }
  .review-quote-rating {
    font-family: var(--sans);
    font-weight: 800;
    color: var(--ink);
  }
  .review-quote-source {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .review-quote-text {
    margin: 0 0 0.85rem;
    font-style: italic;
    line-height: 1.55;
    color: var(--text);
  }
  .review-quote-author {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .review-quote-author-name { color: var(--ink); font-weight: 600; }

  /* ============ ALTERNATIVES ============ */
  .alternatives-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .alternatives-grid { grid-template-columns: 1fr; }
  }
  .alt-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.25rem;
