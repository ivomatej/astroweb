interface FaqItem {
  question: string;
  answerHtml: string;
  open?: boolean;
}

const faqItems: FaqItem[] = [
  {
    open: true,
    question: "Vyplatí se Bosch WGG244A0BY za 15 000 Kč?",
    answerHtml:
      "<p><strong>Ano, jednoznačně.</strong> Za 15 000 Kč dostanete pračku s parametry prémiové třídy — 10letá záruka motoru, energetická třída A, 20 programů včetně Allergy+. Konkurence v této ceně typicky nabízí maximálně 5letou záruku motoru a méně programů.</p><p>Za 10 let životnosti vyjde provoz asi na <strong>1 500 Kč ročně</strong> — investice se rozpouští v každodenním používání.</p>",
  },
  {
    question: "Jak hlučná je Bosch WGG244A0BY v paneláku?",
    answerHtml:
      "<p>Při <strong>praní 52 dB</strong> je velmi tichá — srovnatelná s tichou konverzací. Přes panelákovou stěnu téměř neslyšitelná.</p><p>Při <strong>odstředění 76 dB</strong> je hlasitější — slyšitelná z vedlejší místnosti, ale ne rušivá. Pro <strong>noční praní</strong> doporučujeme nastavit nižší otáčky (800–1000 ot/min) nebo program s redukcí vibrací.</p>",
  },
  {
    question: "Proč Bosch WGG244A0BY nemá Wi-Fi?",
    answerHtml:
      "<p>Bosch WGG244A0BY je model <strong>Series 4</strong>, který Wi-Fi nemá. Home Connect platforma je dostupná až od <strong>Series 6 a výše</strong> (modely WGG246A0BY+).</p><p>Podle naší zkušenosti je <strong>Wi-Fi v pračce zbytečnost</strong> — reálně ji používá max 10 % uživatelů a po pár týdnech přestane. Doplatek 2–4 000 Kč za WiFi modely se nevyplatí.</p>",
  },
  {
    question: "Co znamená 10letá záruka na motor EcoSilence?",
    answerHtml:
      "<p>Bosch poskytuje <strong>standardní 2letou záruku</strong> na celou pračku a <strong>rozšířenou 10letou záruku pouze na motor EcoSilence Drive</strong>. To znamená, že pokud do 10 let selže motor (nejdražší komponent), Bosch ho vymění zdarma.</p><p>Pozor — záruka se nevztahuje na pohyblivé části, ložiska ani elektroniku. Pro plnou ochranu zvažte <strong>rozšířené pojištění</strong> u prodejce (typicky 1 500–3 000 Kč za 5 let).</p>",
  },
  {
    question: "Vejde se Bosch WGG244A0BY do úzké koupelny?",
    answerHtml:
      "<p>Rozměry pračky jsou <strong>848 × 598 × 588 mm</strong> (V × Š × H). To je standardní velikost pro pračku s předním plněním.</p><p>Pro úzké koupelny (kde je méně než 60 cm šířky) byste museli zvolit <strong>úzký model</strong> — Bosch má řadu Serie WLR (45 cm hluboké) nebo WHT (40 cm hluboké). Tato pračka WGG244 je standardní velikosti.</p>",
  },
  {
    question: "Jak často je třeba čistit Bosch WGG244A0BY?",
    answerHtml:
      "<p>Pro dlouhou životnost doporučujeme:</p><p><strong>·</strong> <strong>Měsíčně</strong> — program „Drum Clean“ (60–90 °C, prázdná pračka)<br><strong>·</strong> <strong>Co 2–3 měsíce</strong> — vyčistit gumové těsnění a filtr odpadní vody<br><strong>·</strong> <strong>Co 6 měsíců</strong> — odvápnění (pokud máte tvrdou vodu)</p><p>Bosch má funkci <strong>Drum Clean Reminder</strong> — pračka sama upozorní, kdy ji vyčistit. Údržba prodlouží životnost o 20–30 %.</p>",
  },
];
---

<BaseLayout
  title={`${productName} recenze 2026 — test, parametry, cena | Recenzer.cz`}
  description={`Detailní recenze pračky ${productName}. Test 30 cyklů praní, energetická spotřeba, hlučnost, programy. Srovnání cen ve 4 e-shopech. Aktualizováno 5/2026.`}
>
  <Breadcrumbs
    items={[
      { label: "Domů", href: "/" },
      { label: "Domácí spotřebiče", href: "/domaci-spotrebice/" },
      { label: "Recenze", href: "/recenze/" },
      { label: productName },
    ]}
  />

  <!-- ============ PRODUCT HERO ============ -->
  <header class="product-hero">
    <div class="product-hero-grid">
      <!-- GALLERY -->
      <div class="product-gallery">
        <div class="product-gallery-main">
          <span class="product-gallery-badge">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg
            >
            Editor's Choice
          </span>
          <div class="product-gallery-placeholder" aria-label="Hlavní fotka produktu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"
              ><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="12" cy="13" r="5" /><circle cx="7" cy="7" r="1" /></svg
            >
          </div>
        </div>
        <div class="product-gallery-thumbs" role="list">
          {
            [0, 1, 2, 3].map((i) => (
              <button class={`gallery-thumb ${i === 0 ? "active" : ""}`} type="button" aria-label={`Fotka ${i + 1}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  {i === 0 && <circle cx="12" cy="13" r="5" />}
                  {i === 1 && <line x1="3" y1="9" x2="21" y2="9" />}
