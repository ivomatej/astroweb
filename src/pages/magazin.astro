---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";
import { getAllMagazineArticles, magazineKindMeta } from "../data/magazine";
import { allPeople } from "../data/people";

const articles = getAllMagazineArticles();
const lastUpdated = "2026-05-21";

function authorName(slug: string): string {
  return allPeople.find((p) => p.slug === slug)?.name ?? slug;
}

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}
---

<BaseLayout
  title="Magazín — krátké aktuality a komentáře | Recenzer.cz"
  description="Krátké zprávy z trhu, komentáře k novinkám a bezpečnostní upozornění. Aktuality z oblasti spotřební elektroniky, spotřebičů a auto-moto."
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Magazín" }]} />

  <PageHero
    eyebrow="Krátké aktuality · komentáře · varování"
    eyebrowIcon="info"
    title="Magazín<br/><em>z naší redakce</em>"
    subtitle={`${articles.length} krátkých článků — novinky z veletrhů, komentáře k tržním trendům, bezpečnostní upozornění. <strong>Reakce na události do 48 hodin</strong>, vždy s editoriálním pohledem, ne přepsanou tiskovou zprávou.`}
  />

  <section class="mag-list">
    <div class="inner">
      <ul class="articles-grid">
        {
          articles.map((a) => {
            const kindMeta = magazineKindMeta[a.kind];
            return (
              <li class={`mag-card mag-tone-${kindMeta.tone}`}>
                <header class="mag-head">
                  <span class={`mag-kind mag-kind-${kindMeta.tone}`}>{kindMeta.label}</span>
                  {a.category && <span class="mag-category">{a.category}</span>}
                  <time class="mag-date" datetime={a.publishedAt}>{formatCzechDate(a.publishedAt)}</time>
                </header>
                <h2 class="mag-title">
                  <a href={`/magazin/${a.slug}/`}>{a.title}</a>
                </h2>
                <p class="mag-perex">{a.perex}</p>
                <footer class="mag-footer">
                  <span class="mag-author">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </svg>
                    {authorName(a.authorSlug)}
                  </span>
                  <span class="mag-reading">{a.readingTimeMin} min čtení</span>
                  <a href={`/magazin/${a.slug}/`} class="mag-link">
                    Číst dále
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </a>
                </footer>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  <section class="mag-cta">
    <div class="inner">
      <div class="cta-card">
        <h2>Sledujte aktuality v RSS</h2>
        <p>
          Magazín i další obsah Recenzer.cz najdete v <strong>Atom feedu</strong> pro RSS čtečky.
        </p>
        <div class="cta-actions">
          <a href="/aktualizace.xml" class="btn-primary">
            Atom feed
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M4 11a9 9 0 0 1 9 9" />
              <path d="M4 4a16 16 0 0 1 16 16" />
              <circle cx="5" cy="19" r="1" />
            </svg>
          </a>
          <a href="/newsletter/" class="btn-ghost">Týdenní newsletter</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
    .mag-list { background: var(--bg-warm); border-bottom: 1px solid var(--line); }
    .articles-grid {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 1rem;
    }
    .mag-card {
      padding: 1.75rem 2rem; background: var(--bg);
      border: 1px solid var(--line); border-radius: var(--r-lg);
      transition: transform 0.15s ease, border-color 0.15s ease;
    }
    .mag-card:hover { transform: translateY(-1px); border-color: var(--p-300); }
    .mag-tone-green { border-left: 4px solid var(--green); }
    .mag-tone-amber { border-left: 4px solid var(--amber); }
    .mag-tone-red { border-left: 4px solid var(--red); }
    .mag-tone-purple { border-left: 4px solid var(--p-500); }

    .mag-head {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem;
      margin-bottom: 0.85rem;
    }
    .mag-kind {
      font-family: var(--mono); font-size: 0.68rem;
      text-transform: uppercase; letter-spacing: 0.08em;
      padding: 0.2rem 0.55rem; border-radius: 99px; font-weight: 700;
    }
    .mag-kind-green { background: var(--green-bg); color: var(--green); }
    .mag-kind-amber { background: var(--amber-bg); color: var(--amber); }
    .mag-kind-red { background: var(--red-bg); color: var(--red); }
    .mag-kind-purple { background: var(--p-50); color: var(--p-700); }
    .mag-category {
      font-family: var(--mono); font-size: 0.7rem;
      text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--muted); padding: 0.15rem 0.5rem;
      background: var(--bg-warm); border-radius: 4px;
    }
    .mag-date {
      font-family: var(--mono); font-size: 0.78rem; color: var(--muted);
    }

    .mag-title {
      margin: 0 0 0.7rem; font-size: clamp(1.15rem, 2.2vw, 1.4rem);
      font-weight: 800; color: var(--ink);
      letter-spacing: -0.015em; line-height: 1.3;
    }
    .mag-title a {
      color: var(--ink); text-decoration: none;
      border-bottom: 1px dashed var(--p-300);
    }
    .mag-title a:hover { color: var(--p-700); border-bottom-style: solid; }
    .mag-perex {
      margin: 0 0 1rem; font-size: 0.95rem; line-height: 1.6; color: var(--text);
    }

    .mag-footer {
      display: flex; flex-wrap: wrap; gap: 0.5rem 1rem;
      align-items: center; padding-top: 0.85rem;
      border-top: 1px dashed var(--line);
    }
    .mag-author {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.85rem; color: var(--muted);
    }
    .mag-author svg { width: 13px; height: 13px; color: var(--p-700); }
    .mag-reading {
      font-family: var(--mono); font-size: 0.78rem; color: var(--muted);
    }
    .mag-link {
      margin-left: auto; display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.5rem 0.95rem; background: var(--p-700); color: #fff;
      border-radius: var(--r-sm); font-size: 0.85rem; font-weight: 700;
      text-decoration: none; transition: background 0.15s ease;
    }
    .mag-link:hover { background: var(--p-800); color: #fff; }
    .mag-link svg { width: 12px; height: 12px; }

    /* CTA */
    .mag-cta { background: var(--bg); }
    .cta-card {
      max-width: 760px; margin: 0 auto;
      padding: 2.5rem 2rem;
      background: linear-gradient(135deg, var(--p-700), var(--p-900));
      color: #fff; border-radius: var(--r-xl); text-align: center;
    }
    .cta-card h2 {
      font-size: clamp(1.4rem, 2.6vw, 1.85rem); font-weight: 800;
      letter-spacing: -0.02em; margin-bottom: 0.6rem;
    }
    .cta-card p {
      font-size: 1rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85);
      margin: 0 auto 1.5rem;
    }
    .cta-card p strong { color: #ffd166; }
    .cta-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; }
    .btn-primary, .btn-ghost {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.8rem 1.3rem; border-radius: var(--r);
      font-size: 0.9rem; font-weight: 700; text-decoration: none;
    }
    .btn-primary { background: var(--accent); color: #fff; border: 1px solid var(--accent); }
    .btn-primary:hover { background: #ff6600; }
    .btn-primary svg { width: 14px; height: 14px; }
    .btn-ghost {
      background: rgba(255, 255, 255, 0.12); color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.25);
    }
    .btn-ghost:hover { background: rgba(255, 255, 255, 0.2); }
  </style>
</BaseLayout>
