---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";
import {
  getAllThreads,
  categoryMeta,
  getCategoryCounts,
  badgeMeta,
  type ForumCategory,
} from "../data/forum";

const threads = getAllThreads();
const counts = getCategoryCounts();
const totalReplies = threads.reduce((sum, t) => sum + t.replyCount, 0);
const totalViews = threads.reduce((sum, t) => sum + t.viewCount, 0);

const stats = [
  { value: `${threads.length}`, label: "aktivních vláken" },
  { value: `${totalReplies}`, label: "odpovědí" },
  { value: `${totalViews.toLocaleString("cs-CZ")}`, label: "zobrazení celkem" },
  { value: "240+", label: "registrovaných uživatelů" },
];

const statusLabel: Record<string, { label: string; tone: string }> = {
  open: { label: "Otevřené", tone: "purple" },
  resolved: { label: "Vyřešeno", tone: "green" },
  locked: { label: "Uzamčeno", tone: "muted" },
};
---

<BaseLayout
  title="Diskuze a fórum — Recenzer.cz"
  description={`${threads.length} aktivních vláken v diskuzi Recenzer.cz. Sdílejte zkušenosti s produkty, ptejte se na detaily recenzí, vyměňujte tipy.`}
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Diskuze" }]} />

  <PageHero
    eyebrow="Komunita · diskuze"
    eyebrowIcon="info"
    title="Diskuze<br/><em>a fórum</em>"
    subtitle={`${threads.length} aktivních vláken. <strong>Sdílejte reálné zkušenosti</strong> s produkty, ptejte se redakce a navzájem si pomáhejte. Moderováno přímo šéfredaktorem.`}
  />

  <!-- STATS -->
  <section class="stats-strip">
    <div class="inner">
      <ul>
        {
          stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="forum-cats">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Kategorie diskuze</p>
        <h2>Vyberte oblast vašeho zájmu</h2>
      </header>
      <ul class="cats-grid">
        {
          (Object.keys(categoryMeta) as ForumCategory[]).map((slug) => {
            const meta = categoryMeta[slug];
            return (
              <li>
                <a href={`#cat-${slug}`} class={`cat-card cat-tone-${meta.tone}`}>
                  <strong>{meta.label}</strong>
                  <span class="cat-desc">{meta.description}</span>
                  <span class="cat-count">{counts[slug]} {counts[slug] === 1 ? "vlákno" : counts[slug] < 5 ? "vlákna" : "vláken"}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  <!-- THREADS LIST -->
  <section class="forum-threads">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">{threads.length} vláken</p>
        <h2>Aktivní diskuze</h2>
        <p class="lead">
          Vlákna seřazena podle <strong>poslední aktivity</strong>. Pinned (📌) jsou vždy nahoře.
        </p>
      </header>
      <ul class="threads-list">
        {
          threads.map((t) => {
            const catMeta = categoryMeta[t.category];
            const statMeta = statusLabel[t.status];
            return (
              <li class={`thread-card ${t.isPinned ? "is-pinned" : ""}`} id={`cat-${t.category}`}>
                <div class="thread-avatar-wrap">
                  <div class="thread-avatar">{t.authorInitials}</div>
                  {t.authorBadge && (
                    <span class={`thread-badge badge-${badgeMeta[t.authorBadge].tone}`}>{badgeMeta[t.authorBadge].label}</span>
                  )}
                </div>
                <div class="thread-body">
                  <header class="thread-head">
                    {t.isPinned && <span class="pinned">📌 Připnuto</span>}
                    <span class={`thread-cat cat-tone-${catMeta.tone}`}>{catMeta.label}</span>
                    <span class={`thread-status status-${statMeta.tone}`}>{statMeta.label}</span>
                  </header>
                  <h3 class="thread-title">
                    <a href={`/diskuze/${t.slug}/`}>{t.title}</a>
                  </h3>
                  <div class="thread-meta">
                    <span>
                      <strong>{t.authorName}</strong>
                      <span class="time"> · {t.createdRelative}</span>
                    </span>
                  </div>
                </div>
                <div class="thread-stats">
                  <div>
                    <strong>{t.replyCount}</strong>
                    <span>odpovědí</span>
                  </div>
                  <div>
                    <strong>{t.viewCount.toLocaleString("cs-CZ")}</strong>
                    <span>zobrazení</span>
                  </div>
                  <div class="thread-last">
                    <span>poslední aktivita</span>
                    <strong>{t.lastActivityRelative}</strong>
                  </div>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  <!-- RULES & CTA -->
  <section class="forum-rules">
    <div class="inner rules-grid">
      <div class="rules-text">
        <header class="section-head">
          <p class="eyebrow">Než napíšete</p>
          <h2>3 jednoduchá pravidla</h2>
        </header>
        <ol>
          <li>
            <strong>Slušnost.</strong> I nesouhlas může být formulován férově. Žádné osobní útoky.
          </li>
          <li>
            <strong>Konkrétně.</strong> Pokud máte otázku, uveďte model, datum koupě, problém. Pomůže to ostatním.
          </li>
          <li>
            <strong>Žádná reklama.</strong> Odkazy na produkty OK, ale ne reklamní spam. Pro B2B máme <a href="/pro-znacky-firmy-agentury/">samostatný kontakt</a>.
          </li>
        </ol>
        <p class="rules-cta">
          Detail v <a href="/diskuze/pravidla-foruma/">připnutém vlákně Pravidla diskuze</a>.
        </p>
      </div>
      <aside class="rules-card">
        <span class="rules-eyebrow">Diskuze v prototypu</span>
        <p>
          Aktuálně je diskuze v <strong>read-only módu</strong> — pro publikaci příspěvků čekáme na spuštění backendu (NestJS). V produkční verzi bude vlákna možné komentovat po registraci.
        </p>
        <a href="mailto:diskuze@recenzer.cz" class="rules-btn">
          Napsat moderátorovi e-mailem
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </aside>
    </div>
  </section>

  <style>
    .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
    .section-head { max-width: 65ch; margin: 0 0 2rem; }
    .eyebrow {
      font-family: var(--mono); font-size: 11.5px; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--p-700); font-weight: 700; margin: 0 0 0.5rem;
    }
    .section-head h2 {
      font-size: clamp(1.4rem, 2.7vw, 1.85rem); font-weight: 800;
      color: var(--ink); letter-spacing: -0.025em; line-height: 1.2; margin: 0 0 0.6rem;
    }
    .section-head .lead { font-size: 15px; line-height: 1.6; color: var(--muted); margin: 0; }
    .section-head .lead strong { color: var(--ink); }

    /* Stats */
    .stats-strip { background: var(--bg); border-bottom: 1px solid var(--line); }
    .stats-strip .inner { padding: 2rem var(--gutter); }
    .stats-strip ul {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    }
    @media (max-width: 720px) { .stats-strip ul { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
    .stats-strip li {
      display: flex; flex-direction: column; gap: 4px;
      padding-top: 0.75rem; border-top: 2px solid var(--p-200);
    }
    .stats-strip strong {
      font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 800;
      color: var(--ink); letter-spacing: -0.02em; line-height: 1;
    }
    .stats-strip span { font-size: 12px; color: var(--muted); line-height: 1.3; }

    /* Categories */
    .forum-cats { background: var(--bg-warm); border-bottom: 1px solid var(--line); }
    .cats-grid {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem;
    }
    @media (max-width: 800px) { .cats-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .cats-grid { grid-template-columns: 1fr; } }
    .cat-card {
      display: flex; flex-direction: column; gap: 0.4rem;
      padding: 1.25rem 1.4rem; background: var(--bg);
      border: 1px solid var(--line); border-radius: var(--r);
      text-decoration: none; color: inherit;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .cat-card:hover { border-color: var(--p-300); transform: translateY(-1px); }
    .cat-tone-purple { border-left: 3px solid var(--p-500); }
    .cat-tone-amber { border-left: 3px solid var(--amber); }
    .cat-tone-red { border-left: 3px solid var(--red); }
    .cat-tone-green { border-left: 3px solid var(--green); }
    .cat-tone-blue { border-left: 3px solid #0a4fa3; }
    .cat-tone-muted { border-left: 3px solid var(--muted-2); }
    .cat-card strong { font-size: 1.05rem; color: var(--ink); font-weight: 800; }
    .cat-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }
    .cat-count {
      font-family: var(--mono); font-size: 0.72rem;
      color: var(--p-700); padding: 0.2rem 0.5rem;
      background: var(--p-50); border-radius: 4px;
      align-self: flex-start; font-weight: 700;
      margin-top: 0.35rem;
    }

    /* Threads list */
    .forum-threads { background: var(--bg); border-bottom: 1px solid var(--line); }
    .threads-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 0.75rem;
    }
    .thread-card {
      display: grid; grid-template-columns: 70px 1fr 180px; gap: 1.25rem;
      padding: 1.25rem 1.5rem; background: var(--bg-warm);
      border: 1px solid var(--line); border-radius: var(--r-lg);
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    @media (max-width: 900px) { .thread-card { grid-template-columns: 56px 1fr; gap: 1rem; } }
    .thread-card:hover { border-color: var(--p-300); transform: translateY(-1px); }
    .thread-card.is-pinned {
      border-left: 4px solid var(--accent);
      background: var(--accent-soft);
    }

    .thread-avatar-wrap {
      display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    }
    .thread-avatar {
      width: 50px; height: 50px; border-radius: 50%;
      background: linear-gradient(135deg, var(--p-100), var(--p-200));
      color: var(--p-700);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--mono); font-weight: 800; font-size: 0.92rem;
    }
    .thread-badge {
      font-family: var(--mono); font-size: 0.55rem;
      text-transform: uppercase; letter-spacing: 0.06em;
      padding: 0.1rem 0.35rem; border-radius: 99px; font-weight: 700;
      background: var(--p-50); color: var(--p-700);
      max-width: 70px; text-align: center;
    }
    .badge-green { background: var(--green-bg); color: var(--green); }
    .badge-amber { background: var(--amber-bg); color: var(--amber); }
    .badge-purple { background: var(--p-50); color: var(--p-700); }
    .badge-red { background: var(--red-bg); color: var(--red); }

    .thread-head {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem;
      margin-bottom: 0.55rem;
    }
    .pinned {
      font-family: var(--mono); font-size: 0.72rem;
      color: var(--accent); font-weight: 700;
    }
    .thread-cat {
      font-family: var(--mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.08em;
      padding: 0.15rem 0.5rem; border-radius: 99px;
      font-weight: 700;
    }
    .thread-cat.cat-tone-purple { background: var(--p-50); color: var(--p-700); }
    .thread-cat.cat-tone-amber { background: var(--amber-bg); color: var(--amber); }
    .thread-cat.cat-tone-red { background: var(--red-bg); color: var(--red); }
    .thread-cat.cat-tone-green { background: var(--green-bg); color: var(--green); }
    .thread-cat.cat-tone-blue { background: #e8f0fa; color: #0a4fa3; }
    .thread-cat.cat-tone-muted { background: var(--bg); color: var(--muted); border: 1px solid var(--line); }
    .thread-status {
      font-family: var(--mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.06em;
      padding: 0.15rem 0.5rem; border-radius: 99px; font-weight: 700;
    }
    .status-purple { background: var(--bg); color: var(--p-700); border: 1px solid var(--p-200); }
    .status-green { background: var(--green-bg); color: var(--green); }
    .status-muted { background: var(--bg); color: var(--muted); border: 1px solid var(--line); }

    .thread-title {
      margin: 0 0 0.55rem; font-size: 1.1rem;
      font-weight: 700; color: var(--ink); line-height: 1.35;
    }
    .thread-title a {
      color: var(--ink); text-decoration: none;
      border-bottom: 1px dashed var(--p-300);
    }
    .thread-title a:hover { color: var(--p-700); border-bottom-style: solid; }
    .thread-meta {
      font-size: 0.85rem; color: var(--muted);
    }
    .thread-meta strong { color: var(--ink); font-weight: 600; }
    .thread-meta .time { color: var(--muted); }

    .thread-stats {
      display: flex; flex-direction: column; gap: 0.4rem;
      padding-left: 1rem; border-left: 1px dashed var(--line);
    }
    @media (max-width: 900px) {
      .thread-stats {
        grid-column: 1 / -1; flex-direction: row; flex-wrap: wrap;
        padding-left: 0; border-left: none; padding-top: 0.85rem;
        border-top: 1px dashed var(--line); gap: 1rem;
      }
    }
    .thread-stats > div {
      display: flex; flex-direction: column; gap: 0.05rem;
    }
    .thread-stats strong {
      font-family: var(--sans); font-size: 1rem; font-weight: 800; color: var(--ink);
    }
    .thread-stats span {
      font-family: var(--mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--muted);
    }
    .thread-last strong { color: var(--p-700); font-size: 0.85rem; }

    /* Rules */
    .forum-rules { background: var(--bg-alt); }
    .rules-grid {
      display: grid; grid-template-columns: 1.5fr 1fr; gap: 2.5rem;
      align-items: start;
    }
    @media (max-width: 800px) { .rules-grid { grid-template-columns: 1fr; } }
    .rules-text ol {
      padding: 0; margin: 0 0 1.25rem;
      list-style: none; counter-reset: rules;
      display: flex; flex-direction: column; gap: 0.6rem;
    }
    .rules-text ol li {
      counter-increment: rules; position: relative;
      padding: 1rem 1.25rem 1rem 3rem;
      background: var(--bg); border: 1px solid var(--line);
      border-radius: var(--r); font-size: 0.95rem; line-height: 1.6;
    }
    .rules-text ol li::before {
      content: counter(rules); position: absolute;
      left: 0.85rem; top: 50%; transform: translateY(-50%);
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--p-700); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--mono); font-weight: 800; font-size: 0.88rem;
    }
    .rules-text ol li strong { color: var(--ink); font-weight: 700; }
    .rules-text ol li a {
      color: var(--p-700); text-decoration: none;
      border-bottom: 1px dashed var(--p-300);
    }
    .rules-cta {
      margin: 0; font-size: 0.92rem; color: var(--muted);
    }
    .rules-cta a {
      color: var(--p-700); text-decoration: none;
      border-bottom: 1px dashed var(--p-300); font-weight: 600;
    }

    .rules-card {
      padding: 1.5rem; background: var(--ink); color: #fff;
      border-radius: var(--r-lg);
    }
    .rules-eyebrow {
      display: block; font-family: var(--mono);
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
      color: #ffd166; font-weight: 700; margin-bottom: 0.75rem;
    }
    .rules-card p {
      margin: 0 0 1.25rem; font-size: 0.92rem; line-height: 1.65;
      color: rgba(255, 255, 255, 0.85);
    }
    .rules-card p strong { color: #ffd166; }
    .rules-btn {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.7rem 1.1rem; background: var(--accent); color: #fff;
      border-radius: var(--r-sm); font-size: 0.88rem; font-weight: 700;
      text-decoration: none; transition: background 0.15s ease;
    }
    .rules-btn:hover { background: #ff6600; }
    .rules-btn svg { width: 12px; height: 12px; }
  </style>
</BaseLayout>
