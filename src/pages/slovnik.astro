---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";
import {
  glossaryCategories,
  getAllTermsSorted,
  getTermsByCategory,
  getActiveLetters,
} from "../data/glossary";

const lastUpdated = "2026-05-21";
const allTerms = getAllTermsSorted();
const activeLetters = getActiveLetters();

const stats = [
  { value: `${allTerms.length}`, label: "termínů v slovníku" },
  { value: `${glossaryCategories.length}`, label: "kategorií" },
  { value: "100 %", label: "schválené garantem" },
  { value: "Q1 2026", label: "verze slovníku" },
];

// Group terms by first letter for alphabetical view
const byLetter: Record<string, typeof allTerms> = {};
for (const t of allTerms) {
  const letter = t.term.charAt(0).toUpperCase();
  if (!byLetter[letter]) byLetter[letter] = [];
  byLetter[letter].push(t);
}
const sortedLetters = Object.keys(byLetter).sort();
---

<BaseLayout
  title="Slovník pojmů — terminologie z testů a recenzí | Recenzer.cz"
  description={`Slovník ${allTerms.length} odborných termínů z oblasti elektronářadí, domácích spotřebičů, elektroniky, zahrady a auto-moto. Vysvětlení standardizovaných parametrů, norem a technologií.`}
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Slovník pojmů" }]} />

  <PageHero
    eyebrow={`${allTerms.length} termínů · ${glossaryCategories.length} kategorií`}
    eyebrowIcon="doc"
    title="Slovník<br/><em>pojmů a parametrů</em>"
    subtitle={`Všechny termíny, které používáme v testech a recenzích. Od <strong>brushless motoru</strong> přes <strong>ΔE displeje</strong> po <strong>CCA autobaterie</strong>. Vše schválené odborným garantem a propojené s konkrétními články, kde se termín objevuje.`}
  />

  <!-- ============ STATS ============ -->
  <section class="stats-strip">
    <div class="inner">
      <ul>
        {
          stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ ALPHABET JUMP ============ -->
  <section class="slovnik-alphabet">
    <div class="inner">
      <span class="alphabet-label">Skok na písmeno:</span>
      <div class="alphabet-buttons">
        {
          activeLetters.map((letter) => (
            <a href={`#letter-${letter}`} class="letter-btn">
              {letter}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ CATEGORIES ============ -->
  <section class="slovnik-categories">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Procházet podle kategorie</p>
        <h2>Vyberte si oblast</h2>
        <p class="lead">
          Slovník je rozdělen do 5 kategorií podle oblasti testování. <strong>Kliknutím na kategorii uvidíte jen relevantní termíny.</strong>
        </p>
      </header>
      <ul class="cat-grid">
        {
          glossaryCategories.map((c) => {
            const count = getTermsByCategory(c.slug).length;
            return (
              <li>
                <a href={`/slovnik/${c.slug}/`} class={`cat-card cat-tone-${c.tone}`}>
                  <div class="cat-icon" aria-hidden="true">
                    {c.icon === "bolt" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                      </svg>
                    )}
                    {c.icon === "house" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                      </svg>
                    )}
                    {c.icon === "lab" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10 2v7.31M14 9.3V2M8.5 2h7" />
                        <path d="M14 9.3a6.5 6.5 0 1 1-4 0" />
                      </svg>
                    )}
                    {c.icon === "leaf" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96a1 1 0 0 1 1.8.8c-1 6-2.4 8.84-7.4 11.16-1 .5-1.6 1.08-2.6 2.08" />
                        <path d="M2 21c0-3 1.85-5.36 5.08-6" />
                      </svg>
                    )}
                    {c.icon === "car" && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2" />
                        <circle cx="6.5" cy="16.5" r="2.5" />
                        <circle cx="16.5" cy="16.5" r="2.5" />
                      </svg>
                    )}
                  </div>
                  <div class="cat-body">
                    <strong class="cat-name">{c.name}</strong>
                    <span class="cat-count">{count} termínů</span>
                    <p class="cat-desc">{c.description}</p>
                  </div>
                  <span class="cat-arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  <!-- ============ ALL TERMS ALPHABETICAL ============ -->
  <section class="slovnik-all">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Všechny termíny</p>
        <h2>Abecední seznam — {allTerms.length} pojmů</h2>
        <p class="lead">
          Kompletní slovník seřazený podle abecedy. <strong>Kliknutím na termín otevřete detail s plnou definicí a souvisejícími články.</strong>
        </p>
      </header>

      {
        sortedLetters.map((letter) => (
          <article class="letter-section" id={`letter-${letter}`}>
            <header class="letter-head">
              <span class="letter-mark">{letter}</span>
              <span class="letter-count">{byLetter[letter].length} {byLetter[letter].length === 1 ? "termín" : byLetter[letter].length < 5 ? "termíny" : "termínů"}</span>
            </header>
            <ul class="terms-list">
              {byLetter[letter].map((t) => {
                const cat = glossaryCategories.find((c) => c.slug === t.categorySlug);
                return (
                  <li>
                    <a href={`/slovnik/${t.slug}/`} class="term-card">
                      <div class="term-head">
                        <strong class="term-name">{t.term}</strong>
                        {cat && <span class={`term-cat term-cat-${cat.tone}`}>{cat.name}</span>}
                      </div>
                      <p class="term-def">{t.shortDef}</p>
                      {t.aliases && t.aliases.length > 0 && (
                        <div class="term-aliases">
                          <span class="term-aliases-label">Také známé jako</span>
                          <span>{t.aliases.join(", ")}</span>
                        </div>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="slovnik-cta">
    <div class="inner">
      <div class="cta-card">
        <h2>Chybí vám nějaký termín?</h2>
        <p>
          Slovník rozšiřujeme průběžně podle toho, na co se ptáte. <strong>Napište nám termín, který bychom měli doplnit</strong> — odpoví seniorní redaktor + garant.
        </p>
        <div class="cta-actions">
          <a href="mailto:redakce@recenzer.cz?subject=Návrh%20termínu%20do%20slovníku" class="btn-primary">
            redakce@recenzer.cz
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <a href="/metodika/" class="btn-ghost">Naše metodika</a>
          <a href="/typy-obsahu/" class="btn-ghost">Typy obsahu</a>
        </div>
      </div>
      <p class="cta-meta">
        Slovník aktualizovaný <time datetime={lastUpdated}>{lastUpdated}</time> · Všechny termíny schválené odborným garantem dané kategorie.
      </p>
    </div>
  </section>

  <style>
    .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2rem, 4vw, 3.5rem) var(--gutter); }
    .section-head { max-width: 65ch; margin: 0 0 2rem; }
    .eyebrow {
      font-family: var(--mono); font-size: 11.5px; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--p-700); font-weight: 700; margin: 0 0 0.5rem;
    }
    .section-head h2 {
      font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; letter-spacing: -0.025em;
      color: var(--ink); line-height: 1.2; margin-bottom: 0.6rem;
    }
    .section-head .lead { font-size: 15px; line-height: 1.6; color: var(--muted); margin: 0; }
    .section-head .lead strong { color: var(--ink); }

    /* Stats */
    .stats-strip { background: var(--bg); border-bottom: 1px solid var(--line); }
    .stats-strip .inner { padding: 2rem var(--gutter); }
    .stats-strip ul {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    }
    @media (max-width: 720px) { .stats-strip ul { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
    .stats-strip li {
      display: flex; flex-direction: column; gap: 4px;
      padding-top: 0.75rem; border-top: 2px solid var(--p-200);
    }
    .stats-strip strong {
      font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 800;
      color: var(--ink); letter-spacing: -0.02em; line-height: 1;
    }
    .stats-strip span { font-size: 12px; color: var(--muted); line-height: 1.3; }

    /* Alphabet jump */
    .slovnik-alphabet {
      background: var(--bg-warm); border-bottom: 1px solid var(--line);
      position: sticky; top: 0; z-index: 50;
    }
    .slovnik-alphabet .inner {
      padding: 0.85rem var(--gutter);
      display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    }
    .alphabet-label {
      font-family: var(--mono); font-size: 0.72rem;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--muted); font-weight: 700;
    }
    .alphabet-buttons { display: flex; gap: 0.35rem; flex-wrap: wrap; }
    .letter-btn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 32px; height: 32px; border-radius: 50%;
      background: var(--bg); border: 1px solid var(--line);
      font-family: var(--sans); font-weight: 800; font-size: 0.85rem;
      color: var(--ink); text-decoration: none;
      transition: all 0.15s ease;
    }
    .letter-btn:hover {
      background: var(--p-700); color: #fff; border-color: var(--p-700);
    }

    /* Categories */
    .slovnik-categories { background: var(--bg); border-bottom: 1px solid var(--line); }
    .cat-grid {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.85rem;
    }
    @media (max-width: 760px) { .cat-grid { grid-template-columns: 1fr; } }
    .cat-card {
      display: grid; grid-template-columns: 60px 1fr 28px; gap: 1.25rem;
      padding: 1.5rem; background: var(--bg-warm);
      border: 1px solid var(--line); border-radius: var(--r-lg);
      text-decoration: none; color: inherit; align-items: center;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .cat-card:hover { border-color: var(--p-300); transform: translateY(-2px); }
    .cat-icon {
      width: 60px; height: 60px; border-radius: 16px;
      background: var(--p-50); color: var(--p-700);
      display: flex; align-items: center; justify-content: center;
    }
    .cat-tone-amber .cat-icon { background: var(--amber-bg); color: var(--amber); }
    .cat-tone-green .cat-icon { background: var(--green-bg); color: var(--green); }
    .cat-tone-red .cat-icon { background: var(--red-bg); color: var(--red); }
    .cat-tone-blue .cat-icon { background: #e8f0fa; color: #0a4fa3; }
    .cat-icon svg { width: 28px; height: 28px; }
    .cat-name {
      display: block; font-size: 1.15rem; font-weight: 800;
      color: var(--ink); letter-spacing: -0.015em; margin-bottom: 0.2rem;
    }
    .cat-count {
      display: inline-block; font-family: var(--mono);
      font-size: 0.72rem; color: var(--p-700); font-weight: 700;
      padding: 0.15rem 0.5rem; background: var(--p-50);
      border-radius: 4px; margin-bottom: 0.55rem;
    }
    .cat-tone-amber .cat-count { background: var(--amber-bg); color: var(--amber); }
    .cat-tone-green .cat-count { background: var(--green-bg); color: var(--green); }
    .cat-tone-red .cat-count { background: var(--red-bg); color: var(--red); }
    .cat-tone-blue .cat-count { background: #e8f0fa; color: #0a4fa3; }
    .cat-desc { margin: 0; font-size: 0.88rem; line-height: 1.55; color: var(--muted); }
    .cat-arrow {
      color: var(--p-500); display: inline-flex;
    }
    .cat-arrow svg { width: 18px; height: 18px; }

    /* All terms / Letters */
    .slovnik-all { background: var(--bg-alt); border-bottom: 1px solid var(--line); }
    .letter-section {
      margin-bottom: 2rem;
      scroll-margin-top: 5rem;
    }
    .letter-section:last-child { margin-bottom: 0; }
    .letter-head {
      display: flex; align-items: baseline; gap: 1rem;
      margin-bottom: 1rem; padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--p-200);
    }
    .letter-mark {
      font-family: var(--sans); font-size: 2.4rem; font-weight: 800;
      color: var(--p-700); letter-spacing: -0.025em; line-height: 1;
    }
    .letter-count {
      font-family: var(--mono); font-size: 0.78rem;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--p-700); padding: 0.2rem 0.55rem;
      background: var(--p-50); border-radius: 4px; font-weight: 700;
    }
    .terms-list {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;
    }
    @media (max-width: 800px) { .terms-list { grid-template-columns: 1fr; } }
    .term-card {
      display: block; padding: 1.1rem 1.3rem;
      background: var(--bg); border: 1px solid var(--line);
      border-radius: var(--r); text-decoration: none; color: inherit;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .term-card:hover { border-color: var(--p-300); transform: translateY(-1px); }
    .term-head {
      display: flex; flex-wrap: wrap; align-items: baseline;
      gap: 0.5rem; margin-bottom: 0.4rem;
    }
    .term-name {
      font-size: 1rem; font-weight: 800; color: var(--ink); letter-spacing: -0.01em;
    }
    .term-cat {
      font-family: var(--mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.06em;
      padding: 0.15rem 0.5rem; border-radius: 99px; font-weight: 700;
      background: var(--p-50); color: var(--p-700);
    }
    .term-cat-amber { background: var(--amber-bg); color: var(--amber); }
    .term-cat-green { background: var(--green-bg); color: var(--green); }
    .term-cat-red { background: var(--red-bg); color: var(--red); }
    .term-cat-blue { background: #e8f0fa; color: #0a4fa3; }
    .term-def {
      margin: 0; font-size: 0.88rem; line-height: 1.55; color: var(--text);
    }
    .term-aliases {
      margin-top: 0.5rem; padding-top: 0.5rem;
      border-top: 1px dashed var(--line);
      font-size: 0.78rem;
    }
    .term-aliases-label {
      font-family: var(--mono); text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--muted); margin-right: 0.4rem;
    }
    .term-aliases span:not(.term-aliases-label) { color: var(--ink-soft); }

    /* CTA */
    .slovnik-cta { background: var(--bg); }
    .cta-card {
      max-width: 760px; margin: 0 auto;
      padding: 2.5rem 2rem;
      background: linear-gradient(135deg, var(--p-700), var(--p-900));
      color: #fff; border-radius: var(--r-xl); text-align: center;
    }
    .cta-card h2 {
      font-size: clamp(1.4rem, 2.6vw, 1.85rem); font-weight: 800;
      letter-spacing: -0.02em; margin-bottom: 0.6rem;
    }
    .cta-card p {
      font-size: 1rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85);
      max-width: 56ch; margin: 0 auto 1.5rem;
    }
    .cta-card p strong { color: #ffd166; font-weight: 700; }
    .cta-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; }
    .btn-primary, .btn-ghost {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.8rem 1.3rem; border-radius: var(--r);
      font-size: 0.9rem; font-weight: 700; text-decoration: none;
    }
    .btn-primary { background: var(--accent); color: #fff; border: 1px solid var(--accent); }
    .btn-primary:hover { background: #ff6600; }
    .btn-primary svg { width: 14px; height: 14px; }
    .btn-ghost {
      background: rgba(255, 255, 255, 0.12); color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.25);
    }
    .btn-ghost:hover { background: rgba(255, 255, 255, 0.2); }
    .cta-meta { margin: 1.5rem 0 0; font-size: 0.78rem; color: var(--muted); text-align: center; }
  </style>
</BaseLayout>
