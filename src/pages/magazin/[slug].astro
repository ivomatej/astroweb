---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../../components/page/PageBreadcrumbs.astro";
import MagazineArticleView from "../../components/magazine/MagazineArticleView.astro";
import { magazineArticles, getMagazineArticleBySlug } from "../../data/magazine";
import { allPeople } from "../../data/people";

export function getStaticPaths() {
  return magazineArticles.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getMagazineArticleBySlug(slug!);
if (!article) return Astro.redirect("/magazin/");

const author = allPeople.find((p) => p.slug === article.authorSlug);
const otherArticles = magazineArticles.filter((a) => a.slug !== article.slug).slice(0, 3);
---

<BaseLayout
  title={`${article.title} | Magazín Recenzer.cz`}
  description={article.perex}
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { href: "/magazin/", label: "Magazín" },
      { label: article.title.slice(0, 50) + (article.title.length > 50 ? "…" : "") },
    ]}
  />

  <MagazineArticleView
    article={article}
    author={author}
    otherArticles={otherArticles}
  />
</BaseLayout>
