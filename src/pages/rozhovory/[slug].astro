---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../../components/page/PageBreadcrumbs.astro";
import { interviews, getInterviewBySlug } from "../../data/interviews";
import { allPeople } from "../../data/people";

export function getStaticPaths() {
  return interviews.map((i) => ({ params: { slug: i.slug } }));
}

const { slug } = Astro.params;
const interview = getInterviewBySlug(slug!);
if (!interview) return Astro.redirect("/rozhovory/");

const expert = allPeople.find((p) => p.slug === interview.intervieweeSlug);
const interviewer = allPeople.find((p) => p.slug === interview.interviewerSlug);

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}
---

<BaseLayout
  title={`${interview.title} | Rozhovor Recenzer.cz`}
  description={interview.perex}
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { href: "/rozhovory/", label: "Rozhovory" },
      { label: interview.title.slice(0, 60) + (interview.title.length > 60 ? "…" : "") },
    ]}
  />

  <!-- HERO -->
  <header class="int-hero">
    <div class="inner">
      <span class="hero-eyebrow">Rozhovor · {interview.category}</span>
      <h1>{interview.title}</h1>
      <p class="hero-perex">{interview.perex}</p>

      <div class="hero-people">
        {expert && (
          <a href={`/autor/${expert.slug}/`} class="person-card person-expert">
            <div class="person-avatar">{expert.initials ?? expert.name.slice(0, 2)}</div>
            <div>
              <span class="person-role-label">Odpovídá</span>
              <strong>{expert.name}</strong>
              <span class="person-role">{expert.role}</span>
            </div>
          </a>
        )}
        {interviewer && (
          <a href={`/autor/${interviewer.slug}/`} class="person-card person-interviewer">
            <div class="person-avatar interviewer-avatar">{interviewer.initials ?? interviewer.name.slice(0, 2)}</div>
            <div>
              <span class="person-role-label">Otázky kladl</span>
              <strong>{interviewer.name}</strong>
              <span class="person-role">{interviewer.role}</span>
            </div>
          </a>
        )}
        <div class="hero-meta">
          <span class="meta-item">
            <strong>{interview.readingTimeMin} min</strong>
            <span>čtení</span>
          </span>
          <span class="meta-item">
            <strong>{interview.qa.length}</strong>
            <span>otázek</span>
          </span>
          <span class="meta-item">
            <strong><time datetime={interview.publishedAt}>{formatCzechDate(interview.publishedAt)}</time></strong>
            <span>publikováno</span>
          </span>
        </div>
      </div>
    </div>
  </header>

  <!-- KEY INSIGHTS (TLDR) -->
  <section class="int-tldr">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Klíčové insighty</p>
        <h2>TL;DR pro spěchající</h2>
      </header>
      <ul class="insights">
        {
          interview.keyInsights.map((insight, i) => (
            <li>
              <span class="insight-num">{String(i + 1).padStart(2, "0")}</span>
              <p set:html={insight} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Q&A -->
  <section class="int-qa">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Celý rozhovor</p>
        <h2>{interview.qa.length} otázek a odpovědí</h2>
      </header>
      <ol class="qa-list">
        {
          interview.qa.map((item, i) => (
            <li class="qa-item">
              <div class="qa-q">
                <span class="qa-num">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <span class="qa-label">Otázka</span>
                  <p>{item.q}</p>
                </div>
              </div>
              <div class="qa-a">
                <span class="qa-label qa-label-a">Odpověď ({expert?.name ?? "expert"})</span>
                <div class="qa-prose" set:html={item.aHtml} />
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- RELATED -->
  {interview.relatedHrefs && interview.relatedHrefs.length > 0 && (
    <section class="int-related">
      <div class="inner">
        <header class="section-head">
          <h2>Související obsah</h2>
        </header>
        <ul class="related-list">
          {interview.relatedHrefs.map((r) => (
            <li>
              <a href={r.href}>
                <span class="related-arrow" aria-hidden="true">→</span>
                {r.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <style>
    .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
    .section-head { max-width: 65ch; margin: 0 0 1.75rem; }
    .eyebrow {
      font-family: var(--mono); font-size: 11.5px; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--p-700); font-weight: 700; margin: 0 0 0.5rem;
    }
    .section-head h2 {
      font-size: clamp(1.4rem, 2.5vw, 1.85rem); font-weight: 800;
      color: var(--ink); letter-spacing: -0.025em; line-height: 1.2; margin: 0;
    }

    /* HERO */
    .int-hero {
      background: linear-gradient(135deg, var(--ink), #1f1a30); color: #fff;
    }
    .int-hero .inner { padding: clamp(3rem, 6vw, 5rem) var(--gutter); }
    .hero-eyebrow {
      display: inline-block; font-family: var(--mono);
      font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em;
      font-weight: 700; padding: 0.3rem 0.7rem; border-radius: 99px;
      background: rgba(255, 215, 102, 0.15); color: #ffd166; margin-bottom: 1.5rem;
    }
    .int-hero h1 {
      font-family: var(--sans); font-size: clamp(1.85rem, 4.5vw, 3rem);
      font-weight: 800; letter-spacing: -0.025em;
      color: #fff; line-height: 1.1; margin: 0 0 1.25rem; max-width: 24ch;
    }
    .hero-perex {
      font-size: 1.15rem; line-height: 1.55;
      color: rgba(255, 255, 255, 0.85); margin: 0 0 2rem; max-width: 60ch;
    }

    .hero-people {
      display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;
    }
    .person-card {
      display: inline-flex; align-items: center; gap: 0.85rem;
      padding: 0.85rem 1.1rem;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15); border-radius: var(--r);
      text-decoration: none; color: inherit;
      transition: background 0.15s ease;
    }
    .person-card:hover { background: rgba(255, 255, 255, 0.14); }
    .person-avatar {
      width: 44px; height: 44px; border-radius: 50%;
      background: linear-gradient(135deg, #ffd166, #ffaa33); color: var(--ink);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--sans); font-weight: 800; font-size: 0.95rem;
    }
    .interviewer-avatar {
      background: linear-gradient(135deg, var(--p-200), var(--p-300));
      color: var(--p-900);
    }
    .person-role-label {
      display: block; font-family: var(--mono); font-size: 0.62rem;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: rgba(255, 255, 255, 0.6);
    }
    .person-card strong { display: block; font-size: 0.95rem; color: #fff; }
    .person-role { font-size: 0.78rem; color: rgba(255, 255, 255, 0.7); }

    .hero-meta {
      display: flex; gap: 1rem; margin-left: auto;
    }
    .meta-item {
      display: flex; flex-direction: column; align-items: center;
      padding: 0.5rem 0.85rem; background: rgba(255, 255, 255, 0.05);
      border-radius: var(--r-sm);
    }
    .meta-item strong { color: #ffd166; font-family: var(--sans); font-weight: 800; font-size: 1.1rem; }
    .meta-item span { font-size: 0.72rem; color: rgba(255, 255, 255, 0.6); }

    /* TLDR */
    .int-tldr { background: var(--p-50); border-bottom: 1px solid var(--p-200); }
    .insights {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.85rem;
      max-width: var(--max-w-text);
    }
    @media (max-width: 720px) { .insights { grid-template-columns: 1fr; } }
    .insights li {
      display: grid; grid-template-columns: 40px 1fr; gap: 0.85rem;
      padding: 1.1rem 1.3rem; background: var(--bg);
      border: 1px solid var(--p-200); border-radius: var(--r);
    }
    .insight-num {
      font-family: var(--mono); font-size: 1.2rem; font-weight: 800;
      color: var(--p-300); line-height: 1;
    }
    .insights p {
      margin: 0; line-height: 1.6; color: var(--text); font-size: 0.92rem;
    }
    .insights p :global(strong) { color: var(--ink); font-weight: 600; }

    /* Q&A */
    .int-qa { background: var(--bg); border-bottom: 1px solid var(--line); }
    .qa-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 1.5rem;
      max-width: var(--max-w-text);
    }
    .qa-item {
      padding: 1.75rem; background: var(--bg-warm);
      border: 1px solid var(--line); border-radius: var(--r-lg);
    }

    .qa-q {
      display: grid; grid-template-columns: 48px 1fr; gap: 1rem;
      margin-bottom: 1.25rem;
    }
    .qa-num {
      font-family: var(--sans); font-size: 1.8rem; font-weight: 800;
      color: var(--p-300); letter-spacing: -0.025em; line-height: 1;
    }
    .qa-label {
      display: block; font-family: var(--mono);
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--p-700); font-weight: 700; margin-bottom: 0.4rem;
    }
    .qa-label-a { color: #ffd166; }
    .qa-q p {
      margin: 0; font-size: 1.1rem; font-weight: 700;
      color: var(--ink); line-height: 1.4;
    }

    .qa-a {
      padding: 1.25rem 1.5rem; background: var(--ink); color: rgba(255,255,255,0.92);
      border-radius: var(--r); border-left: 4px solid #ffd166;
    }
    .qa-prose :global(p) {
      margin: 0 0 1rem; line-height: 1.7; font-size: 1rem;
      color: rgba(255, 255, 255, 0.9);
    }
    .qa-prose :global(p:last-child) { margin-bottom: 0; }
    .qa-prose :global(ul) { margin: 0.85rem 0 1.25rem; padding: 0 0 0 1.5rem; }
    .qa-prose :global(li) {
      margin: 0 0 0.45rem; line-height: 1.65;
      color: rgba(255, 255, 255, 0.88);
    }
    .qa-prose :global(strong) { color: #ffd166; font-weight: 700; }

    /* Related */
    .int-related { background: var(--bg-warm); }
    .related-list {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem;
      max-width: var(--max-w-text);
    }
    @media (max-width: 720px) { .related-list { grid-template-columns: 1fr; } }
    .related-list li a {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 1rem 1.25rem; background: var(--bg);
      border: 1px solid var(--line); border-radius: var(--r);
      text-decoration: none; color: var(--ink); font-weight: 600;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .related-list li a:hover {
      border-color: var(--p-300); transform: translateY(-1px); color: var(--p-700);
    }
    .related-arrow {
      font-size: 1.25rem; color: var(--p-500); font-weight: 800;
    }
  </style>
</BaseLayout>
