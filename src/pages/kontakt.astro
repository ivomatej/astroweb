---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";

interface ContactChannel {
  icon: "mail" | "chat" | "phone" | "map";
  label: string;
  value: string;
  href?: string;
  note?: string;
}

const channels: ContactChannel[] = [
  {
    icon: "mail",
    label: "Redakce",
    value: "redakce@recenzer.cz",
    href: "mailto:redakce@recenzer.cz",
    note: "Tipy, opravy, dotazy k článkům — odpovídáme do 24 h v pracovní dny.",
  },
  {
    icon: "mail",
    label: "Spolupráce a inzerce",
    value: "obchod@recenzer.cz",
    href: "mailto:obchod@recenzer.cz",
    note: "Pro firmy, agentury a partnery. Vždy podle Kodexu férové firmy.",
  },
  {
    icon: "phone",
    label: "Telefon",
    value: "+420 776 123 456",
    href: "tel:+420776123456",
    note: "Po–Pá 9:00–17:00",
  },
  {
    icon: "map",
    label: "Sídlo",
    value: "Converso Group s.r.o.",
    note: "Jankovcova 1535/2a, 170 00 Praha 7 · IČO 09322035",
  },
];

const faqs = [
  {
    q: "Jak nahlásit chybu v článku?",
    a: 'Použijte formulář <a href="/oprava-chyb/">Nahlásit chybu</a>, nebo nám napište na <a href="mailto:redakce@recenzer.cz">redakce@recenzer.cz</a>. Opravy řešíme obvykle do 48 hodin a změnu zveřejníme v historii revizí článku.',
  },
  {
    q: "Můžete otestovat náš produkt?",
    a: 'Modely si kupujeme sami za běžnou tržní cenu, abychom zachovali nezávislost. Pokud máte tip na konkurenční model, který by stál za test, napište nám. Pro spolupráci a kampaně viz <a href="/pro-znacky-firmy-agentury/">Pro značky a agentury</a>.',
  },
  {
    q: "Chtěl bych psát pro Recenzer.",
    a: 'Aktuální pozice najdete na <a href="/kariera/">/kariera/</a>. Pokud zrovna nehledáme nikoho ve vašem oboru, můžete poslat životopis na <a href="mailto:redakce@recenzer.cz">redakce@recenzer.cz</a>.',
  },
  {
    q: "Můžete recenzi sponzorovat?",
    a: 'Ne. <strong>Žádný článek na Recenzer.cz není a nikdy nebude placený.</strong> Detail v <a href="/eticky-kodex/">Etickém kodexu</a> a <a href="/o-nas/#jak-vydelavame">Jak vyděláváme</a>.',
  },
];
---

<BaseLayout
  title="Kontakt — Recenzer"
  description="Spolupráce, opravy v článcích, dotazy nebo tipy na nové testy. Kontaktní e-maily, telefon a adresa redakce."
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Kontakt" }]} />

  <PageHero
    eyebrow="Napište nám"
    eyebrowIcon="mail"
    title="Spojte se s&nbsp;<em>redakcí</em>"
    subtitle="Tipy na nové testy, opravy faktů, dotazy k metodice, žádosti o spolupráci — uvítáme vše. V pracovní dny odpovídáme <strong>do 24 hodin</strong>."
  />

  <!-- Channels -->
  <section class="kontakt-channels">
    <div class="inner">
      <ul class="channels-grid">
        {
          channels.map((c) => (
            <li class="channel-card">
              <div class="channel-ic" aria-hidden="true">
                {c.icon === "mail" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                )}
                {c.icon === "phone" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z" />
                  </svg>
                )}
                {c.icon === "map" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
              </div>
              <div class="channel-body">
                <div class="channel-label">{c.label}</div>
                {
                  c.href ? (
                    <a class="channel-value" href={c.href}>{c.value}</a>
                  ) : (
                    <span class="channel-value">{c.value}</span>
                  )
                }
                {c.note && <p class="channel-note">{c.note}</p>}
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Form -->
  <section class="kontakt-form-section">
    <div class="inner">
      <header class="form-head">
        <p class="eyebrow">Pošlete nám zprávu</p>
        <h2>Stačí pár řádků</h2>
        <p class="lead">
          Pokud preferujete formulář před e-mailem, vyplňte ho zde. Pole označená hvězdičkou jsou povinná.
        </p>
      </header>

      <form class="kontakt-form" method="post" action="/api/contact" novalidate>
        <div class="grid-2">
          <label class="field">
            <span>Vaše jméno *</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label class="field">
            <span>E-mail *</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
        </div>

        <label class="field">
          <span>Předmět *</span>
          <select name="topic" required>
            <option value="">Vyberte téma</option>
            <option value="oprava">Oprava nebo upřesnění v článku</option>
            <option value="tip">Tip na nový test</option>
            <option value="spoluprace">Spolupráce / inzerce</option>
            <option value="media">Mediální dotaz</option>
            <option value="jine">Jiné</option>
          </select>
        </label>

        <label class="field">
          <span>Zpráva *</span>
          <textarea name="message" rows="6" required placeholder="Popište, s čím vám můžeme pomoci…"></textarea>
        </label>

        <label class="consent">
          <input type="checkbox" name="consent" required />
          <span>Souhlasím se <a href="/zasady-osobnich-udaju/">zpracováním osobních údajů</a>.</span>
        </label>

        <div class="form-actions">
          <button type="submit" class="btn-primary">
            Odeslat zprávu
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
        </div>
      </form>
    </div>
  </section>

  <!-- FAQ -->
  <section class="kontakt-faq">
    <div class="inner">
      <header class="form-head">
        <p class="eyebrow">Nejčastější otázky</p>
        <h2>Než nám napíšete</h2>
      </header>

      <ul class="faq-list">
        {
          faqs.map((f) => (
            <li>
              <details>
                <summary>{f.q}</summary>
                <div class="faq-body" set:html={f.a} />
              </details>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <style>
    .inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: clamp(2.5rem, 5vw, 4rem) var(--gutter);
    }

    .kontakt-channels {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }

    .channels-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    @media (max-width: 720px) {
      .channels-grid { grid-template-columns: 1fr; }
    }

    .channel-card {
      display: grid;
      grid-template-columns: 44px 1fr;
      gap: 1rem;
      padding: 1.25rem;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
    }

    .channel-ic {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: var(--p-50);
      color: var(--p-700);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .channel-ic svg { width: 20px; height: 20px; }

    .channel-label {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 0.35rem;
    }

    .channel-value {
      display: block;
      font-size: 16px;
      font-weight: 700;
      color: var(--ink);
      text-decoration: none;
      margin-bottom: 0.4rem;
    }

    a.channel-value:hover,
    a.channel-value:focus-visible {
      color: var(--p-700);
    }

    .channel-note {
      font-size: 13px;
      line-height: 1.5;
      color: var(--muted);
      margin: 0;
    }

    /* ---------- Form ---------- */
    .kontakt-form-section {
      background: var(--bg-warm);
      border-bottom: 1px solid var(--line);
    }

    .form-head {
      max-width: 60ch;
      margin: 0 auto 2rem;
      text-align: center;
    }

    .eyebrow {
      font-family: var(--mono);
      font-size: 11.5px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--p-700);
      font-weight: 700;
      margin: 0 0 0.5rem;
    }

    .form-head h2 {
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 0.5rem;
    }

    .form-head .lead {
      font-size: 15px;
      color: var(--muted);
      margin: 0;
    }

    .kontakt-form {
      max-width: 680px;
      margin: 0 auto;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--r-xl);
      padding: clamp(1.5rem, 3vw, 2rem);
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    @media (max-width: 560px) {
      .grid-2 { grid-template-columns: 1fr; }
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .field > span {
      font-size: 12.5px;
      font-weight: 600;
      color: var(--ink);
    }

    .field input,
    .field select,
    .field textarea {
      padding: 0.7rem 0.85rem;
      border: 1px solid var(--line);
      border-radius: var(--r);
      font: inherit;
      font-size: 14.5px;
      color: var(--ink);
      background: #fff;
    }

    .field textarea {
      resize: vertical;
      min-height: 120px;
    }

    .field input:focus-visible,
    .field select:focus-visible,
    .field textarea:focus-visible {
      outline: none;
      border-color: var(--p-500);
      box-shadow: 0 0 0 3px rgba(122, 79, 227, 0.15);
    }

    .consent {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }

    .consent input[type="checkbox"] {
      margin-top: 3px;
      accent-color: var(--p-700);
    }

    .consent a {
      color: var(--p-700);
      text-decoration: underline;
    }

    .form-actions {
      display: flex;
      justify-content: flex-end;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.8rem 1.4rem;
      background: var(--p-700);
      color: #fff;
      border: 1px solid var(--p-700);
      border-radius: var(--r);
      font-size: 14.5px;
      font-weight: 600;
      cursor: pointer;
    }

    .btn-primary:hover,
    .btn-primary:focus-visible {
      background: var(--p-800);
      border-color: var(--p-800);
    }

    .btn-primary svg { width: 14px; height: 14px; }

    /* ---------- FAQ ---------- */
    .kontakt-faq {
      background: var(--bg);
    }

    .faq-list {
      list-style: none;
      padding: 0;
      margin: 0;
      max-width: 720px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .faq-list details {
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
      padding: 1rem 1.25rem;
    }

    .faq-list summary {
      cursor: pointer;
      font-size: 15px;
      font-weight: 700;
      color: var(--ink);
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .faq-list summary::-webkit-details-marker { display: none; }

    .faq-list summary::after {
      content: "+";
      font-family: var(--mono);
      font-weight: 700;
      color: var(--p-700);
      font-size: 1.2rem;
      transition: transform 0.15s;
    }

    .faq-list details[open] summary::after {
      content: "−";
    }

    .faq-body {
      padding-top: 0.85rem;
      font-size: 14.5px;
      line-height: 1.6;
      color: var(--ink-soft);
    }

    .faq-body :global(a) {
      color: var(--p-700);
      text-decoration: underline;
    }

    .faq-body :global(strong) {
      color: var(--ink);
      font-weight: 700;
    }
  </style>
</BaseLayout>
