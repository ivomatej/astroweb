      border-color: var(--p-800);
      color: #fff;
    }
    .contact-label {
      font-family: var(--mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      font-weight: 700;
    }
    .contact-primary .contact-label { color: rgba(255, 255, 255, 0.7); }
    .contact-value {
