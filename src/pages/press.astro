    .contact-note {
      font-size: 0.82rem;
      color: var(--muted);
    }
    .contact-primary .contact-note { color: rgba(255, 255, 255, 0.7); }
    .contact-placeholder .contact-value { color: var(--amber); font-style: italic; }

    /* ============ FACTSHEET ============ */
    .press-factsheet {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
