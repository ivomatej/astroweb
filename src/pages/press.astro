    }
    .stats-strip li {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding-top: 0.75rem;
      border-top: 2px solid var(--p-200);
    }
    .stats-strip strong {
      font-size: clamp(1.5rem, 2.7vw, 2rem);
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .stats-strip span {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.3;
    }

    /* ============ CONTACT ============ */
    .press-contact {
      background: var(--bg-warm);
      border-bottom: 1px solid var(--line);
    }
    .contact-cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.85rem;
    }
    @media (max-width: 720px) { .contact-cards { grid-template-columns: 1fr; } }
    .contact-card {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding: 1.25rem 1.4rem;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--r);
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .contact-card:hover {
      border-color: var(--p-300);
      transform: translateY(-1px);
    }
    .contact-primary {
      background: linear-gradient(135deg, var(--p-700), var(--p-900));
      border-color: var(--p-700);
      color: #fff;
    }
    .contact-primary:hover {
