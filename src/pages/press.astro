---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";
import { ivoMatej, alenaRajnochova, jakubNovak } from "../data/people";

const lastUpdated = "2026-05-21";

interface FactsheetRow {
  label: string;
  value: string;
  note?: string;
}

const factsheet: FactsheetRow[] = [
  { label: "Název webu", value: "Recenzer.cz", note: "+ SK mutace Recenzer.sk" },
  { label: "Provozovatel", value: "Converso Group s.r.o.", note: "IČO 09322035" },
  { label: "Sídlo redakce", value: "Praha 7 + laboratoř Brno-Židenice" },
  { label: "Šéfredaktor", value: "Ivo Matěj", note: "v této roli od 2016" },
  { label: "Založeno", value: "2016", note: "10 let v provozu" },
  { label: "Tým", value: "8 interních + 6 externích garantů", note: "14 lidí celkem" },
  { label: "Kategorií produktů", value: "4 000+", note: "k 5/2026" },
  { label: "Publikovaných článků", value: "8 200+" },
  { label: "Měsíční návštěvnost", value: "≈ 1,2 mil. unikátních / měsíc" },
  { label: "Testovací laboratoř", value: "180 m², 32 přístrojů", note: "Brno-Židenice" },
  { label: "Mediální tým", value: "Ivo Matěj + Alena Rajnochová", note: "k dispozici pro rozhovory" },
  { label: "Licence obsahu", value: "Citace dle § 31 AZ", note: "Plné převzetí jen po dohodě" },
];

interface PressTopic {
  topic: string;
  whoComments: string;
  email: string;
  examples: string[];
}

const pressTopics: PressTopic[] = [
  {
    topic: "Affiliate marketing a média v ČR",
    whoComments: "Ivo Matěj (šéfredaktor)",
    email: "ivo.matej@recenzer.cz",
    examples: ["MarketingFest 2024 keynote", "Lupa.cz, Marketing & Media, CzechCrunch interview"],
  },
  {
    topic: "Recenzní žurnalistika a důvěra v online média",
    whoComments: "Ivo Matěj + Lucie Horáková (editorka)",
    email: "redakce@recenzer.cz",
    examples: ["Médiajournal odborný článek 8/2023", "Forbes ČR rozhovor 10/2023"],
  },
  {
    topic: "Energetika a životnost domácích spotřebičů",
    whoComments: "Alena Rajnochová (hlavní redaktorka)",
    email: "redakce@recenzer.cz",
    examples: ["Vesmír 5/2023 článek", "dTest, iDNES.cz citace"],
  },
  {
    topic: "Elektronářadí — bezpečnost a kvalita",
    whoComments: "Jakub Novák, DiS. (odborný garant)",
    email: "jakub.novak@zamecnictvi-novak.cz",
    examples: ["Profi nářadí, Stavba magazín"],
  },
  {
    topic: "AI v redakční práci a transparentnost",
    whoComments: "Ivo Matěj",
    email: "ivo.matej@recenzer.cz",
    examples: ["AI politika v. 2.1 publikovaná 5/2026"],
  },
  {
    topic: "Spotřebitelská práva a transparentnost cen",
    whoComments: "Petr Svoboda (redaktor — finance)",
    email: "redakce@recenzer.cz",
    examples: ["Měšec.cz, Peníze.cz, Investiční magazín"],
  },
];

interface PressRelease {
  date: string;
  title: string;
  href?: string;
  excerpt: string;
  topic: string;
}

const pressReleases: PressRelease[] = [
  {
    date: "2026-05-21",
    title: "Recenzer.cz publikuje transparentní AI politiku verze 2.1",
    excerpt:
      "Český spotřebitelský web jako jeden z prvních v ČR detailně zveřejnil, jakým způsobem používá AI nástroje (Claude, GPT-4, Perplexity) v redakční práci, včetně 7 explicit no-AI zón.",
    topic: "Editorial standards",
  },
  {
    date: "2026-05-21",
    title: "Spuštěna meta-stránka „Naše chyby“ — 8 systémových omylů redakce",
    excerpt:
      "Recenzer.cz veřejně přiznává osm systémových chyb od založení v roce 2016 — od doporučení vadné pračky až po absenci akustické komory. Wirecutter-style transparentnost.",
    topic: "Editorial standards",
  },
  {
    date: "2026-04-30",
    title: "Změna testovací metodiky pro zimní pneumatiky",
    excerpt:
      "Aritmetický průměr nahrazen bezpečnostně váženým skóre (sníh × 2, led × 1,5). Reaguje na kritiku řidičů z Vysočiny po sezoně 2020/21.",
    topic: "Methodology",
  },
  {
    date: "2026-04-22",
    title: "Vychází srovnání Bosch vs Miele pračky 2026",
    excerpt:
      "Detailní 7kolové srovnání dvou nejprodávanějších značek na CZ trhu. TCO za 10 let, audience profiles, verdikt pro 5 různých kupujících.",
    topic: "Domácí spotřebiče",
  },
  {
    date: "2026-02-08",
    title: "Recenzer.cz spouští 24h monitoring cen ve 12 e-shopech",
    excerpt:
      "Automatický AI agent obchází Heureku, Alzu, Datart a dalších 9 e-shopů. Sleduje 1 240 produktů, při změně > 15 % posílá redakci notifikaci.",
    topic: "Site features",
  },
  {
    date: "2025-11-12",
    title: "Redakční tým přiznává aritmetickou chybu v testu letních pneumatik",
    excerpt:
      "Brzdná dráha Michelin Primacy 4 na mokru opravena ze 33,5 m na 34,8 m. Detail v archivu oprav. Šéfredaktor zveřejnil postup pro interní rekontrolu.",
    topic: "Corrections",
  },
];

interface Spokesperson {
  slug: string;
  name: string;
  role: string;
  initials: string;
  topics: string[];
  email: string;
  bio: string;
}

const spokespeople: Spokesperson[] = [
  {
    slug: ivoMatej.slug,
    name: ivoMatej.name,
    role: "Šéfredaktor · zakladatel",
    initials: ivoMatej.initials ?? "IM",
    topics: ["Affiliate marketing", "Recenzní žurnalistika", "AI v médiích", "Editorial standards"],
    email: ivoMatej.contactEmail ?? "ivo.matej@recenzer.cz",
    bio:
      "Vede Recenzer.cz od roku 2016. 17 let v online marketingu, předtím affiliate manager. Spoluautor knihy „Co si nekupovat 2024“ (Grada), keynote speaker MarketingFest 2024.",
  },
  {
    slug: alenaRajnochova.slug,
    name: alenaRajnochova.name,
    role: "Hlavní redaktorka · domácí spotřebiče",
    initials: alenaRajnochova.initials ?? "AR",
    topics: ["Pračky", "Sušičky", "Myčky", "Energetika domácnosti", "Štítky EU"],
    email: alenaRajnochova.contactEmail ?? "redakce@recenzer.cz",
    bio:
      "8 let v redakcích recenzních portálů, Mgr. žurnalistika UK. Členka Syndikátu novinářů ČR. Konzultantka Stiftung Warentest pro CZ trh. Citována v dTest, iDNES.cz.",
  },
  {
    slug: jakubNovak.slug,
    name: jakubNovak.name,
    role: "Odborný garant · elektronářadí",
    initials: jakubNovak.initials ?? "JN",
    topics: ["Aku brusky", "Pily", "Vrtačky", "Bezpečnost práce", "Svářecí technika"],
    email: "jakub.novak@zamecnictvi-novak.cz",
    bio:
      "18 let praxe v profesionálním zámečnictví. Svářečský průkaz ČSN EN ISO 9606-1 (metoda 135 + 141), člen Cechu zámečníků a kovářů ČR. Vlastník zámečnické provozovny v Brně.",
  },
];

interface BrandColor {
  name: string;
  hex: string;
  usage: string;
}

const brandColors: BrandColor[] = [
  { name: "Purple 700 (primary)", hex: "#4f24a8", usage: "Hlavní accent, links, CTA" },
  { name: "Purple 900 (dark)", hex: "#2e1466", usage: "Headers, dark gradients" },
  { name: "Accent orange", hex: "#ff4f00", usage: "CTA tlačítka, badges" },
  { name: "Ink (text primary)", hex: "#15131e", usage: "Body text, headlines" },
  { name: "Bg warm", hex: "#f6f3fb", usage: "Section backgrounds" },
  { name: "Mono font", hex: "JetBrains Mono", usage: "Eyebrows, code, mono labels" },
];

interface AssetItem {
  kind: "logo" | "photo" | "doc";
  title: string;
  format: string;
  size: string;
  note?: string;
  filename: string;
}

const downloadableAssets: AssetItem[] = [
  { kind: "logo", title: "Logo Recenzer.cz", format: "SVG", size: "1,2 kB", filename: "recenzer-logo.svg", note: "Vektor, plně škálovatelné" },
  { kind: "logo", title: "Logo barevné — pozitiv", format: "PNG", size: "12 kB", filename: "recenzer-logo-color.png", note: "1200 × 400 px, transparentní" },
  { kind: "logo", title: "Logo bílá varianta — negativ", format: "PNG", size: "10 kB", filename: "recenzer-logo-white.png", note: "Pro tmavé pozadí" },
  { kind: "logo", title: "Favicon set", format: "ICO + PNG", size: "8 kB", filename: "favicon-set.zip", note: "16, 32, 192, 512 px" },
  { kind: "photo", title: "Foto Ivo Matěj — portrét", format: "JPG", size: "1,8 MB", filename: "ivo-matej-portrait.jpg", note: "1600 × 2000 px, 300 DPI" },
  { kind: "photo", title: "Foto laboratoř Brno", format: "JPG", size: "4,2 MB", filename: "laboratory-brno.jpg", note: "4K, 300 DPI" },
  { kind: "photo", title: "Foto redakce", format: "JPG", size: "3,1 MB", filename: "team-photo.jpg", note: "Tým srpen 2025" },
  { kind: "doc", title: "Media kit PDF", format: "PDF", size: "2,4 MB", filename: "recenzer-media-kit-2026.pdf", note: "Kompletní press balíček" },
  { kind: "doc", title: "Brand guidelines", format: "PDF", size: "1,1 MB", filename: "recenzer-brand-guidelines.pdf", note: "Logo, barvy, typografie" },
  { kind: "doc", title: "Factsheet 2026", format: "PDF", size: "180 kB", filename: "recenzer-factsheet-2026.pdf", note: "Jednostránkový fact sheet" },
];

const stats = [
  { value: "10 let", label: "v provozu od 2016" },
  { value: "1,2 mil.", label: "unikátních návštěvníků / měsíc" },
  { value: "14", label: "lidí v redakci" },
  { value: "~24 h", label: "průměrný čas reakce na press" },
];

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}
---

<BaseLayout
  title="Press & Media kit — pro novináře | Recenzer.cz"
  description="Press kit Recenzer.cz pro novináře — přímý kontakt na šéfredaktora, factsheet, témata pro rozhovory, archiv tiskových zpráv, ke stažení loga a fotky redakce."
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { label: "Press & Media kit" },
    ]}
  />

  <PageHero
    eyebrow="Press · media kit"
    eyebrowIcon="mail"
    title="Press &<br/><em>Media kit</em>"
    subtitle={`Centralizovaný balíček pro novináře, agentury a média. Najdete tady <strong>přímý kontakt na šéfredaktora</strong>, factsheet o webu, témata, ke kterým jsme schopni komentovat, archiv tiskových zpráv a balíček materiálů ke stažení. Stav k <time datetime="${lastUpdated}">${lastUpdated}</time>.`}
  />

  <!-- ============ STATS ============ -->
  <section class="stats-strip">
    <div class="inner">
      <ul>
        {
          stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ PRESS CONTACT ============ -->
  <section class="press-contact">
    <div class="inner contact-grid">
      <div class="contact-main">
        <header class="section-head">
          <p class="eyebrow">Přímý press kontakt</p>
          <h2>Pište přímo šéfredaktorovi, ne na obecný e-mail</h2>
          <p class="lead">
            Pro press dotazy reaguju do <strong>24 hodin v pracovní dny</strong>. Mimo pracovní dobu posílejte SMS — odpovím při nejbližší příležitosti.
          </p>
        </header>

        <div class="contact-cards">
          <a href="mailto:press@recenzer.cz?subject=Press%20request" class="contact-card contact-primary">
            <span class="contact-label">Press e-mail</span>
            <strong class="contact-value">press@recenzer.cz</strong>
            <span class="contact-note">Mířeno přímo na šéfredaktora Ivo Matěje</span>
          </a>
          <a href="mailto:ivo.matej@recenzer.cz" class="contact-card">
            <span class="contact-label">Osobní e-mail šéfredaktora</span>
            <strong class="contact-value">ivo.matej@recenzer.cz</strong>
            <span class="contact-note">Pro citlivé / důvěrné dotazy</span>
          </a>
          <div class="contact-card contact-placeholder">
            <span class="contact-label">Press telefon</span>
            <strong class="contact-value">Doplnit pevné číslo redakce</strong>
            <span class="contact-note">Po–Pá 9:00–17:00</span>
          </div>
          <a href="/sefredaktor/" class="contact-card">
            <span class="contact-label">Plný profil + pravomoci</span>
            <strong class="contact-value">/sefredaktor/</strong>
            <span class="contact-note">Editor-in-chief stránka</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FACTSHEET ============ -->
  <section class="press-factsheet">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Factsheet</p>
        <h2>Fakta o webu na jedno místo</h2>
        <p class="lead">
          Vše, co rychle potřebujete pro článek. Kompletní verze ke stažení jako <a href="#assets">PDF factsheet</a>.
        </p>
      </header>
      <div class="factsheet-table-wrap">
        <table class="factsheet-table">
          <tbody>
            {
              factsheet.map((row) => (
                <tr>
                  <td class="fs-label">{row.label}</td>
                  <td class="fs-value">
                    <strong>{row.value}</strong>
                    {row.note && <span class="fs-note">{row.note}</span>}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ============ SPOKESPEOPLE ============ -->
  <section class="press-spokespeople">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">K dispozici pro rozhovory</p>
        <h2>{spokespeople.length} mluvčí podle tématu</h2>
        <p class="lead">
          Pro rychlou orientaci, kdo komentuje co. <strong>Přímé e-maily jsou na jejich osobní schránky</strong> — žádná press agentura mezi vámi.
        </p>
      </header>
      <ul class="spk-grid">
        {
          spokespeople.map((p) => (
            <li class="spk-card">
              <div class="spk-head">
                <div class="spk-avatar">{p.initials}</div>
                <div class="spk-id">
                  <a href={`/autor/${p.slug}/`} class="spk-name">
                    {p.name}
                  </a>
                  <span class="spk-role">{p.role}</span>
                </div>
              </div>
              <p class="spk-bio">{p.bio}</p>
              <div class="spk-topics">
                <span class="spk-topics-label">Komentuje</span>
                <ul>
                  {p.topics.map((t) => <li>{t}</li>)}
                </ul>
              </div>
              <a href={`mailto:${p.email}?subject=Press%20request`} class="spk-mail">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                  <polyline points="22,6 12,13 2,6" />
                </svg>
                {p.email}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ PRESS TOPICS ============ -->
  <section class="press-topics">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Co umíme komentovat</p>
        <h2>{pressTopics.length} témat, ke kterým máme co říct</h2>
        <p class="lead">
          Když připravujete článek nebo reportáž, podívejte se, jestli vám můžeme dodat citaci či expertní pohled.
        </p>
      </header>
      <ul class="topics-list">
        {
          pressTopics.map((t) => (
            <li class="topic-card">
              <h3>{t.topic}</h3>
              <div class="topic-meta">
                <span class="topic-who">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                  </svg>
                  <strong>{t.whoComments}</strong>
                </span>
                <a href={`mailto:${t.email}?subject=Press%20request`} class="topic-email">
                  {t.email}
                </a>
              </div>
              {t.examples.length > 0 && (
                <div class="topic-examples">
                  <span class="topic-examples-label">Dříve citováno</span>
                  <ul>
                    {t.examples.map((e) => <li>{e}</li>)}
                  </ul>
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ PRESS RELEASES ============ -->
  <section class="press-releases" id="tiskove-zpravy">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Tiskové zprávy</p>
        <h2>Archiv tiskových zpráv</h2>
        <p class="lead">
          Tiskové zprávy redakce — od nových editoriálních politik po retraction notices. Pro odběr nových zpráv přidejte <a href="/aktualizace.xml">/aktualizace.xml</a> do své RSS čtečky.
        </p>
      </header>
      <ol class="releases-list">
        {
          pressReleases.map((pr) => (
            <li class="release-item">
              <div class="release-meta">
                <time class="release-date" datetime={pr.date}>{formatCzechDate(pr.date)}</time>
                <span class="release-topic">{pr.topic}</span>
              </div>
              <h3 class="release-title">{pr.title}</h3>
              <p class="release-excerpt">{pr.excerpt}</p>
              <div class="release-actions">
                <a href={`mailto:press@recenzer.cz?subject=Full%20text:%20${encodeURIComponent(pr.title)}`} class="release-link">
                  Vyžádat plný text
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </a>
              </div>
            </li>
          ))
        }
      </ol>
      <div class="releases-cta">
        <a href="/aktualizace/" class="releases-cta-link">
          Kompletní archiv aktualizací (50+ záznamů)
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ DOWNLOADABLE ASSETS ============ -->
  <section class="press-assets" id="assets">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Ke stažení · brand assets</p>
        <h2>Logo, fotky, dokumenty</h2>
        <p class="lead">
          Všechny soubory jsou licencované pro <strong>citace, reporty a editoriální použití</strong> s atribucí „Foto / logo: Recenzer.cz". Pro komerční použití kontaktujte
          <a href="mailto:press@recenzer.cz">press@recenzer.cz</a>.
        </p>
      </header>
      <ul class="assets-grid">
        {
          downloadableAssets.map((a) => (
            <li class={`asset-card asset-${a.kind}`}>
              <div class="asset-icon" aria-hidden="true">
                {a.kind === "logo" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                  </svg>
                )}
                {a.kind === "photo" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <circle cx="9" cy="9" r="2" />
                    <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                  </svg>
                )}
                {a.kind === "doc" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                  </svg>
                )}
              </div>
              <div class="asset-body">
                <strong class="asset-title">{a.title}</strong>
                <div class="asset-specs">
                  <span class="asset-format">{a.format}</span>
                  <span class="asset-size">{a.size}</span>
                </div>
                {a.note && <p class="asset-note">{a.note}</p>}
              </div>
              <a href={`/press/${a.filename}`} download class="asset-download" aria-label={`Stáhnout ${a.title}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="assets-note">
        Soubory jsou placeholdery — finální assets aktualizujeme s release v.2.1 media kitu (plánováno 06/2026).
      </p>
    </div>
  </section>

  <!-- ============ BRAND COLORS ============ -->
  <section class="press-brand">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Brand guidelines</p>
        <h2>Barvy a typografie</h2>
        <p class="lead">
