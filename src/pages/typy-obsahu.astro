const stats = [
  { value: `${contentTypes.length}`, label: "typů obsahu" },
  { value: "1–25", label: "min čtení podle typu" },
  { value: "1 den–10 týd.", label: "produkční čas" },
  { value: "100 %", label: "schvaluje šéfredaktor" },
