                  <line x1="3" y1="12" x2="3.01" y2="12" />
                  <line x1="3" y1="18" x2="3.01" y2="18" />
                </svg>
              )}
              {ct.icon === "vs" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 3v18M15 3v18" />
                  <path d="M5 8h2M5 16h2M17 8h2M17 16h2" />
                </svg>
              )}
              {ct.icon === "product" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <circle cx="12" cy="13" r="5" />
                </svg>
              )}
              {ct.icon === "guide" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="3 6 8 6 8 18 3 18" />
                  <polyline points="21 6 16 6 16 18 21 18" />
                  <line x1="8" y1="12" x2="16" y2="12" />
                </svg>
              )}
              {ct.icon === "brand" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
              )}
              {ct.icon === "news" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2" />
                  <path d="M18 14h-8M15 18h-5M10 6h8v4h-8z" />
                </svg>
              )}
              {ct.icon === "interview" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg>
              )}
              {ct.icon === "shop" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                  <line x1="3" y1="6" x2="21" y2="6" />
                  <path d="M16 10a4 4 0 0 1-8 0" />
                </svg>
              )}
            </div>
            <span class="ct-short">{ct.shortName}</span>
            <div class="ct-tags">
              <div class="ct-tag">
                <span class="ct-tag-label">Čtení</span>
                <strong>{ct.readingTime}</strong>
              </div>
              <div class="ct-tag">
                <span class="ct-tag-label">Tvorba</span>
                <strong>{ct.productionTime}</strong>
              </div>
              <div class="ct-tag">
                <span class="ct-tag-label">Refresh</span>
                <strong>{ct.refreshCadence}</strong>
              </div>
            </div>
            {ct.sampleHref && (
              <a href={ct.sampleHref} class="ct-sample-link">
                <span class="ct-sample-label">Vzorový článek</span>
                <span class="ct-sample-title">{ct.sampleTitle}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            )}
          </aside>

          <div class="ct-body">
