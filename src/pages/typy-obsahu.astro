              <p class="ct-eyebrow">{ct.subtitle}</p>
              <h2>{ct.title}</h2>
              <p class="ct-oneliner" set:html={ct.oneLiner} />
            </header>

            <div class="ct-blocks">
              <div class="ct-block">
                <h3>Co tam najdete</h3>
                <ul>
                  {ct.whatItContains.map((c) => <li>{c}</li>)}
                </ul>
              </div>

              <div class="ct-block">
                <h3>Jak to vzniká</h3>
                <ul>
                  {ct.howWeMakeIt.map((c) => <li>{c}</li>)}
                </ul>
              </div>
            </div>

            <div class="ct-summary">
              <div class="ct-summary-card">
                <span class="ct-summary-label">Co se dozvíte</span>
                <p>{ct.whatYouLearn}</p>
              </div>
              <div class="ct-summary-card">
                <span class="ct-summary-label">Pro koho je ideální</span>
                <p>{ct.bestFor}</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    ))
  }

