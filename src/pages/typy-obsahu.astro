---

<BaseLayout
  title="Typy obsahu — co najdete na Recenzer.cz | Recenzer"
  description="9 typů redakčního obsahu na Recenzer.cz — od hloubkové analýzy přes TOP žebříčky po recenze e-shopů. Co kdy číst, jak vznikají a komu jsou určené."
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { label: "Typy obsahu" },
    ]}
  />

  <PageHero
    eyebrow="Editorial standards · taxonomy"
    eyebrowIcon="doc"
    title="9 typů obsahu<br/><em>které najdete na webu</em>"
    subtitle={`Recenzer.cz není jen „blog“. Máme <strong>9 různých redakčních formátů</strong>, každý s vlastní metodikou, časovou náročností a cílovou skupinou čtenářů. Tady je přehled, co kdy číst a co od jakého typu očekávat.`}
  />

  <!-- ============ STATS ============ -->
  <section class="stats-strip">
    <div class="inner">
      <ul>
        {
          stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ DECISION MATRIX ============ -->
  <section class="ct-matrix">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Rychlý průvodce</p>
        <h2>Co byste měli číst podle situace</h2>
        <p class="lead">
          Devět typických situací, ve kterých k nám čtenáři přijdou — a jaký formát doporučujeme.
        </p>
      </header>
      <div class="matrix-table-wrap">
        <table class="matrix-table">
          <thead>
            <tr>
              <th>Vaše situace</th>
              <th>Co číst</th>
              <th>Proč zrovna to</th>
            </tr>
          </thead>
          <tbody>
            {
              decisionMatrix.map((m) => (
                <tr>
                  <td><strong>{m.situation}</strong></td>
                  <td>
                    <a href={m.href} class="matrix-link">
                      {m.recommendation}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <line x1="5" y1="12" x2="19" y2="12" />
                        <polyline points="12 5 19 12 12 19" />
                      </svg>
                    </a>
                  </td>
                  <td class="matrix-why">{m.why}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ============ CONTENT TYPES ============ -->
  {
    contentTypes.map((ct) => (
      <section class={`ct-section ct-tone-${ct.tone}`} id={ct.id}>
        <div class="inner ct-grid">
          <aside class="ct-meta">
            <div class="ct-icon" aria-hidden="true">
              {ct.icon === "doc" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
