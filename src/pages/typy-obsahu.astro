---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";

const lastUpdated = "2026-05-21";

interface ContentType {
  /** Slug pro anchor URL (#hloubkova-analyza). */
  id: string;
  /** Krátký název (chip / breadcrumb). */
  shortName: string;
  /** Plný název s podtitulem. */
  title: string;
  subtitle: string;
  /** Barevný tone pro UI. */
  tone: "purple" | "amber" | "green" | "red" | "ink" | "blue";
  /** Ikona. */
  icon:
    | "doc"
    | "list"
    | "vs"
    | "product"
    | "guide"
    | "brand"
    | "news"
    | "interview"
    | "shop";
  /** Krátká definice (jedna věta). */
  oneLiner: string;
  /** Co tam najdete (3–5 bullets). */
  whatItContains: string[];
  /** Metodika — jak vzniká (2–4 bullets). */
  howWeMakeIt: string[];
  /** Čas, který strávíte čtením. */
  readingTime: string;
  /** Jak dlouho na něm pracujeme. */
  productionTime: string;
  /** Co se ze článku dozvíte (1 věta). */
  whatYouLearn: string;
  /** Pro koho je ideální. */
  bestFor: string;
  /** Vzorová URL. */
  sampleHref?: string;
  sampleTitle?: string;
  /** Frekvence aktualizace. */
  refreshCadence: string;
}

