---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";

const lastUpdated = "2026-05-21";

interface ProgramTier {
  name: string;
  level: string;
  tone: "green" | "amber" | "purple";
  perks: string[];
  qualification: string;
}

const tiers: ProgramTier[] = [
  {
    name: "Tester L1 — Začátečník",
    level: "0–2 produkty otestované",
    tone: "green",
    qualification: "Stačí registrace + první test podle protokolu.",
    perks: [
      "Možnost otestovat 1–3 produkty ročně",
      "Produkt po testu zůstává testerovi (50 % z případů)",
      "Veřejné jmenné poděkování v článku",
      "Roční konference testerů (1× ročně, online)",
    ],
  },
  {
    name: "Tester L2 — Pokročilý",
    level: "3–10 produktů otestováno + 80 % testů úspěšných",
    tone: "amber",
    qualification: "Min. 3 dokončené testy s 80% kvalitou (hodnotí seniorní redaktor).",
    perks: [
      "Možnost otestovat až 8 produktů ročně",
      "100 % produktů zůstává testerovi (zdarma na trvalo)",
      "Honorář 500–1 500 Kč za dokončený test",
      "Pravidelný feedback od seniorního redaktora",
      "Pozvánka na fyzické setkání testerů v laboratoři Brno (1× ročně)",
    ],
  },
  {
    name: "Tester L3 — Expert",
    level: "10+ produktů + invitee z L2",
    tone: "purple",
    qualification: "Pozvání po L2 — vybíráme experty pro hloubkové testy (10+ produktů, vlastní specializace).",
    perks: [
      "Hloubkové dlouhodobé testy (3+ měsíce v užívání)",
      "Honorář 2 500–8 000 Kč za hloubkový test",
      "Spoluautorství článku — vaše jméno u publikace",
      "Reálné odměny: kromě peněz i kalibrované přístroje, vzdělávací rozpočet",
      "Členství v interní Slack komunitě testerů",
      "Možnost přechodu na placený freelance kontrakt",
    ],
  },
];

interface Step {
  num: string;
  title: string;
  text: string;
}

const steps: Step[] = [
  {
    num: "01",
    title: "Registrace a krátký dotazník",
    text:
      "Vyplníte 10minutový dotazník — jaké kategorie vás zajímají, jaké máte zkušenosti, kolik máte času. Žádné CV.",
  },
  {
    num: "02",
    title: "První test do 14 dnů",
    text:
      "Pošleme vám návrh produktu k otestování. Pokud souhlasíte, doručíme ho zdarma. <strong>Test trvá 2–6 týdnů</strong> podle kategorie.",
  },
  {
    num: "03",
    title: "Reportujete podle protokolu",
    text:
      "Dostanete testovací protokol s konkrétními otázkami. Reportujete <strong>foto, video, naměřené hodnoty</strong> a slovní hodnocení. Bez literárních nároků.",
  },
  {
    num: "04",
    title: "Náš redaktor vyhodnotí",
    text:
      "Seniorní redaktor zpracuje váš report + svůj laboratorní test do finálního článku. Vaše jméno bude uvedeno mezi spolu-testery.",
  },
  {
    num: "05",
    title: "Postup po úspěšných testech",
    text:
      "Po 3 úspěšných testech postupujete na L2 (honorář), po 10+ na L3 (hloubkové testy, vyšší honorář, spoluautorství).",
  },
];

interface FAQ {
  q: string;
  a: string;
  open?: boolean;
}

const faqs: FAQ[] = [
  {
    open: true,
    q: "Můžu testovat, i když nemám technické vzdělání?",
    a:
      "<strong>Ano, dokonce to chceme.</strong> Většina produktů, které testujeme, je pro běžné uživatele. Vaše perspektiva běžného kupujícího je pro nás cennější než inženýrský detail. Technické měření zajišťuje naše laboratoř.",
  },
  {
    q: "Kolik času to zabere?",
    a:
      "Záleží na kategorii. <strong>Pračka — 6 týdnů</strong> (cca 2 hodiny týdně = 12 hodin celkem). <strong>Aku bruska — 2 týdny</strong> (cca 5 hodin celkem). Vždy uvádíme předem.",
  },
  {
    q: "Co pokud nepošlu report?",
    a:
      "Žádný problém — můžete to nadále zkusit. Ale po 2 nedokončených testech vás nepošleme další produkt. Pochopitelně.",
  },
  {
    q: "Můžu si produkt nechat?",
    a:
      "<strong>L1: 50 % šance</strong> (záleží na ceně produktu). <strong>L2 a vyšší: vždy ano</strong>, automaticky. U drahých produktů (50 000+ Kč) je možný i symbolický odkup za zůstatkovou cenu.",
  },
  {
    q: "Bude mé jméno v článku?",
    a:
      "Pokud chcete. Nastavujete v profilu, jestli „Jan N., Praha“ nebo „Anonymní tester“. V L3 (expertní) je vaše jméno u článku automaticky.",
  },
  {
    q: "Co když mi produkt nebude fungovat?",
    a:
      "Reportujte to v reportu — to je pro nás cenná informace. <strong>Závada produktu není vaše chyba.</strong> Pokud se rozbije při běžném používání, započítává se to do našeho hodnocení.",
  },
  {
    q: "Jsem k dispozici jen 2 hodiny týdně. Mohu se přihlásit?",
    a:
      "Ano. Vybereme vám produkt, který odpovídá vaší dostupnosti. Nikdy nevynucujeme tempo. Honorář v L2+ je <strong>za dokončený test</strong>, ne za odpracované hodiny.",
  },
];

const stats = [
  { value: "240+", label: "aktivních testerů" },
  { value: "L1 / L2 / L3", label: "3 úrovně programu" },
  { value: "500–8 000 Kč", label: "honorář v L2+" },
  { value: "100 %", label: "zdarma + produkt zůstává" },
];
---

<BaseLayout
  title="Staňte se testerem Recenzer.cz — komunita testerů produktů"
  description="Komunita testerů produktů Recenzer.cz. 3 úrovně programu, honorář 500–8 000 Kč za hloubkový test, produkt zůstává testerovi. Registrace zdarma, bez technického vzdělání."
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Staňte se testerem" }]} />

  <PageHero
    eyebrow="Komunita · od 2018"
    eyebrowIcon="check"
    title="Staňte se<br/><em>testerem Recenzer.cz</em>"
    subtitle="Pomáháme čtenářům lépe nakupovat. <strong>Vy nám pomůžete testovat.</strong> Nepotřebujete technické vzdělání — jen běžnou kuchyni / dílnu / domácnost a 2–4 hodiny týdně. Produkty dostáváte zdarma, v L2+ i honorář."
  />

  <!-- ============ STATS ============ -->
  <section class="stats-strip">
    <div class="inner">
      <ul>
        {
          stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="tester-how">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Jak to funguje</p>
        <h2>5 kroků od registrace po první test</h2>
        <p class="lead">
          Žádná zkušební doba, žádný požadavek na zkušenosti. <strong>L1 začátečník je default</strong> — postupně postupujete podle aktivity.
        </p>
      </header>
      <ol class="steps-list">
        {
          steps.map((s) => (
            <li>
              <div class="step-num-wrap">
                <span class="step-num">{s.num}</span>
              </div>
              <div class="step-body">
                <h3>{s.title}</h3>
                <p set:html={s.text} />
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============ TIERS ============ -->
  <section class="tester-tiers">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">3 úrovně programu</p>
        <h2>L1 → L2 → L3</h2>
        <p class="lead">
          Začínáte v L1 (začátečník), postupujete dle aktivity a kvality. <strong>Žádné poplatky, žádný „premium tier" k zakoupení.</strong>
        </p>
      </header>
      <ul class="tiers-grid">
        {
          tiers.map((t) => (
            <li class={`tier-card tier-tone-${t.tone}`}>
              <header class="tier-head">
                <strong class="tier-name">{t.name}</strong>
                <span class="tier-level">{t.level}</span>
              </header>
              <p class="tier-qual">
                <span class="tier-qual-label">Jak se kvalifikovat</span>
                {t.qualification}
              </p>
              <div class="tier-perks">
                <span class="tier-perks-label">Co získáte</span>
                <ul>
                  {t.perks.map((p) => <li>{p}</li>)}
                </ul>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="tester-faq">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Časté dotazy</p>
        <h2>Vše, na co se ptáte</h2>
      </header>
      <div class="faq-list">
        {
          faqs.map((f) => (
            <details class="faq-item" open={f.open}>
              <summary class="faq-question">
                <span>{f.q}</span>
                <span class="faq-toggle" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                </span>
              </summary>
              <div class="faq-answer" set:html={f.a} />
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="tester-cta">
    <div class="inner">
      <div class="cta-card">
        <h2>Pojďte testovat s námi</h2>
        <p>
          Registrace zabere 10 minut. <strong>Žádné CV ani motivační dopis</strong> — jen krátký dotazník o vašich preferencích. Vaše první nabídka přijde do 14 dnů.
        </p>
        <div class="cta-actions">
          <a href="mailto:kariera@recenzer.cz?subject=Registrace%20jako%20tester" class="btn-primary">
            kariera@recenzer.cz
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <a href="/metodika/" class="btn-ghost">Naše metodika</a>
          <a href="/eticky-kodex/" class="btn-ghost">Etický kodex</a>
          <a href="/testovaci-laborator/" class="btn-ghost">Naše laboratoř</a>
        </div>
      </div>
      <p class="cta-meta">
        Komunita funguje od 2018 · Poslední úprava programu <time datetime={lastUpdated}>{lastUpdated}</time>.
      </p>
    </div>
  </section>

  <style>
    .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
    .section-head { max-width: 65ch; margin: 0 0 2rem; }
    .eyebrow {
      font-family: var(--mono); font-size: 11.5px; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--p-700); font-weight: 700; margin: 0 0 0.5rem;
    }
    .section-head h2 {
      font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; letter-spacing: -0.025em;
      color: var(--ink); line-height: 1.2; margin-bottom: 0.6rem;
    }
    .section-head .lead { font-size: 15px; line-height: 1.6; color: var(--muted); margin: 0; }
    .section-head .lead strong { color: var(--ink); }

    /* Stats */
    .stats-strip { background: var(--bg); border-bottom: 1px solid var(--line); }
    .stats-strip .inner { padding: 2rem var(--gutter); }
    .stats-strip ul {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    }
    @media (max-width: 720px) { .stats-strip ul { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
    .stats-strip li {
      display: flex; flex-direction: column; gap: 4px;
      padding-top: 0.75rem; border-top: 2px solid var(--p-200);
    }
    .stats-strip strong {
      font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 800;
      color: var(--ink); letter-spacing: -0.02em; line-height: 1;
    }
    .stats-strip span { font-size: 12px; color: var(--muted); line-height: 1.3; }

    /* How */
    .tester-how { background: var(--bg-warm); border-bottom: 1px solid var(--line); }
    .steps-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 0.85rem; max-width: 880px;
    }
    .steps-list li {
      display: grid; grid-template-columns: 70px 1fr; gap: 1.5rem;
      padding: 1.25rem 1.5rem; background: var(--bg);
      border: 1px solid var(--line); border-radius: var(--r-lg);
    }
    @media (max-width: 600px) { .steps-list li { grid-template-columns: 1fr; gap: 0.85rem; } }
    .step-num-wrap { display: flex; align-items: flex-start; }
    .step-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 56px; height: 56px; border-radius: 50%;
      background: linear-gradient(135deg, var(--p-700), var(--p-900)); color: #fff;
      font-family: var(--sans); font-weight: 800; font-size: 1.4rem; letter-spacing: -0.02em;
    }
    .step-body h3 {
      margin: 0 0 0.4rem; font-size: 1.05rem; font-weight: 700; color: var(--ink);
    }
    .step-body p {
      margin: 0; line-height: 1.6; color: var(--text); font-size: 0.92rem;
    }
    .step-body p :global(strong) { color: var(--ink); font-weight: 600; }

    /* Tiers */
    .tester-tiers { background: var(--bg); border-bottom: 1px solid var(--line); }
    .tiers-grid {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem;
    }
    @media (max-width: 900px) { .tiers-grid { grid-template-columns: 1fr; } }
    .tier-card {
      padding: 1.75rem; background: var(--bg-warm);
      border: 1px solid var(--line); border-radius: var(--r-lg);
      display: flex; flex-direction: column; gap: 1rem;
    }
    .tier-tone-green { border-top: 4px solid var(--green); }
    .tier-tone-amber { border-top: 4px solid var(--amber); }
    .tier-tone-purple { border-top: 4px solid var(--p-700); }

    .tier-head { display: flex; flex-direction: column; gap: 0.35rem; }
    .tier-name {
      font-size: 1.15rem; font-weight: 800;
      color: var(--ink); letter-spacing: -0.015em;
    }
    .tier-tone-green .tier-name { color: var(--green); }
    .tier-tone-amber .tier-name { color: var(--amber); }
    .tier-tone-purple .tier-name { color: var(--p-700); }
    .tier-level {
      font-family: var(--mono); font-size: 0.78rem;
      color: var(--muted);
    }

    .tier-qual {
      margin: 0; padding: 0.85rem 1.1rem;
      background: var(--bg); border-radius: var(--r-sm);
      font-size: 0.88rem; line-height: 1.55; color: var(--text);
    }
    .tier-qual-label {
      display: block; font-family: var(--mono);
      font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--p-700); font-weight: 700; margin-bottom: 0.3rem;
    }

    .tier-perks { padding-top: 0.5rem; border-top: 1px dashed var(--line); }
    .tier-perks-label {
      display: block; font-family: var(--mono);
      font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--p-700); font-weight: 700; margin-bottom: 0.6rem;
    }
    .tier-perks ul {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 0.4rem;
    }
    .tier-perks li {
      position: relative; padding-left: 1.5rem;
      font-size: 0.88rem; line-height: 1.55; color: var(--text);
    }
    .tier-perks li::before {
      content: "✓"; position: absolute; left: 0;
      color: var(--green); font-weight: 800; font-size: 0.95rem; line-height: 1.65;
    }

    /* FAQ */
    .tester-faq { background: var(--bg-alt); border-bottom: 1px solid var(--line); }
    .faq-list {
      max-width: var(--max-w-text); display: flex; flex-direction: column; gap: 0.5rem;
    }
    .faq-item {
      background: var(--bg); border: 1px solid var(--line);
      border-radius: var(--r); overflow: hidden;
    }
    .faq-item[open] { border-color: var(--p-300); }
    .faq-question {
      list-style: none; cursor: pointer;
      padding: 1rem 1.25rem;
      display: flex; justify-content: space-between; align-items: center;
      gap: 1rem; font-weight: 700; color: var(--ink); font-size: 1rem;
    }
    .faq-question::-webkit-details-marker { display: none; }
    .faq-toggle {
      width: 24px; height: 24px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      color: var(--p-700); transition: transform 0.2s ease;
    }
    .faq-toggle svg { width: 16px; height: 16px; }
    .faq-item[open] .faq-toggle { transform: rotate(45deg); }
    .faq-answer {
      padding: 0 1.25rem 1.1rem;
      line-height: 1.65; color: var(--text);
    }
    .faq-answer :global(strong) { color: var(--ink); font-weight: 600; }

    /* CTA */
    .tester-cta { background: var(--bg); }
    .cta-card {
      max-width: 760px; margin: 0 auto;
      padding: 2.5rem 2rem;
      background: linear-gradient(135deg, var(--p-700), var(--p-900));
      color: #fff; border-radius: var(--r-xl); text-align: center;
    }
    .cta-card h2 {
      font-size: clamp(1.4rem, 2.6vw, 1.85rem); font-weight: 800;
      letter-spacing: -0.02em; margin-bottom: 0.6rem;
    }
    .cta-card p {
      font-size: 1rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85);
      max-width: 56ch; margin: 0 auto 1.5rem;
    }
    .cta-card p strong { color: #ffd166; font-weight: 700; }
    .cta-actions {
      display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center;
    }
    .btn-primary, .btn-ghost {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.8rem 1.3rem; border-radius: var(--r);
      font-size: 0.9rem; font-weight: 700; text-decoration: none;
    }
    .btn-primary { background: var(--accent); color: #fff; border: 1px solid var(--accent); }
    .btn-primary:hover { background: #ff6600; }
    .btn-primary svg { width: 14px; height: 14px; }
    .btn-ghost {
      background: rgba(255, 255, 255, 0.12); color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.25);
    }
    .btn-ghost:hover { background: rgba(255, 255, 255, 0.2); }
    .cta-meta { margin: 1.5rem 0 0; font-size: 0.78rem; color: var(--muted); text-align: center; }
  </style>
</BaseLayout>
