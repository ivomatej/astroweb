---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kontakt — ivomatej" description="Jak mě zastihnout">
  <section>
    <h1>Kontakt</h1>
    <p>
      Máš nápad, otázku nebo si jen chceš popovídat? Nejrychleji mě zastihneš
      e-mailem nebo přes GitHub.
    </p>
    <ul>
      <li>E-mail: <a href="mailto:hello@example.com">hello@example.com</a></li>
      <li>GitHub: <a href="https://github.com/ivomatej" rel="noopener noreferrer" target="_blank">@ivomatej</a></li>
    </ul>
    <div class="cta-row">
      <a href="/" class="btn btn-primary">Zpět domů</a>
      <a href="/about" class="btn">O mně</a>
    </div>
  </section>
</Layout>
