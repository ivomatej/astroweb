---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";
import { ivoMatej } from "../data/people";

const lastUpdated = "2026-05-21";

interface ContactChannel {
  icon: "mail" | "phone" | "post" | "datova";
  label: string;
  value: string;
  href?: string;
  note: string;
}

const directContacts: ContactChannel[] = [
  {
    icon: "mail",
    label: "Přímý e-mail šéfredaktora",
    value: "ivo.matej@recenzer.cz",
    href: "mailto:ivo.matej@recenzer.cz",
    note: "Odpovídám zpravidla do 24 hodin v pracovní dny. Pro citlivé záležitosti (stížnost, právní podnět) preferuji e-mail.",
  },
  {
    icon: "phone",
    label: "Telefon do redakce",
    value: "Doplnit po finalizaci pevné linky",
    note: "Pevné číslo redakce s úředními hodinami Po–Pá 9:00–17:00. Mimo úřední dobu pouze SMS.",
  },
  {
    icon: "post",
    label: "Korespondenční adresa",
    value: "Recenzer.cz / Ivo Matěj, Jankovcova 1535/2a, 170 00 Praha 7",
    note: "Pro formální podání (stížnost, žádost o opravu, právní výzva). Doporučená pošta s dodejkou.",
  },
  {
    icon: "datova",
    label: "Datová schránka",
    value: "Doplnit ID datové schránky Converso Group s.r.o.",
    note: "Pro úřední komunikaci. Nejrychlejší cesta pro výzvy státních orgánů, ÚOOÚ a soudu.",
  },
];

interface Responsibility {
  icon: "doc" | "shield" | "scale" | "check" | "users" | "edit";
  title: string;
  text: string;
}

const responsibilities: Responsibility[] = [
  {
    icon: "doc",
    title: "Veškerý publikovaný obsah",
    text: "Odpovídám za to, že každý článek na Recenzer.cz prošel redakčním procesem podle <a href=\"/redakcni-zasady/\">Redakčních zásad</a>. Žádný obsah neprochází bez schválení.",
  },
  {
    icon: "scale",
    title: "Editoriální nezávislost",
    text: "Garantuji, že obchodní oddělení nemá vliv na obsah recenzí. Affiliate partnerství neovlivňují hodnocení produktů. Detail v <a href=\"/eticky-kodex/\">Etickém kodexu</a>.",
  },
  {
    icon: "check",
    title: "Fakta a metodika testů",
    text: "Schvaluji metodiku každé testovací řady (pračky, brusky, autosedačky). Pokud test nedrží <a href=\"/metodika/\">naše standardy</a>, neprojde do publikace.",
  },
  {
    icon: "users",
    title: "Personální obsazení redakce",
    text: "Najímám autory a garanty. Kontroluju jejich kvalifikaci, ověřuju profesní certifikáty. Veřejné profily na <a href=\"/autori/\">/autori/</a> jsou výsledkem mé kontroly.",
  },
  {
    icon: "edit",
    title: "Opravy chyb a stížnosti",
    text: "Konečné slovo má šéfredaktor. Pokud čtenář nahlásí chybu přes <a href=\"/oprava-chyb/\">formulář oprav</a> nebo eskaluje na mě, rozhoduju o opravě, dementi nebo stažení článku.",
  },
  {
    icon: "shield",
    title: "Soulad s právními předpisy",
    text: "Dohlížím na soulad obsahu se zákonem č. 46/2000 Sb. (periodický tisk), občanským zákoníkem (ochrana osobnosti), zákonem č. 634/1992 Sb. (ochrana spotřebitele) a GDPR.",
  },
];

interface Authority {
  scope: string;
  decision: string;
  who: string;
  appeal: string;
}

const authorityMatrix: Authority[] = [
  {
    scope: "Publikovat / stáhnout článek",
    decision: "Konečné rozhodnutí",
    who: "Šéfredaktor",
    appeal: "Provozovatel (Converso Group s.r.o.) — jen v případě právních důvodů",
  },
  {
    scope: "Změnit hodnocení produktu po publikaci",
    decision: "Po konzultaci s autorem a garantem",
    who: "Šéfredaktor + garant",
    appeal: "Rozdílový hlas garanta v Knize chyb",
  },
  {
    scope: "Reagovat na stížnost ohledně obsahu",
    decision: "Konečné rozhodnutí",
    who: "Šéfredaktor",
    appeal: "Mediální rada / ČOI / ÚOOÚ (dle povahy)",
  },
  {
    scope: "Přijmout / odmítnout placený obsah",
    decision: "Před zveřejněním",
    who: "Šéfredaktor + Etická komise",
    appeal: "Bez odvolání — striktní zákaz nákupu pozitivních recenzí",
  },
  {
    scope: "Odmítnout reklamní spolupráci",
    decision: "Editoriální veto",
    who: "Šéfredaktor",
    appeal: "Bez odvolání",
  },
  {
    scope: "Smazat komentář / banovat uživatele",
    decision: "Eskalace od moderátora",
    who: "Šéfredaktor",
    appeal: "Vrácení účtu po písemné výzvě",
  },
  {
    scope: "Personální rozhodnutí v redakci",
    decision: "Konečné rozhodnutí",
    who: "Šéfredaktor",
    appeal: "Jednatel společnosti — jen u trvalého pracovního poměru",
  },
];

interface ComplaintStep {
  num: string;
  title: string;
  text: string;
  timing: string;
}

const complaintProcess: ComplaintStep[] = [
  {
    num: "01",
    title: "Pošlete podnět e-mailem",
    text: "Napište mi na <a href=\"mailto:ivo.matej@recenzer.cz\">ivo.matej@recenzer.cz</a> s předmětem „Stížnost“. Uveďte konkrétní URL článku, popis problému a vaše požadované řešení (oprava, dementi, stažení).",
    timing: "Do 24 hodin potvrzení přijetí",
  },
  {
    num: "02",
    title: "Posouzení v redakci",
    text: "Společně s autorem článku a (pokud je relevantní) odborným garantem prověřím tvrzení. Mám na to <strong>5 pracovních dnů</strong>. U citlivých případů (lékařský, právní obsah) konzultuji s externím garantem.",
    timing: "5 pracovních dnů",
  },
  {
    num: "03",
    title: "Odpověď s vyhodnocením",
    text: "Dostanete odpověď s jedním z těchto výsledků: <strong>(a)</strong> oprava článku, <strong>(b)</strong> dementi či doplnění, <strong>(c)</strong> stažení článku, <strong>(d)</strong> zamítnutí podnětu s vysvětlením proč.",
    timing: "Do 7 pracovních dnů od podnětu",
  },
  {
    num: "04",
    title: "Eskalace, pokud nejste spokojeni",
    text: "Pokud vám moje rozhodnutí nesedí, máte právo na eskalaci. Podle typu podnětu na: <strong>Radu pro reklamu</strong> (klamavá reklama), <strong>ČOI</strong> (spotřebitelská práva), <strong>ÚOOÚ</strong> (osobní údaje) nebo <strong>soud</strong> (ochrana osobnosti).",
    timing: "Bez časového limitu",
  },
  {
    num: "05",
    title: "Veřejná evidence chyb",
    text: "Každá oprava, dementi i stažení článku se objeví na stránce <a href=\"/oprava-chyb/\">Oprava chyb</a>. Historii všech revizí konkrétního článku najdete přímo v sekci „Historie revizí“ pod článkem.",
    timing: "Trvalý záznam",
  },
];

interface DontDo {
  text: string;
}

const wontDo: DontDo[] = [
  { text: "Nebudu mazat negativní hodnocení produktu kvůli stížnosti výrobce." },
  { text: "Nepřijmu objednanou „pozitivní recenzi“ za úplatu nebo barter — nikdy." },
  { text: "Nezveřejním obsah, který nemá identifikovatelného autora a editoriální kontrolu." },
  { text: "Nepublikuju komerční sdělení označené jako redakční obsah." },
  { text: "Nepřebírám obsah z jiných webů jako vlastní (a jiným ho nedávám bezúplatně dál)." },
  { text: "Nepublikuju údaje o soukromých osobách bez jejich souhlasu — kromě veřejně činných ve veřejně relevantních věcech." },
];

interface CertCard {
  title: string;
  body: string;
  href: string;
  badge: string;
}

const credBadges: CertCard[] = [
  { title: "Etický kodex", body: "Pravidla, podle kterých redakce funguje", href: "/eticky-kodex/", badge: "Závazné" },
  { title: "Redakční zásady", body: "Procesní pravidla a workflow", href: "/redakcni-zasady/", badge: "Veřejné" },
  { title: "Metodika testů", body: "Jak vznikají recenze v laboratoři", href: "/metodika/", badge: "ISO standardy" },
  { title: "Ověřování faktů", body: "Fact-checking proces v 5 krocích", href: "/overovani-faktu/", badge: "5 kroků" },
  { title: "Oprava chyb", body: "Veřejná evidence všech revizí", href: "/oprava-chyb/", badge: "Trvalá" },
  { title: "Impressum", body: "Údaje o provozovateli a redakci", href: "/impressum/", badge: "Zákonné" },
];

interface EscalationBody {
  icon: "scale" | "users" | "shield" | "court";
  name: string;
  scope: string;
  href: string;
  hrefLabel: string;
}

const escalationBodies: EscalationBody[] = [
  {
    icon: "users",
    name: "Rada pro reklamu (RPR)",
    scope: "Klamavá reklama, srovnávací reklama, skryté komerční sdělení.",
    href: "https://www.rpr.cz/",
    hrefLabel: "rpr.cz",
  },
  {
    icon: "shield",
    name: "Česká obchodní inspekce (ČOI)",
    scope: "Spotřebitelská práva, mimosoudní řešení sporů, klamavé obchodní praktiky.",
    href: "https://www.coi.cz/",
    hrefLabel: "coi.cz",
  },
  {
    icon: "scale",
    name: "Úřad pro ochranu osobních údajů (ÚOOÚ)",
    scope: "GDPR, neoprávněné zveřejnění osobních údajů, právo na výmaz.",
    href: "https://www.uoou.cz/",
    hrefLabel: "uoou.cz",
  },
  {
    icon: "court",
    name: "Soud — žaloba na ochranu osobnosti",
    scope: "Občanský zákoník § 81 a násl. — zásah do osobnostních práv.",
    href: "https://www.justice.cz/",
    hrefLabel: "justice.cz",
  },
];

const stats = [
  { value: "10", label: "let jako šéfredaktor (2016–)" },
  { value: "120+", label: "schválených článků měsíčně" },
  { value: "24 h", label: "průměrný čas reakce" },
  { value: "5 dní", label: "lhůta na vyřízení stížnosti" },
];
---

<BaseLayout
  title="Šéfredaktor a odpovědný redaktor — Ivo Matěj | Recenzer"
  description="Ivo Matěj je odpovědný redaktor Recenzer.cz dle zákona č. 46/2000 Sb. Přímý kontakt, rozsah odpovědnosti, rozhodovací pravomoc a postup pro stížnosti na obsah."
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { label: "Šéfredaktor" },
    ]}
  />

  <PageHero
    eyebrow="Editor-in-chief · odpovědný redaktor"
    eyebrowIcon="shield"
    title="Šéfredaktor je<br/><em>jeden konkrétní člověk</em>"
    subtitle="Za každé slovo na Recenzer.cz odpovídá <strong>Ivo Matěj</strong>. Není to právní fikce — je to praktická role. Tady najdete přímý kontakt, rozsah pravomoci a způsob, jak ho oslovit přímo, pokud máte stížnost nebo právní podnět."
  />

  <!-- ============ STATS ============ -->
  <section class="stats-strip">
    <div class="inner">
      <ul>
        {
          stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ KDO JE EDITOR-IN-CHIEF ============ -->
  <section class="eic-hero">
    <div class="inner eic-hero-grid">
      <div class="eic-avatar">
        <span>{ivoMatej.initials}</span>
      </div>
      <div class="eic-body">
        <p class="eic-role">Odpovědný redaktor · Editor-in-chief · Šéfredaktor</p>
        <h2 class="eic-name">{ivoMatej.name}</h2>
        <p class="eic-tagline">{ivoMatej.tagline}</p>
        <div class="eic-meta">
          <div class="eic-meta-item">
            <span class="eic-meta-label">V této roli od</span>
            <strong>2016 (10 let)</strong>
          </div>
          <div class="eic-meta-item">
            <span class="eic-meta-label">Jmenován jednatelem</span>
            <strong>Converso Group s.r.o.</strong>
          </div>
          <div class="eic-meta-item">
            <span class="eic-meta-label">Právní rámec</span>
            <strong>Zákon č. 46/2000 Sb., § 4</strong>
          </div>
        </div>
        <div class="eic-quick-links">
          <a href="/autor/ivo-matej/" class="eic-link">
            <span>Plný profil a publikace</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"
              ><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg
            >
          </a>
          <a href="https://www.linkedin.com/in/ivomatej" rel="noopener" target="_blank" class="eic-link">
            <span>LinkedIn</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"
              ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg
            >
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PŘÍMÝ KONTAKT ============ -->
  <section class="eic-contacts">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Přímý kontakt</p>
        <h2>Jak mě oslovit přímo</h2>
        <p class="lead">
          Pokud se vás obsah dotýká osobně, máte právní podnět nebo chcete eskalovat — pište mi přímo. <strong>Neukrývám se za sekretariát.</strong>
        </p>
      </header>
      <ul class="contact-grid">
        {
          directContacts.map((c) => (
            <li class="contact-card">
              <div class="contact-icon" aria-hidden="true">
                {c.icon === "mail" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                )}
                {c.icon === "phone" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                )}
                {c.icon === "post" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
                {c.icon === "datova" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <line x1="3" y1="9" x2="21" y2="9" />
                    <path d="m9 16 2 2 4-4" />
                  </svg>
                )}
              </div>
              <div class="contact-body">
                <span class="contact-label">{c.label}</span>
                {c.href ? (
                  <a href={c.href} class="contact-value">{c.value}</a>
                ) : (
                  <strong class="contact-value contact-value-placeholder">
                    <em>{c.value}</em>
                  </strong>
                )}
                <p class="contact-note">{c.note}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ ZA CO ODPOVÍDÁ ============ -->
  <section class="eic-responsibilities">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Rozsah odpovědnosti</p>
        <h2>Za co konkrétně odpovídám</h2>
        <p class="lead">
          Být šéfredaktor není čestný titul — je to praktická role s konkrétními povinnostmi. Tady je <strong>šest oblastí</strong>, ve kterých je moje slovo poslední.
        </p>
      </header>
      <ul class="resp-grid">
        {
          responsibilities.map((r) => (
            <li class="resp-card">
              <div class="resp-icon" aria-hidden="true">
                {r.icon === "doc" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                  </svg>
                )}
                {r.icon === "scale" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 16.4 8 4l-5 8h10" />
                    <path d="m5 12 3 4M16 16.4l3-4.4h-7" />
                    <line x1="8" y1="4" x2="8" y2="20" />
                  </svg>
                )}
                {r.icon === "check" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 11 12 14 22 4" />
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                  </svg>
                )}
                {r.icon === "users" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                )}
                {r.icon === "edit" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20h9" />
                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z" />
                  </svg>
                )}
                {r.icon === "shield" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  </svg>
                )}
              </div>
              <h3 class="resp-title">{r.title}</h3>
              <p class="resp-text" set:html={r.text} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ ROZHODOVACÍ PRAVOMOC ============ -->
  <section class="eic-authority">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Rozhodovací pravomoc</p>
        <h2>Co rozhoduje šéfredaktor, kde má veto a kdy je odvolání</h2>
        <p class="lead">
          Tabulka přesně mapuje, kdo má v daném okamžiku „poslední slovo" a kdo ho může přebít. <strong>Žádné šedé zóny.</strong>
        </p>
      </header>
      <div class="authority-table-wrap">
        <table class="authority-table">
          <thead>
            <tr>
              <th>Oblast rozhodování</th>
              <th>Typ rozhodnutí</th>
              <th>Kdo rozhoduje</th>
              <th>Odvolání / eskalace</th>
            </tr>
          </thead>
          <tbody>
            {
              authorityMatrix.map((a) => (
                <tr>
                  <td><strong>{a.scope}</strong></td>
                  <td>{a.decision}</td>
                  <td><span class="auth-who">{a.who}</span></td>
                  <td>{a.appeal}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ============ JAK ŘEŠIT STÍŽNOSTI ============ -->
  <section class="eic-complaint">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Stížnosti na obsah</p>
        <h2>Pětikrokový postup, jak řeším podnět od čtenáře</h2>
        <p class="lead">
          Stížnost neignoruju a neodkládám. Tady je <strong>přesný proces s časovými lhůtami</strong>, který garantuju každému, kdo si na obsah Recenzer.cz stěžuje.
        </p>
      </header>
      <ol class="complaint-list">
        {
          complaintProcess.map((s) => (
            <li class="complaint-step">
              <div class="complaint-num-wrap">
                <span class="complaint-num">{s.num}</span>
                <span class="complaint-timing">{s.timing}</span>
              </div>
              <div class="complaint-body">
                <h3>{s.title}</h3>
                <p set:html={s.text} />
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============ ESKALACE / ODVOLACÍ ORGÁNY ============ -->
