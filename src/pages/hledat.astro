---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
---

<BaseLayout
  title="Hledat | Recenzer.cz"
  description="Vyhledávání v recenzích, slovníku, značkách, rubrikách a editoriálních stránkách Recenzer.cz."
  noIndex
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Hledat" }]} />

  <section class="search-page">
    <div class="inner">
      <header class="search-head">
        <p class="eyebrow">Vyhledávání</p>
        <h1>Hledat na Recenzer.cz</h1>
        <p class="lead">
          Hledá v <strong id="search-count">…</strong> recenzích, slovníkových
          heslech, značkách, rubrikách a editoriálních stránkách. Diakritika a
          velikost písmen nehraje roli.
        </p>

        <form class="search-form" method="get" action="/hledat/" role="search">
          <label for="search-input" class="visually-hidden">Hledaný výraz</label>
          <div class="search-input-wrap">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              class="search-icon"
            >
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input
              id="search-input"
              type="search"
              name="q"
              placeholder="Např. pračka, kickback, Bosch, slovník…"
              autocomplete="off"
              autocapitalize="off"
              autocorrect="off"
              spellcheck="false"
            />
            <button type="submit" class="search-submit">Hledat</button>
          </div>
        </form>
      </header>

      <p id="search-status" class="search-status" aria-live="polite">
        Načítám index…
      </p>

      <nav
        id="search-filter"
        class="search-filter"
        aria-label="Filtr typů výsledků"
        hidden
      >
        <span class="filter-label">Filtr:</span>
        <ul class="filter-chips" role="list"></ul>
      </nav>

      <ol id="search-results" class="search-results"></ol>

      <section id="search-empty" class="search-empty" hidden>
        <h2>Žádné výsledky</h2>
        <p>
          Zkuste obecnější výraz nebo se podívejte na rozcestníky:
        </p>
        <ul class="empty-links">
          <li><a href="/mapa-webu/">Mapa webu</a></li>
          <li><a href="/slovnik/">Slovník pojmů</a></li>
          <li><a href="/znacky/">Značky výrobců</a></li>
          <li><a href="/diskuze/">Diskuze / fórum</a></li>
        </ul>
      </section>

      <section id="search-initial" class="search-initial">
        <h2>Co můžete hledat</h2>
        <ul class="initial-grid">
          <li><strong>Produkty a kategorie</strong><span>pračka, aku bruska, autobaterie, zimní pneu, kávovar…</span></li>
          <li><strong>Slovníkové pojmy</strong><span>brushless, kickback, AquaStop, ΔE displeje…</span></li>
          <li><strong>Značky</strong><span>Bosch, Miele, Makita, Samsung…</span></li>
          <li><strong>Editoriální stránky</strong><span>metodika, laboratoř, etický kodex, naše chyby…</span></li>
        </ul>
      </section>
    </div>
  </section>

  <script is:inline>
    /* eslint-disable */
    (function () {
      const qs = (s, root) => (root || document).querySelector(s);

      const input    = qs("#search-input");
      const status   = qs("#search-status");
      const list     = qs("#search-results");
      const empty    = qs("#search-empty");
      const initial  = qs("#search-initial");
      const countEl  = qs("#search-count");
      const form     = qs(".search-form");
      const filterEl = qs("#search-filter");
      const filterChips = qs(".filter-chips");

      // Threshold: only show filter bar when there are MANY results
      // spanning MULTIPLE categories. For 3–5 hits or single-family
      // results the bar adds noise without value.
      const FILTER_MIN_RESULTS  = 6;
      const FILTER_MIN_FAMILIES = 2;

      // Kind → filter-family mapping. Multiple kinds can collapse into
      // one family (e.g. "Článek (pillar)" and "Žebříček" both → article).
      // The "label" is what the user sees on the filter chip.
      function kindFamily(kind) {
        const cls = kindClass(kind);
        switch (cls) {
          case "k-article":     return { key: "article",     label: "Články" };
          case "k-category":    return { key: "category",    label: "Rubriky" };
          case "k-glossary":    return { key: "glossary",    label: "Slovník" };
          case "k-brand":       return { key: "brand",       label: "Značky" };
          case "k-magazine":    return { key: "magazine",    label: "Magazín" };
          case "k-interview":   return { key: "interview",   label: "Rozhovory" };
          case "k-forum":       return { key: "forum",       label: "Diskuze" };
          case "k-person":      return { key: "person",      label: "Autoři" };
          case "k-standards":   return { key: "standards",   label: "Standardy" };
          case "k-corrections": return { key: "corrections", label: "Korekce" };
          case "k-legal":       return { key: "legal",       label: "Právní" };
          case "k-hub":         return { key: "hub",         label: "Rozcestníky" };
          default:              return { key: "page",        label: "Stránky" };
        }
      }

      // Diacritic-insensitive normalization (strip combining marks U+0300–036F)
      const COMBINING = /[̀-ͯ]/g;
      function fold(s) {
        return (s || "")
          .toString()
          .normalize("NFD")
          .replace(COMBINING, "")
          .toLowerCase();
      }

      // Tokenize query into 1+ char tokens
      function tokens(q) {
        return fold(q)
          .replace(/[^a-z0-9\s+\-]/gi, " ")
          .split(/\s+/)
          .filter((t) => t.length >= 1);
      }

      function escapeHtml(s) {
        return (s || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function highlight(text, qTokens) {
        if (!text || !qTokens.length) return escapeHtml(text);
        const folded = fold(text);
        const ranges = [];
        for (const t of qTokens) {
          if (t.length < 2) continue;
          let idx = 0;
          while ((idx = folded.indexOf(t, idx)) !== -1) {
            ranges.push([idx, idx + t.length]);
            idx += t.length;
          }
        }
        if (!ranges.length) return escapeHtml(text);
        ranges.sort((a, b) => a[0] - b[0]);
        // merge overlaps
        const merged = [ranges[0]];
        for (let i = 1; i < ranges.length; i++) {
          const last = merged[merged.length - 1];
          if (ranges[i][0] <= last[1]) {
            last[1] = Math.max(last[1], ranges[i][1]);
          } else {
            merged.push(ranges[i]);
          }
        }
        let out = "";
        let cursor = 0;
        for (const [start, end] of merged) {
          out += escapeHtml(text.slice(cursor, start));
          out += "<mark>" + escapeHtml(text.slice(start, end)) + "</mark>";
          cursor = end;
        }
        out += escapeHtml(text.slice(cursor));
        return out;
      }

      // Score one entry against tokens.
      // - exact title token = 5
      // - title prefix token = 3
      // - title contains token = 2
      // - desc contains token = 1
      // - tag exact = 4
      // Each token contributes once; tokens that don't match anywhere drop the entry.
      function scoreEntry(entry, qTokens) {
        const fTitle = fold(entry.title);
        const fDesc  = fold(entry.desc);
        const fHint  = fold(entry.hint || "");
        const fTags  = (entry.tags || []).map(fold);

        let total = 0;
        for (const t of qTokens) {
          let hit = 0;
          // Exact tag match
          if (fTags.includes(t)) hit = Math.max(hit, 4);
          // Title word boundary match
          if (fTitle === t) hit = Math.max(hit, 5);
          else if (fTitle.startsWith(t + " ") || fTitle.endsWith(" " + t) || fTitle.includes(" " + t + " ")) hit = Math.max(hit, 3);
          else if (fTitle.includes(t)) hit = Math.max(hit, 2);
          // Description/hint contains
          if (fDesc.includes(t))  hit = Math.max(hit, 1);
          if (fHint.includes(t))  hit = Math.max(hit, 1);
          if (!hit) return 0; // every token must match somewhere
          total += hit;
        }
        return total;
      }

      // Map result.kind to a CSS class — drives chip color and left border.
      function kindClass(kind) {
        const k = (kind || "").toLowerCase();
        if (k.startsWith("článek") || k === "žebříček" || k === "srovnání") return "k-article";
        if (k === "rubrika")        return "k-category";
        if (k.startsWith("slovník")) return "k-glossary";
        if (k === "značka")         return "k-brand";
        if (k === "magazín")        return "k-magazine";
        if (k === "rozhovor")       return "k-interview";
        if (k === "diskuze")        return "k-forum";
        if (k === "autor")          return "k-person";
        if (k === "standardy")      return "k-standards";
        if (k === "korekce")        return "k-corrections";
        if (k === "právní")         return "k-legal";
        if (k === "rozcestník" || k === "navigace") return "k-hub";
        return "k-page";
      }

      // Czech date formatter: "2026-05-22" → "22. 5. 2026".
      // Uses Intl with cs-CZ if available; falls back to a hand-built string.
      const dateFormatter = (function () {
        try {
          return new Intl.DateTimeFormat("cs-CZ", {
            day: "numeric",
            month: "numeric",
            year: "numeric",
          });
        } catch (e) { return null; }
      })();

      function formatDate(iso) {
        if (!iso) return "";
        const d = new Date(iso);
        if (isNaN(d.getTime())) return iso;
        if (dateFormatter) return dateFormatter.format(d);
        return d.getDate() + ". " + (d.getMonth() + 1) + ". " + d.getFullYear();
      }

      // Inline SVG icons used in the meta line and action button.
      const ICON_CAL =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">' +
          '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>' +
          '<line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>';
      const ICON_USER =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">' +
          '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';
      const ICON_ARROW =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">' +
          '<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';

      function renderResults(entries, qTokens) {
        list.innerHTML = entries
          .map(({ entry }) => {
            const title = highlight(entry.title, qTokens);
            const desc  = highlight(entry.desc,  qTokens);
            const hint  = entry.hint ? escapeHtml(entry.hint) : "";
            const cls   = kindClass(entry.kind);
            const dateStr   = formatDate(entry.date);
            const authorStr = entry.author ? escapeHtml(entry.author) : "";

            const metaParts = [];
            if (dateStr)   metaParts.push('<span class="result-meta-item"><span class="result-meta-ic" aria-hidden="true">' + ICON_CAL + '</span><time datetime="' + escapeHtml(entry.date || "") + '">' + escapeHtml(dateStr) + '</time></span>');
            if (authorStr) metaParts.push('<span class="result-meta-item"><span class="result-meta-ic" aria-hidden="true">' + ICON_USER + '</span><span>' + authorStr + '</span></span>');
            const metaRow = metaParts.length
              ? '<div class="result-meta">' + metaParts.join("") + '</div>'
              : "";

            return (
              '<li class="search-result ' + cls + '">' +
                '<a class="result-link" href="' + escapeHtml(entry.url) + '" aria-label="Zobrazit: ' + escapeHtml(entry.title) + '">' +
                  '<div class="result-head">' +
                    '<span class="result-kind">' + escapeHtml(entry.kind) + '</span>' +
                    (hint ? '<span class="result-hint">' + hint + '</span>' : '') +
                  '</div>' +
                  '<h3 class="result-title">' + title + '</h3>' +
                  (desc ? '<p class="result-desc">' + desc + '</p>' : '') +
                  metaRow +
                  '<span class="result-cta" aria-hidden="true">Zobrazit ' + ICON_ARROW + '</span>' +
                '</a>' +
              '</li>'
            );
          })
          .join("");
      }

      // Read initial query + filter from URL
      const urlParams = new URLSearchParams(window.location.search);
      const urlQuery  = urlParams.get("q") || "";
      let activeFilter = urlParams.get("type") || "";
      if (urlQuery) input.value = urlQuery;
      input.focus();

      function updateUrl(q, filter) {
        const url = new URL(window.location.href);
        if (q) url.searchParams.set("q", q);
        else url.searchParams.delete("q");
        if (filter) url.searchParams.set("type", filter);
        else url.searchParams.delete("type");
        window.history.replaceState({}, "", url);
      }

      // Update document title with current query
      function updateTitle(q) {
        document.title = q
          ? '„' + q + '" — vyhledávání | Recenzer.cz'
          : "Hledat | Recenzer.cz";
      }
      updateTitle(urlQuery);

      // Fetch index, then run query
      fetch("/search-index.json", { cache: "force-cache" })
        .then((r) => {
          if (!r.ok) throw new Error("HTTP " + r.status);
          return r.json();
        })
        .then((data) => {
          const all = data.entries || [];
          if (countEl) countEl.textContent = String(all.length);

          // Last successful score result kept here so a filter-chip
          // click can re-render without re-scoring.
          let lastScored = [];
          let lastTokens = [];
          let lastQuery  = "";

          function renderFilterBar(scored) {
            // Tally results per family
            const counts = {};
            const labels = {};
            const klass  = {};
            for (const { entry } of scored) {
              const fam = kindFamily(entry.kind);
              counts[fam.key] = (counts[fam.key] || 0) + 1;
              labels[fam.key] = fam.label;
              klass[fam.key]  = kindClass(entry.kind);
            }

            const familyKeys = Object.keys(counts);
            const showFilter =
              scored.length >= FILTER_MIN_RESULTS &&
              familyKeys.length >= FILTER_MIN_FAMILIES;

            if (!showFilter) {
              filterEl.hidden = true;
              filterChips.innerHTML = "";
              // If filter was active but no longer meaningful, drop it
              if (activeFilter) {
                activeFilter = "";
                updateUrl(lastQuery, "");
              }
              return;
            }

            // Sort families by descending count, then by Czech label
            familyKeys.sort((a, b) =>
              counts[b] - counts[a] || labels[a].localeCompare(labels[b], "cs")
            );

            // If active filter no longer matches any family, reset it
            if (activeFilter && !counts[activeFilter]) {
              activeFilter = "";
              updateUrl(lastQuery, "");
            }

            const allActive = activeFilter ? "" : " is-active";
            let chipsHtml =
              '<li><button type="button" class="filter-chip filter-all' + allActive +
              '" data-family="" aria-pressed="' + (activeFilter ? "false" : "true") +
              '">Vše <span class="filter-count">' + scored.length + '</span></button></li>';

            for (const key of familyKeys) {
              const isActive = key === activeFilter;
              chipsHtml +=
                '<li><button type="button" class="filter-chip ' + klass[key] +
                (isActive ? " is-active" : "") +
                '" data-family="' + escapeHtml(key) +
                '" aria-pressed="' + (isActive ? "true" : "false") + '">' +
                escapeHtml(labels[key]) +
                ' <span class="filter-count">' + counts[key] + '</span>' +
                '</button></li>';
            }
            filterChips.innerHTML = chipsHtml;
            filterEl.hidden = false;
          }

          function pluralVysledek(n) {
            return n === 1 ? "výsledek" : n < 5 ? "výsledky" : "výsledků";
          }

          function applyFilterAndRender() {
            const visible = activeFilter
              ? lastScored.filter(({ entry }) => kindFamily(entry.kind).key === activeFilter)
              : lastScored;

            if (!visible.length) {
              // Active filter has 0 hits — recover gracefully
              status.hidden = false;
              status.textContent =
                'V kategorii nejsou žádné výsledky. Klikněte na „Vše" pro reset.';
              list.innerHTML = "";
              return;
            }

            const word = pluralVysledek(visible.length);
            const totalNote =
              activeFilter && visible.length < lastScored.length
                ? " (z " + lastScored.length + ")"
                : "";
            status.hidden = false;
            status.textContent =
              "Nalezeno " + visible.length + " " + word + ' pro „' + lastQuery + '"' + totalNote;

            renderResults(visible, lastTokens);
          }

          function run(q) {
            const qt = tokens(q);
            if (!qt.length) {
              status.hidden = false;
              status.textContent = "Zadejte hledaný výraz.";
              list.innerHTML = "";
              filterEl.hidden = true;
              empty.hidden = true;
              initial.hidden = false;
              return;
            }
            initial.hidden = true;
            const scored = [];
            for (const e of all) {
              const s = scoreEntry(e, qt);
              if (s > 0) scored.push({ entry: e, score: s });
            }
            scored.sort((a, b) => b.score - a.score || a.entry.title.localeCompare(b.entry.title, "cs"));

            lastScored = scored;
            lastTokens = qt;
            lastQuery  = q;

            if (!scored.length) {
              status.hidden = false;
              status.textContent = 'Pro „' + q + '" nebyly nalezeny žádné výsledky.';
              list.innerHTML = "";
              filterEl.hidden = true;
              empty.hidden = false;
              return;
            }
            empty.hidden = true;
            renderFilterBar(scored);
            applyFilterAndRender();
          }

          // Filter chip click → swap active filter and re-render
          filterChips.addEventListener("click", function (e) {
            const btn = e.target.closest(".filter-chip");
            if (!btn) return;
            const fam = btn.getAttribute("data-family") || "";
            activeFilter = fam === activeFilter ? "" : fam;
            updateUrl(lastQuery, activeFilter);
            // Re-render chips to update aria-pressed/is-active states
            renderFilterBar(lastScored);
            applyFilterAndRender();
          });

          if (urlQuery) {
            run(urlQuery);
          } else {
            status.hidden = true;
            initial.hidden = false;
          }

          // Live search as the user types — debounced, updates URL without reload.
          let debounce;
          input.addEventListener("input", () => {
            clearTimeout(debounce);
            debounce = setTimeout(() => {
              const q = input.value.trim();
              updateUrl(q, activeFilter);
              updateTitle(q);
              run(q);
            }, 120);
          });
        })
        .catch((err) => {
          status.textContent = "Vyhledávací index se nepodařilo načíst. " + (err && err.message ? "(" + err.message + ")" : "");
        });

      // Submit handler: prevent default if JS is active, just run inline.
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        input.dispatchEvent(new Event("input"));
        input.focus();
      });
    })();
  </script>

  <style is:global>
    .inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: clamp(2rem, 4vw, 3.5rem) var(--gutter) clamp(3rem, 5vw, 5rem);
    }

    .search-head {
      max-width: 760px;
      margin: 0 auto 2.5rem;
      text-align: center;
    }

    .eyebrow {
      font-family: var(--mono);
      font-size: 11.5px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--p-700);
      font-weight: 700;
      margin: 0 0 0.6rem;
    }

    .search-head h1 {
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--ink);
      line-height: 1.15;
      margin: 0 0 0.85rem;
    }

    .lead {
      font-size: 15px;
      line-height: 1.6;
      color: var(--muted);
      margin: 0 0 2rem;
    }

    .lead strong { color: var(--ink); font-weight: 700; }

    .search-form {
      width: 100%;
      max-width: 600px;
      margin: 0 auto;
    }

    .search-input-wrap {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.5rem 0.5rem 1rem;
      background: #fff;
      border: 2px solid var(--p-700);
      border-radius: 999px;
      box-shadow: 0 8px 24px -12px rgba(46, 20, 102, 0.22);
    }

    .search-input-wrap:focus-within {
      border-color: var(--p-500);
      box-shadow: 0 0 0 4px rgba(122, 79, 227, 0.18);
    }

    .search-icon {
      width: 18px;
      height: 18px;
      color: var(--p-700);
      flex-shrink: 0;
    }

    .search-input-wrap input[type="search"] {
      border: 0;
      background: transparent;
      padding: 0.75rem 0;
      font-size: 16px;
      color: var(--ink);
      font-family: inherit;
      width: 100%;
    }

    .search-input-wrap input[type="search"]:focus {
      outline: none;
    }

    .search-input-wrap input[type="search"]::-webkit-search-cancel-button {
      -webkit-appearance: none;
      appearance: none;
    }

    .search-submit {
      padding: 0.7rem 1.4rem;
      border: 0;
      border-radius: 999px;
      background: var(--p-700);
      color: #fff;
      font-weight: 700;
      font-size: 14px;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.15s;
    }

    .search-submit:hover,
    .search-submit:focus-visible {
      background: var(--p-800);
    }

    .visually-hidden {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .search-status {
      max-width: 760px;
      margin: 0 auto 1.5rem;
      text-align: center;
      font-size: 14px;
      color: var(--muted);
      font-family: var(--mono);
      letter-spacing: 0.02em;
    }

    .search-status[hidden] { display: none; }

    /* ============ FILTER BAR ============ */
    .search-filter {
      max-width: 760px;
      margin: 0 auto 1.5rem;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem 0.85rem;
      padding: 0.85rem 1rem;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
    }

    .search-filter[hidden] { display: none; }

    .filter-label {
      font-family: var(--mono);
      font-size: 10.5px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      font-weight: 700;
      padding-right: 0.25rem;
      flex-shrink: 0;
    }

    .filter-chips {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 4px 11px;
      border-radius: 999px;
      background: #fff;
      color: var(--kc-text, var(--ink-soft));
      border: 1px solid var(--line);
      font-family: inherit;
      font-size: 12.5px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s, color 0.12s;
    }

    .filter-chip:hover,
    .filter-chip:focus-visible {
      border-color: var(--kc-border, var(--p-400));
      background: var(--kc-bg, var(--p-50));
      outline: none;
    }

    .filter-chip.is-active {
      background: var(--kc-border, var(--p-700));
      border-color: var(--kc-border, var(--p-700));
      color: #fff;
    }

    .filter-chip.filter-all {
      --kc-text:   var(--p-700);
      --kc-bg:     var(--p-50);
      --kc-border: var(--p-700);
    }

    .filter-count {
      display: inline-block;
      min-width: 1.5em;
      padding: 1px 6px;
      border-radius: 999px;
      background: var(--kc-bg, var(--bg-warm));
      color: var(--kc-text, var(--muted));
      font-family: var(--mono);
      font-size: 10.5px;
      font-weight: 700;
      text-align: center;
      line-height: 1.4;
    }

    .filter-chip.is-active .filter-count {
      background: rgba(255, 255, 255, 0.22);
      color: #fff;
    }

    .search-results {
      list-style: none;
      padding: 0;
      margin: 0 auto;
      max-width: 760px;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }

    /* ============ KIND COLOR TOKENS ============
       Each .k-* class sets 3 custom properties used downstream:
         --kc-bg     — chip background
         --kc-text   — chip text + left-border accent
         --kc-border — visible left-border accent color
    */
    .k-article    { --kc-bg: var(--p-50);    --kc-text: var(--p-700);  --kc-border: var(--p-500); }
    .k-category   { --kc-bg: #e0f2fe;        --kc-text: #075985;       --kc-border: #0284c7; }
    .k-glossary   { --kc-bg: var(--green-bg);--kc-text: var(--green-text); --kc-border: var(--green); }
    .k-brand      { --kc-bg: var(--amber-bg);--kc-text: var(--amber-text); --kc-border: var(--amber); }
    .k-magazine   { --kc-bg: #fce7f3;        --kc-text: #9d174d;       --kc-border: #db2777; }
    .k-interview  { --kc-bg: #ccfbf1;        --kc-text: #115e59;       --kc-border: #14b8a6; }
    .k-forum      { --kc-bg: #fff7ed;        --kc-text: #9a3412;       --kc-border: #ea580c; }
    .k-person     { --kc-bg: #e0e7ff;        --kc-text: #3730a3;       --kc-border: #6366f1; }
    .k-standards  { --kc-bg: #dcfce7;        --kc-text: #14532d;       --kc-border: #16a34a; }
    .k-corrections{ --kc-bg: #fee2e2;        --kc-text: #991414;       --kc-border: #dc2626; }
    .k-legal      { --kc-bg: #f1f5f9;        --kc-text: #475569;       --kc-border: #64748b; }
    .k-hub        { --kc-bg: #f3e8ff;        --kc-text: #6b21a8;       --kc-border: #a855f7; }
    .k-page       { --kc-bg: #f1f5f9;        --kc-text: #334155;       --kc-border: #64748b; }

    .search-result .result-link {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "head head"
        "title title"
        "desc desc"
        "meta cta";
      gap: 0.5rem 1rem;
      align-items: end;
      padding: 1.2rem 1.4rem 1.1rem;
      background: #fff;
      border: 1px solid var(--line);
      border-left: 4px solid var(--kc-border, var(--p-500));
      border-radius: var(--r-lg);
      text-decoration: none;
      color: var(--ink);
      transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    }

    @media (max-width: 540px) {
      .search-result .result-link {
        grid-template-areas:
          "head"
          "title"
          "desc"
          "meta"
          "cta";
        grid-template-columns: 1fr;
      }
    }

    .search-result .result-link:hover,
    .search-result .result-link:focus-visible {
      border-color: var(--kc-border, var(--p-400));
      transform: translateY(-1px);
      box-shadow: 0 12px 28px -18px rgba(46, 20, 102, 0.28);
      outline: none;
    }

    .result-head {
      grid-area: head;
      display: flex;
      gap: 0.6rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 0;
    }

    .result-kind {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 2px 9px;
      border-radius: 999px;
      background: var(--kc-bg, var(--p-50));
      color: var(--kc-text, var(--p-700));
      font-family: var(--mono);
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .result-hint {
      font-size: 12.5px;
      color: var(--muted);
      font-weight: 500;
      line-height: 1.3;
    }

    .result-title {
      grid-area: title;
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.015em;
      line-height: 1.3;
      margin: 0;
    }

    .search-result .result-link:hover .result-title,
    .search-result .result-link:focus-visible .result-title {
      color: var(--kc-text, var(--p-700));
    }

    .result-desc {
      grid-area: desc;
      margin: 0;
      font-size: 13.5px;
      line-height: 1.55;
      color: var(--ink-soft);
    }

    .result-meta {
      grid-area: meta;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 1rem;
      font-size: 12.5px;
      color: var(--muted);
      margin-top: 0.25rem;
    }

    .result-meta-item {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      line-height: 1.4;
    }

    .result-meta-ic {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--muted-2);
    }

    .result-meta-ic svg {
      width: 100%;
      height: 100%;
    }

    .result-meta time { font-variant-numeric: tabular-nums; }

    .result-cta {
      grid-area: cta;
      justify-self: end;
      align-self: end;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.5rem 0.95rem;
      border-radius: 999px;
      background: var(--kc-bg, var(--p-50));
      color: var(--kc-text, var(--p-700));
      font-family: inherit;
      font-size: 13px;
      font-weight: 700;
      white-space: nowrap;
      transition: background 0.15s, color 0.15s, transform 0.15s;
    }

    .search-result .result-link:hover .result-cta,
    .search-result .result-link:focus-visible .result-cta {
      background: var(--kc-border, var(--p-700));
      color: #fff;
      transform: translateX(2px);
    }

    .result-cta svg {
      width: 14px;
      height: 14px;
    }

    .search-result mark {
      background: #fef08a;
      color: inherit;
      padding: 0 1px;
      border-radius: 2px;
      font-weight: 700;
    }

    .search-empty,
    .search-initial {
      max-width: 760px;
      margin: 2rem auto 0;
      padding: 1.5rem 1.75rem;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
    }

    .search-empty[hidden],
    .search-initial[hidden] { display: none; }

    .search-empty h2,
    .search-initial h2 {
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.015em;
      margin: 0 0 0.75rem;
    }

    .search-empty p {
      font-size: 14.5px;
      color: var(--ink-soft);
      line-height: 1.6;
      margin: 0 0 0.85rem;
    }

    .empty-links {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .empty-links a {
      display: inline-block;
      padding: 0.45rem 0.85rem;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--p-700);
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
    }

    .empty-links a:hover,
    .empty-links a:focus-visible {
      border-color: var(--p-400);
      background: var(--p-50);
    }

    .initial-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    @media (max-width: 600px) {
      .initial-grid { grid-template-columns: 1fr; }
    }

    .initial-grid li {
      padding: 0.85rem 1rem;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--r);
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .initial-grid strong {
      color: var(--ink);
      font-weight: 700;
      font-size: 13.5px;
    }

    .initial-grid span {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }
  </style>
</BaseLayout>
