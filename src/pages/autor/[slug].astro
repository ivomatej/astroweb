---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../../components/page/PageBreadcrumbs.astro";
import { allPeople, getPersonBySlug } from "../../data/people";

export function getStaticPaths() {
  return allPeople.map((person) => ({
    params: { slug: person.slug },
    props: { person },
  }));
}

const { person } = Astro.props;
if (!person) return Astro.redirect("/404");

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}

const kindLabel = person.kind === "internal" ? "Interní redakce" : "Externí odborný garant";
---

<BaseLayout
  title={`${person.name} — ${person.role} | Recenzer`}
  description={person.tagline}
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { href: "/autori/", label: "Autoři" },
      { label: person.name },
    ]}
  />

  <!-- Hero -->
  <header class:list={["autor-hero", `kind-${person.kind}`]}>
    <div class="inner">
      <div class="hero-grid">
        <div class:list={["hero-avatar", `kind-${person.kind}`]}>
          {person.photoUrl ? (
            <img src={person.photoUrl} alt={person.name} />
          ) : (
            <span>{person.initials ?? person.name.slice(0, 2)}</span>
          )}
        </div>
        <div class="hero-body">
          <p class="hero-eyebrow">{kindLabel} · Recenzer.cz</p>
          <h1 class="hero-name">{person.name}</h1>
          <p class="hero-role">{person.role}</p>
          <p class="hero-tagline">{person.tagline}</p>
          {person.links && person.links.length > 0 && (
            <div class="hero-links">
              {person.links.map((l) => (
                <a href={l.href}>{l.label}</a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </header>

  <!-- Stats -->
  {person.stats && person.stats.length > 0 && (
    <section class="autor-stats">
      <div class="inner">
        <ul>
          {person.stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Long bio -->
  {person.longBioHtml && (
    <section class="autor-bio">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">O autorovi</p>
          <h2>Cesta k Recenzer.cz</h2>
        </header>
        <div class="bio-content" set:html={person.longBioHtml} />
      </div>
    </section>
  )}

  <!-- Expertise -->
  {person.expertise.length > 0 && (
    <section class="autor-expertise">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">Čemu se věnuji</p>
          <h2>Oblasti odbornosti</h2>
        </header>
        <ul class="expertise-chips">
          {person.expertise.map((e) => <li>{e}</li>)}
        </ul>
      </div>
    </section>
  )}

  <!-- Credentials -->
  {person.credentials.length > 0 && (
    <section class="autor-creds">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">Vzdělání a zkušenosti</p>
          <h2>Kvalifikace</h2>
        </header>
        <ul class="creds-list">
          {person.credentials.map((c) => (
            <li set:html={c} />
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Timeline -->
  {person.timeline && person.timeline.length > 0 && (
    <section class="autor-timeline">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">Career</p>
          <h2>Kariérní timeline</h2>
        </header>
        <ol class="timeline-line">
          {person.timeline.map((t) => (
            <li>
              <span class="tl-year">{t.year}</span>
              <div>
                <h3>{t.title}</h3>
                <p>{t.text}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}

  <!-- Articles -->
  {person.articles && person.articles.length > 0 && (
    <section class="autor-articles">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">Publikace</p>
          <h2>Co jsem napsal nebo schválil</h2>
          <p class="lead">
            Poslední {person.articles.length} článků, na kterých jsem se podílel — buď jako autor, nebo jako garant kontroly.
          </p>
        </header>
        <ul class="articles-list">
          {person.articles.map((a) => (
            <li>
              <a href={a.href}>
                <div class="art-meta">
                  <span class="art-cat">{a.category}</span>
                  <time datetime={a.date}>{formatCzechDate(a.date)}</time>
                </div>
                <h3>{a.title}</h3>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Profesní registrace s ověřitelnými ID -->
  {person.professionalRegistrations && person.professionalRegistrations.length > 0 && (
    <section class="autor-registrations">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">Profesní registrace · ověřitelné</p>
          <h2>Certifikáty a členství</h2>
          <p class="lead">
            Každý záznam má <strong>identifikátor pro ověření</strong> u vystavující organizace. Kliknutím na odkaz najdete autora v jejich veřejném registru.
          </p>
        </header>
        <ul class="reg-list">
          {person.professionalRegistrations.map((r) => (
            <li class="reg-card">
              <div class="reg-card-head">
                <span class="reg-body">{r.body}</span>
                {r.href && (
                  <a href={r.href} rel="noopener" target="_blank" class="reg-verify-link">
                    Ověřit
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                  </a>
                )}
              </div>
              <div class="reg-title">{r.title}</div>
              {r.identifier && (
                <div class="reg-id-row">
                  <span class="reg-id-label">ID / Cert. č.</span>
                  <code class="reg-id">{r.identifier}</code>
                </div>
              )}
              {(r.issuedAt || r.validUntil) && (
                <div class="reg-dates">
                  {r.issuedAt && <span><strong>Vydáno:</strong> <time datetime={r.issuedAt}>{formatCzechDate(r.issuedAt)}</time></span>}
                  {r.validUntil && <span><strong>Platnost do:</strong> <time datetime={r.validUntil}>{formatCzechDate(r.validUntil)}</time></span>}
                </div>
              )}
              {r.note && <p class="reg-note">{r.note}</p>}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Externí publikace -->
  {person.externalPublications && person.externalPublications.length > 0 && (
    <section class="autor-publications">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">Publikace mimo Recenzer</p>
          <h2>Knihy, papers, přednášky</h2>
          <p class="lead">
            Externě publikované práce s ověřitelným identifikátorem (ISBN, ISSN, DOI). Kliknutím se dostanete na databázi nebo přímo na zdroj.
          </p>
        </header>
        <ul class="pub-list">
          {person.externalPublications.map((p) => (
            <li class="pub-card">
              <span class={`pub-kind pub-kind-${p.kind}`}>
                {p.kind === "book" && "Kniha"}
                {p.kind === "article" && "Odborný článek"}
                {p.kind === "talk" && "Přednáška"}
                {p.kind === "course" && "Online kurz"}
              </span>
              <h3 class="pub-title">
                {p.href ? (
                  <a href={p.href} rel="noopener" target="_blank">{p.title}</a>
                ) : (
                  p.title
                )}
              </h3>
              <div class="pub-meta">
                {p.publisher && <span><strong>{p.publisher}</strong></span>}
                <span class="pub-year">{p.year}</span>
                {p.role && <span class="pub-role">{p.role}</span>}
              </div>
              {p.identifier && (
                <div class="pub-id-row">
                  <code class="pub-id">{p.identifier}</code>
                </div>
              )}
              {p.description && <p class="pub-desc">{p.description}</p>}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Externí mediální citace -->
  {person.mediaCitationsDetailed && person.mediaCitationsDetailed.length > 0 ? (
    <section class="autor-media-detailed">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">V médiích · konkrétní citace</p>
          <h2>Kde citovali Recenzer.cz nebo autora</h2>
          <p class="lead">
            Konkrétní články v ostatních médiích. <strong>Bez konkrétního URL je „byli jsme v médiích" prázdné tvrzení</strong> — proto je tu uvádíme přesně.
          </p>
        </header>
        <ul class="media-detailed-list">
          {person.mediaCitationsDetailed.map((m) => (
            <li class="media-citation">
              <div class="media-citation-head">
                <span class="media-outlet">{m.outlet}</span>
                <time class="media-date" datetime={m.date}>{formatCzechDate(m.date)}</time>
              </div>
              <h3 class="media-title">
                <a href={m.href} rel="noopener" target="_blank">
                  {m.title}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              </h3>
              {m.excerpt && <p class="media-excerpt">„{m.excerpt}"</p>}
              <div class="media-url">
                <code>{m.href.replace(/^https?:\/\//, "").slice(0, 70)}{m.href.replace(/^https?:\/\//, "").length > 70 ? "…" : ""}</code>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ) : person.mediaCitations && person.mediaCitations.length > 0 && (
    <section class="autor-media">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">V médiích</p>
          <h2>Recenzer.cz citovali</h2>
          <p class="lead">
            Pro tohoto autora připravujeme konkrétní URL každé citace.
          </p>
        </header>
        <ul class="media-logos">
          {person.mediaCitations.map((m) => <li>{m}</li>)}
        </ul>
      </div>
    </section>
  )}

  <!-- Sociální / profesní profily -->
  {person.socialProfiles && person.socialProfiles.length > 0 && (
    <section class="autor-socials">
      <div class="inner">
        <header class="section-head">
          <p class="eyebrow">Sociální a profesní profily</p>
          <h2>Ověřte si nás na externích platformách</h2>
          <p class="lead">
            <strong>Timeline na LinkedIn musí sedět s touto stránkou.</strong> Pokud zjistíte nesoulad, napište nám na <a href="mailto:redakce@recenzer.cz">redakce@recenzer.cz</a> — opravíme.
          </p>
        </header>
        <ul class="socials-grid">
          {person.socialProfiles.map((s) => (
            <li class="social-card">
              <div class="social-icon" aria-hidden="true">
                {s.network === "linkedin" && (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 1 1 8.25 6.5 1.75 1.75 0 0 1 6.5 8.25zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0 0 13 14.19V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
                )}
                {s.network === "github" && (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2C5.86 21 5.18 18.65 5.18 18.65c-.53-1.34-1.29-1.7-1.29-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.04 11.04 0 0 1 5.8 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.07.78 2.16v3.2c0 .31.21.68.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
                )}
                {(s.network === "twitter" || s.network === "x") && (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                )}
                {s.network === "orcid" && (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947 0 .525-.422.947-.947.947-.525 0-.946-.422-.946-.947 0-.525.421-.947.946-.947zm-.722 3.038h1.444v10.041H6.647zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722z"/></svg>
                )}
                {s.network === "website" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                )}
                {s.network === "instagram" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                )}
                {(s.network === "youtube" || s.network === "mastodon" || s.network === "scholar") && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                )}
              </div>
              <div class="social-content">
                <div class="social-network">{s.network.toUpperCase()}</div>
                <a href={s.href} rel="noopener" target="_blank" class="social-handle">{s.handle}</a>
                {s.note && <p class="social-note">{s.note}</p>}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Contact -->
  <section class="autor-contact">
    <div class="inner">
      <div class="contact-card">
        <h2>Máte na mě otázku?</h2>
        <p>
          Odpovídám zpravidla do 24 hodin v pracovní dny. Pište otevřeně — tipy, otázky, kritiku, vše vítáme.
        </p>
        {person.contactEmail ? (
          <div class="contact-actions">
            <a href={`mailto:${person.contactEmail}`} class="btn-primary">
              {person.contactEmail}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
            <a href="/autori/" class="btn-ghost">Všichni autoři</a>
          </div>
        ) : (
          <div class="contact-actions">
            <a href="mailto:redakce@recenzer.cz" class="btn-primary">
              redakce@recenzer.cz
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
            <a href="/autori/" class="btn-ghost">Všichni autoři</a>
          </div>
        )}
      </div>
    </div>
  </section>

  <style>
    .inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: clamp(2rem, 4vw, 3rem) var(--gutter);
    }

    .section-head {
      max-width: 65ch;
      margin: 0 0 1.75rem;
    }

    .eyebrow {
      font-family: var(--mono);
      font-size: 11.5px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--p-700);
      font-weight: 700;
      margin: 0 0 0.5rem;
    }

    .section-head h2 {
      font-size: clamp(1.4rem, 2.5vw, 1.85rem);
      font-weight: 800;
      letter-spacing: -0.025em;
      color: var(--ink);
      line-height: 1.2;
      margin-bottom: 0.6rem;
    }

    .section-head .lead {
      font-size: 15px;
      line-height: 1.6;
      color: var(--muted);
      margin: 0;
    }

    /* Hero */
    .autor-hero {
      background:
        radial-gradient(900px circle at 90% 0%, rgba(149, 114, 240, 0.14), transparent 55%),
        radial-gradient(700px circle at 10% 110%, rgba(99, 50, 204, 0.08), transparent 55%),
        var(--bg);
      border-bottom: 1px solid var(--line);
    }

    .autor-hero.kind-external {
      background:
        radial-gradient(900px circle at 90% 0%, rgba(180, 83, 9, 0.12), transparent 55%),
        radial-gradient(700px circle at 10% 110%, rgba(180, 83, 9, 0.06), transparent 55%),
        var(--bg);
    }

    .autor-hero .inner {
      padding: clamp(2.5rem, 5vw, 4rem) var(--gutter);
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 2rem;
      align-items: center;
    }

    @media (max-width: 600px) { .hero-grid { grid-template-columns: 100px 1fr; gap: 1.25rem; } }

    .hero-avatar {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: var(--p-100);
      color: var(--p-700);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 42px;
      flex-shrink: 0;
      overflow: hidden;
    }

    @media (max-width: 600px) {
      .hero-avatar { width: 100px; height: 100px; font-size: 30px; }
    }

    .hero-avatar.kind-external {
      background: var(--amber-bg);
      color: var(--amber);
    }

    .hero-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--p-700);
      font-weight: 700;
      margin: 0 0 0.5rem;
    }

    .autor-hero.kind-external .hero-eyebrow { color: var(--amber); }

    .hero-name {
      font-size: clamp(1.85rem, 4vw, 2.75rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--ink);
      line-height: 1.1;
      margin: 0 0 0.4rem;
    }

    .hero-role {
      font-size: clamp(1rem, 1.4vw, 1.15rem);
      font-weight: 600;
      color: var(--p-700);
      margin: 0 0 0.85rem;
    }

    .autor-hero.kind-external .hero-role { color: var(--amber); }

    .hero-tagline {
      font-size: 15px;
      line-height: 1.55;
      color: var(--ink-soft);
      margin: 0 0 1.25rem;
      max-width: 60ch;
    }

    .hero-links {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .hero-links a {
      padding: 0.45rem 0.95rem;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--r);
      font-size: 13px;
      font-weight: 600;
      color: var(--ink);
      text-decoration: none;
    }

    .hero-links a:hover,
    .hero-links a:focus-visible {
      border-color: var(--p-400);
      color: var(--p-700);
    }

    /* Stats */
    .autor-stats {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }

    .autor-stats .inner {
      padding: 2rem var(--gutter);
    }

    .autor-stats ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 720px) { .autor-stats ul { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }

    .autor-stats li {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding-top: 0.75rem;
      border-top: 2px solid var(--p-200);
    }

    .autor-stats strong {
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.02em;
      line-height: 1;
    }

