---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../../components/page/PageBreadcrumbs.astro";
import AuthorView from "../../components/author/AuthorView.astro";
import { allPeople } from "../../data/people";

export function getStaticPaths() {
  return allPeople.map((person) => ({
    params: { slug: person.slug },
    props: { person },
  }));
}

const { person } = Astro.props;
if (!person) return Astro.redirect("/404");
---

<BaseLayout
  title={`${person.name} — ${person.role} | Recenzer`}
  description={person.tagline}
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { href: "/autori/", label: "Autoři" },
      { label: person.name },
    ]}
  />

  <AuthorView person={person} articles={person.articles} />
</BaseLayout>
