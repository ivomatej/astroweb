---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";
import { getAllJobs, jobTypeMeta } from "../data/jobs";

const allJobs = getAllJobs();
const lastUpdated = "2026-05-21";

const stats = [
  { value: `${allJobs.length}`, label: "otevřených pozic" },
  { value: "14", label: "lidí v týmu" },
  { value: "100 %", label: "Remote-friendly" },
  { value: "30 dní", label: "dovolené" },
];

const benefits = [
  {
    icon: "money",
    title: "Férová mzda nezávislá na affiliate",
    text:
      "Autoři dostávají <strong>fixní honoráře</strong>, ne provize z prodeje. Vaše hodnocení produktu neovlivňuje vaši výplatu. Etika je infrastruktura, ne motto.",
  },
  {
    icon: "home",
    title: "Plně remote-first",
    text:
      "Pracujte odkud chcete v rámci ČR/SK. Občasné cestování do laboratoře Brno (1× měsíčně) je benefit, ne povinnost.",
  },
  {
    icon: "tools",
    title: "Hardware budget 50–60k Kč ročně",
    text:
      "Vlastní notebook, monitor, ergonomické sedačka, sluchátka — výběr na vás. Po 3 letech zařízení odkupujete za zůstatkovou cenu.",
  },
  {
    icon: "growth",
    title: "Vzdělávací rozpočet 30 000 Kč ročně",
    text:
      "Konference, kurzy, knihy, jazykové školy. Bez schvalování drobností pod 5 000 Kč. Vy víte nejlépe, co potřebujete.",
  },
  {
    icon: "lab",
    title: "Plný přístup do testovací laboratoře",
    text:
      "Naše 180 m² laboratoř v Brně-Židenicích máte k dispozici pro vlastní testy i osobní projekty (po dohodě).",
  },
  {
    icon: "freedom",
    title: "Žádné meeting kultura",
    text:
      "Async-first komunikace přes Linear + Slack. Pravidelný 30min weekly + 4× ročně off-site. Žádné daily stand-upy v 9:00.",
  },
];

const process = [
  {
    num: "01",
    title: "Pošlete CV + portfolio",
    text:
      "E-mailem na <a href=\"mailto:kariera@recenzer.cz\">kariera@recenzer.cz</a>. Nepotřebujeme motivační dopis ani LinkedIn — stačí <strong>3 ukázky vaší práce</strong> (články, kód, redaktorské úpravy).",
    timing: "Den 0",
  },
  {
    num: "02",
    title: "Odpověď do 5 pracovních dnů",
    text:
      "Vyřizuje hiring manager dané pozice (uvedeno u inzerátu). Pošleme buď pozvánku na pohovor, nebo věcné zamítnutí s důvodem.",
    timing: "Do 5 dnů",
  },
  {
    num: "03",
    title: "30min úvodní rozhovor",
    text:
      "Videohovor (Google Meet / Whereby) s hiring managerem a šéfredaktorem. <strong>Mluvíme o vaší motivaci a souladu s editoriálními standardy</strong> — ne o tom, „kde se vidíte za 5 let“.",
    timing: "Týden 1",
  },
  {
    num: "04",
    title: "Praktický úkol",
    text:
      "Záleží na pozici: <strong>redaktor</strong> dostane návrh článku k oponentuře (2 h placené práce), <strong>developer</strong> code-review existujícího PR, <strong>garant</strong> konzultaci jednoho čerstvého testu.",
    timing: "Týden 2",
  },
  {
    num: "05",
    title: "Finální rozhovor + nabídka",
    text:
      "60min rozhovor se šéfredaktorem + kolegou z týmu. Probíráme detail spolupráce, mzdu, benefity. Do 48 h pošleme finální nabídku.",
    timing: "Týden 3",
  },
];
---

<BaseLayout
  title="Kariéra v Recenzer.cz — otevřené pozice pro novináře, autory, developery"
  description="Otevřené pozice v Recenzer.cz — redakce domácích spotřebičů, elektroniky, externí garanti, frontend developer, korektor, stáž. Plně remote-first, férová mzda nezávislá na affiliate."
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Kariéra" }]} />

  <PageHero
    eyebrow="Recenzer.cz · od 2016"
    eyebrowIcon="info"
    title="Hledáme lidi, kteří<br/><em>nelžou pro provizi</em>"
    subtitle={`Aktuálně máme otevřených <strong>${allJobs.length} pozic</strong> — od interní redakce po stáž. Všechny v duchu jediné věci, na které stavíme: <strong>editorial nezávislost je důležitější než affiliate provize</strong>.`}
  />

  <!-- ============ STATS ============ -->
  <section class="stats-strip">
    <div class="inner">
      <ul>
        {
          stats.map((s) => (
            <li>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ POSITIONS ============ -->
  <section class="kariera-positions">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Otevřené pozice</p>
        <h2>{allJobs.length} pozic, které právě hledáme</h2>
        <p class="lead">
          Pokud vás zaujme jakákoliv pozice, pošlete CV a 3 ukázky práce na <a href="mailto:kariera@recenzer.cz">kariera@recenzer.cz</a>. Odpovídáme do 5 pracovních dnů.
        </p>
      </header>

      <ul class="positions-list">
        {
          allJobs.map((job) => (
            <li class={`position-card tone-${jobTypeMeta[job.type].tone}`}>
              <div class="position-icon" aria-hidden="true">
                {job.type === "editorial" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20h9" />
                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z" />
                  </svg>
                )}
                {job.type === "expert" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  </svg>
                )}
                {job.type === "tech" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="16 18 22 12 16 6" />
                    <polyline points="8 6 2 12 8 18" />
                  </svg>
                )}
                {job.type === "editor" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="9" y1="13" x2="15" y2="13" />
                    <line x1="9" y1="17" x2="15" y2="17" />
                  </svg>
                )}
                {job.type === "internship" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                    <polyline points="22 4 12 14.01 9 11.01" />
                  </svg>
                )}
              </div>
              <div class="position-body">
                <div class="position-meta">
                  <span class={`position-type position-type-${jobTypeMeta[job.type].tone}`}>{jobTypeMeta[job.type].label}</span>
                  <span class="position-badge">{job.shortBadge}</span>
                  <span class="position-compensation">{job.compensation}</span>
                </div>
                <h3 class="position-title">
                  <a href={`/kariera/${job.slug}/`}>{job.title}</a>
                </h3>
                <p class="position-summary">{job.summary}</p>
                <footer class="position-footer">
                  <span class="position-manager">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </svg>
                    {job.hiringManager}
                  </span>
                  <a href={`/kariera/${job.slug}/`} class="position-detail">
                    Detail pozice
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </a>
                </footer>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ BENEFITS ============ -->
  <section class="kariera-benefits">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Co u nás dostanete</p>
        <h2>Benefity, které nejsou ovoce v kuchyni</h2>
        <p class="lead">
          Nemáme ping-pong stůl ani pivo v ledničce. Místo toho: fixní mzda nezávislá na affiliate, hardware budget a vlastní laboratoř.
        </p>
      </header>
      <ul class="benefits-grid">
        {
          benefits.map((b) => (
            <li class="benefit-card">
              <div class="benefit-icon" aria-hidden="true">
                {b.icon === "money" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23" />
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                  </svg>
                )}
                {b.icon === "home" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                  </svg>
                )}
                {b.icon === "tools" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                  </svg>
                )}
                {b.icon === "growth" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
                    <polyline points="17 6 23 6 23 12" />
                  </svg>
                )}
                {b.icon === "lab" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 2v7.31" />
                    <path d="M14 9.3V2" />
                    <path d="M8.5 2h7" />
                    <path d="M14 9.3a6.5 6.5 0 1 1-4 0" />
                  </svg>
                )}
                {b.icon === "freedom" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                )}
              </div>
              <h3>{b.title}</h3>
              <p set:html={b.text} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ PROCESS ============ -->
  <section class="kariera-process">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Výběrový proces</p>
        <h2>5 kroků od CV po nástup</h2>
        <p class="lead">
          Trvá to <strong>2–4 týdny</strong>. Žádné assessment centra ani 7 kol pohovorů. Pokud to zabere déle než měsíc, je něco špatně — řekněte nám.
        </p>
      </header>
      <ol class="process-list">
        {
          process.map((p) => (
            <li>
              <div class="process-num-wrap">
                <span class="process-num">{p.num}</span>
                <span class="process-timing">{p.timing}</span>
              </div>
              <div class="process-body">
                <h3>{p.title}</h3>
                <p set:html={p.text} />
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="kariera-cta">
    <div class="inner">
      <div class="cta-card">
        <h2>Nevidíte svou pozici?</h2>
        <p>
          Pokud věříte, že byste do redakce pasovali a vaše kvalifikace nesedí přesně na žádný z aktuálních inzerátů, napište. <strong>Rádi se dozvíme o talentu předtím, než budeme inzerovat.</strong>
        </p>
        <div class="cta-actions">
          <a href="mailto:kariera@recenzer.cz?subject=Zájem%20o%20spolupráci" class="btn-primary">
            kariera@recenzer.cz
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <a href="/o-nas/" class="btn-ghost">O redakci</a>
          <a href="/eticky-kodex/" class="btn-ghost">Etický kodex</a>
          <a href="/sefredaktor/" class="btn-ghost">Šéfredaktor</a>
        </div>
      </div>
      <p class="cta-meta">
        Aktualizace inzerátů průběžně · poslední revize <time datetime={lastUpdated}>{lastUpdated}</time>.
      </p>
    </div>
  </section>

  <style>
    .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
    .section-head { max-width: 65ch; margin: 0 0 2rem; }
    .eyebrow {
      font-family: var(--mono); font-size: 11.5px; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--p-700); font-weight: 700; margin: 0 0 0.5rem;
    }
    .section-head h2 {
      font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; letter-spacing: -0.025em;
      color: var(--ink); line-height: 1.2; margin-bottom: 0.6rem;
    }
    .section-head .lead { font-size: 15px; line-height: 1.6; color: var(--muted); margin: 0; }
    .section-head .lead strong { color: var(--ink); }
    .section-head .lead a { color: var(--p-700); text-decoration: none; border-bottom: 1px dashed var(--p-300); }

    /* Stats */
    .stats-strip { background: var(--bg); border-bottom: 1px solid var(--line); }
    .stats-strip .inner { padding: 2rem var(--gutter); }
    .stats-strip ul {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    }
    @media (max-width: 720px) { .stats-strip ul { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
    .stats-strip li {
      display: flex; flex-direction: column; gap: 4px;
      padding-top: 0.75rem; border-top: 2px solid var(--p-200);
    }
    .stats-strip strong {
      font-size: clamp(1.5rem, 2.7vw, 2rem); font-weight: 800;
      color: var(--ink); letter-spacing: -0.02em; line-height: 1;
    }
    .stats-strip span { font-size: 12px; color: var(--muted); line-height: 1.3; }

    /* Positions */
    .kariera-positions { background: var(--bg-warm); border-bottom: 1px solid var(--line); }
    .positions-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 0.85rem;
    }
    .position-card {
      display: grid; grid-template-columns: 64px 1fr; gap: 1.25rem;
      padding: 1.5rem 1.75rem; background: var(--bg);
      border: 1px solid var(--line); border-radius: var(--r-lg);
      transition: transform 0.15s ease, border-color 0.15s ease;
    }
    @media (max-width: 600px) { .position-card { grid-template-columns: 1fr; gap: 0.85rem; padding: 1.25rem; } }
    .position-card:hover { transform: translateY(-2px); border-color: var(--p-300); }
    .position-card.tone-purple { border-left: 4px solid var(--p-500); }
    .position-card.tone-amber { border-left: 4px solid var(--amber); }
    .position-card.tone-green { border-left: 4px solid var(--green); }
    .position-card.tone-red { border-left: 4px solid var(--red); }
    .position-card.tone-muted { border-left: 4px solid var(--muted-2); }

    .position-icon {
      width: 64px; height: 64px; border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      background: var(--p-50); color: var(--p-700);
    }
    .position-card.tone-amber .position-icon { background: var(--amber-bg); color: var(--amber); }
    .position-card.tone-green .position-icon { background: var(--green-bg); color: var(--green); }
    .position-card.tone-red .position-icon { background: var(--red-bg); color: var(--red); }
    .position-card.tone-muted .position-icon { background: var(--bg-warm); color: var(--muted); }
    .position-icon svg { width: 28px; height: 28px; }

    .position-meta {
      display: flex; flex-wrap: wrap; gap: 0.4rem 0.75rem;
      align-items: center; margin-bottom: 0.55rem;
    }
    .position-type {
      font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase;
      letter-spacing: 0.08em; font-weight: 700;
      padding: 0.2rem 0.55rem; border-radius: 99px;
      background: var(--p-50); color: var(--p-700);
    }
    .position-type-amber { background: var(--amber-bg); color: var(--amber); }
    .position-type-green { background: var(--green-bg); color: var(--green); }
    .position-type-red { background: var(--red-bg); color: var(--red); }
    .position-type-muted { background: var(--bg-warm); color: var(--muted); border: 1px solid var(--line); }

    .position-badge {
      font-family: var(--mono); font-size: 0.72rem;
      color: var(--muted); padding: 0.15rem 0.5rem;
      background: var(--bg-warm); border-radius: 4px;
    }
    .position-compensation {
      font-family: var(--mono); font-size: 0.78rem;
      color: var(--green); font-weight: 700;
    }

    .position-title {
      margin: 0 0 0.5rem; font-size: 1.2rem;
      font-weight: 800; color: var(--ink); letter-spacing: -0.015em; line-height: 1.3;
    }
    .position-title a {
      color: var(--ink); text-decoration: none;
      border-bottom: 1px dashed var(--p-300);
    }
    .position-title a:hover { color: var(--p-700); border-bottom-style: solid; }

    .position-summary {
      margin: 0 0 0.85rem; font-size: 0.92rem;
      line-height: 1.55; color: var(--text);
    }

    .position-footer {
      display: flex; flex-wrap: wrap; gap: 0.5rem 1rem;
      align-items: center; padding-top: 0.7rem;
      border-top: 1px dashed var(--line);
    }
    .position-manager {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.82rem; color: var(--muted);
    }
    .position-manager svg { width: 13px; height: 13px; color: var(--p-700); }
    .position-detail {
      margin-left: auto; display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.55rem 0.9rem; background: var(--p-700); color: #fff;
      border-radius: var(--r-sm); font-size: 0.85rem; font-weight: 700;
      text-decoration: none; transition: background 0.15s ease;
    }
    .position-detail:hover { background: var(--p-800); color: #fff; }
    .position-detail svg { width: 12px; height: 12px; }

    /* Benefits */
    .kariera-benefits { background: var(--bg); border-bottom: 1px solid var(--line); }
    .benefits-grid {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem;
    }
    @media (max-width: 880px) { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .benefits-grid { grid-template-columns: 1fr; } }
    .benefit-card {
      padding: 1.5rem; background: var(--bg-warm);
      border: 1px solid var(--line); border-top: 3px solid var(--p-500);
      border-radius: var(--r);
    }
    .benefit-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: var(--p-50); color: var(--p-700);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 0.85rem;
    }
    .benefit-icon svg { width: 20px; height: 20px; }
    .benefit-card h3 {
      margin: 0 0 0.5rem; font-size: 1.02rem;
      font-weight: 800; color: var(--ink); letter-spacing: -0.015em;
    }
    .benefit-card p {
      margin: 0; font-size: 0.9rem; line-height: 1.6; color: var(--text);
    }
    .benefit-card p :global(strong) { color: var(--ink); font-weight: 600; }

    /* Process */
    .kariera-process { background: var(--bg-alt); border-bottom: 1px solid var(--line); }
    .process-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 0.85rem;
    }
    .process-list li {
      display: grid; grid-template-columns: 100px 1fr; gap: 1.5rem;
      padding: 1.5rem; background: var(--bg);
      border: 1px solid var(--line); border-radius: var(--r-lg);
    }
    @media (max-width: 600px) { .process-list li { grid-template-columns: 1fr; gap: 0.5rem; } }
    .process-num-wrap {
      display: flex; flex-direction: column; align-items: center;
      text-align: center; gap: 0.4rem;
    }
    @media (max-width: 600px) { .process-num-wrap { flex-direction: row; justify-content: flex-start; } }
    .process-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 56px; height: 56px; border-radius: 50%;
      background: linear-gradient(135deg, var(--p-700), var(--p-900)); color: #fff;
      font-family: var(--sans); font-weight: 800; font-size: 1.4rem; letter-spacing: -0.02em;
    }
    .process-timing {
      font-family: var(--mono); font-size: 0.7rem;
      text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--green); font-weight: 700;
      padding: 0.2rem 0.5rem; background: var(--green-bg); border-radius: 4px;
    }
    .process-body h3 {
      margin: 0 0 0.4rem; font-size: 1.05rem;
