---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../../components/page/PageBreadcrumbs.astro";
import EshopReviewView from "../../components/eshop/EshopReviewView.astro";
import { eshopReviews, getEshopBySlug } from "../../data/eshops";

export function getStaticPaths() {
  return eshopReviews.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const eshop = getEshopBySlug(slug!);
if (!eshop) return Astro.redirect("/recenze-eshopu/");

const otherEshops = eshopReviews.filter((e) => e.slug !== eshop.slug).slice(0, 3);
---

<BaseLayout
  title={`Recenze ${eshop.name} (${eshop.domain}) — náš test | Recenzer.cz`}
  description={eshop.tagline}
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { href: "/recenze-eshopu/", label: "Recenze e-shopů" },
      { label: eshop.name },
    ]}
  />

  <EshopReviewView eshop={eshop} otherEshops={otherEshops} />
</BaseLayout>
