          <div><dt>GPS souřadnice</dt><dd><code>{labAddress.gps}</code></dd></div>
          <div><dt>MHD</dt><dd>{labAddress.publicTransport}</dd></div>
          <div><dt>Parkování</dt><dd>{labAddress.parking}</dd></div>
        </dl>
      </div>
      <aside class="visit-card">
