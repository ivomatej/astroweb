    .visit-value {
      font-weight: 700;
      color: var(--ink);
      font-size: 0.95rem;
    }
    .visit-note {
      color: var(--muted);
      font-size: 0.78rem;
      line-height: 1.4;
    }
    .visit-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.7rem 1rem;
      background: var(--p-700);
      color: #fff;
      border-radius: var(--r);
      font-size: 0.88rem;
      font-weight: 700;
      text-decoration: none;
      transition: background 0.15s ease;
    }
    .visit-cta:hover { background: var(--p-800); }
    .visit-cta svg { width: 12px; height: 12px; }

    /* ============ GALLERY ============ */
    .lab-gallery {
      background: var(--bg-alt);
      border-bottom: 1px solid var(--line);
    }
    .gallery-grid {
      list-style: none;
      padding: 0;
      margin: 0 0 1.5rem;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.85rem;
    }
    @media (max-width: 1000px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 700px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .gallery-grid { grid-template-columns: 1fr; } }
    .gallery-item {
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--r);
      overflow: hidden;
    }
    .gallery-frame {
      position: relative;
      aspect-ratio: 4 / 3;
      background: linear-gradient(135deg, var(--p-50), var(--bg-warm));
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .gallery-num {
      position: absolute;
      top: 0.5rem;
      left: 0.5rem;
      padding: 0.2rem 0.5rem;
      background: rgba(20, 16, 50, 0.85);
      color: #fff;
      border-radius: 4px;
      font-family: var(--mono);
      font-size: 0.7rem;
      font-weight: 700;
    }
    .gallery-tag {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      padding: 0.2rem 0.55rem;
      background: var(--accent);
      color: #fff;
      border-radius: 99px;
      font-family: var(--mono);
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 700;
    }
    .gallery-placeholder {
      width: 64px;
      height: 64px;
      color: var(--p-300);
    }
    .gallery-placeholder svg { width: 100%; height: 100%; }
    .gallery-text {
      padding: 0.85rem 1rem;
    }
    .gallery-text strong {
      display: block;
      font-size: 0.92rem;
      color: var(--ink);
      margin-bottom: 0.25rem;
    }
    .gallery-text p {
      margin: 0;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.5;
    }
    .gallery-note {
      max-width: var(--max-w-text);
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.55;
      padding: 1rem 1.25rem;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-left: 3px solid var(--p-500);
      border-radius: var(--r);
    }
    .gallery-note a { color: var(--p-700); }

    /* ============ VIDEO ============ */
    .lab-video {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }
    .video-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 2rem;
      align-items: start;
    }
    @media (max-width: 880px) { .video-grid { grid-template-columns: 1fr; } }

    .video-frame {
      position: relative;
      aspect-ratio: 16 / 9;
      background: linear-gradient(135deg, var(--ink), #1f1a30);
      border-radius: var(--r-lg);
      overflow: hidden;
    }
    .video-placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255, 255, 255, 0.6);
      cursor: pointer;
      transition: color 0.15s ease;
    }
    .video-placeholder:hover { color: #fff; }
    .video-placeholder svg {
      width: 72px;
      height: 72px;
      padding: 18px;
      background: rgba(255, 255, 255, 0.15);
      border-radius: 50%;
      backdrop-filter: blur(8px);
    }
    .video-duration {
      position: absolute;
      bottom: 1rem;
      right: 1rem;
      padding: 0.3rem 0.6rem;
      background: rgba(20, 16, 50, 0.85);
      color: #fff;
      border-radius: 4px;
      font-family: var(--mono);
      font-size: 0.78rem;
      font-weight: 700;
    }

    .video-chapters {
      list-style: none;
      padding: 0;
      margin: 0 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .video-chapters li {
      display: grid;
      grid-template-columns: 50px 1fr;
      gap: 0.85rem;
      padding: 0.6rem 0.85rem;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-radius: var(--r-sm);
      font-size: 0.88rem;
    }
    .video-time {
      font-family: var(--mono);
      font-weight: 700;
      color: var(--p-700);
    }
    .video-title {
      color: var(--ink);
    }
    .video-meta {
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.55;
      margin: 0;
    }
    .video-meta strong { color: var(--ink); }

    /* ============ STATIONS ============ */
    .lab-stations {
      background: var(--bg-alt);
      border-bottom: 1px solid var(--line);
    }

    .stations-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    @media (max-width: 720px) { .stations-grid { grid-template-columns: 1fr; } }

    .station-card {
      padding: 1.75rem;
      background: var(--bg);
      border: 1px solid var(--line);
      border-top: 3px solid var(--p-500);
      border-radius: var(--r-lg);
    }

    .station-card.accent-purple { border-top-color: var(--p-500); }
    .station-card.accent-amber { border-top-color: var(--amber); }
    .station-card.accent-red { border-top-color: var(--red); }
    .station-card.accent-green { border-top-color: var(--green); }

    .station-ic {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: var(--p-50);
      color: var(--p-700);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.85rem;
    }

    .station-card.accent-amber .station-ic { background: var(--amber-bg); color: var(--amber); }
    .station-card.accent-red .station-ic { background: var(--red-bg); color: var(--red); }
    .station-card.accent-green .station-ic { background: var(--green-bg); color: var(--green); }

    .station-ic svg { width: 22px; height: 22px; }

    .station-card h3 {
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.015em;
      margin-bottom: 0.4rem;
    }

    .station-card p {
      font-size: 14px;
      line-height: 1.6;
      color: var(--muted);
      margin: 0 0 0.85rem;
    }

    .station-extras {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding-top: 0.85rem;
      border-top: 1px dashed var(--line);
    }
    .station-extras li {
      position: relative;
      padding-left: 1rem;
      font-size: 0.82rem;
      color: var(--ink-soft);
      line-height: 1.5;
    }
    .station-extras li::before {
      content: "›";
      position: absolute;
      left: 0;
      color: var(--p-600);
      font-weight: 700;
    }

    /* ============ INSTRUMENTS TABLE ============ */
    .lab-instruments {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }
    .instr-table-wrap {
      overflow-x: auto;
      border: 1px solid var(--line);
      border-radius: var(--r);
      margin-bottom: 1.5rem;
    }
    .instr-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.86rem;
      min-width: 900px;
    }
    .instr-table thead th {
      padding: 0.75rem 0.85rem;
      background: var(--bg-warm);
      text-align: left;
      font-family: var(--mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--p-700);
      font-weight: 700;
      border-bottom: 1px solid var(--line);
      white-space: nowrap;
    }
    .instr-table tbody td {
      padding: 0.75rem 0.85rem;
      border-bottom: 1px solid var(--line-soft);
      vertical-align: top;
      color: var(--text);
    }
    .instr-table tbody tr:last-child td { border-bottom: none; }
    .instr-table tbody tr:hover td { background: var(--bg-warm); }
    .instr-table .cell-name strong {
      display: block;
      color: var(--ink);
      font-weight: 700;
      margin-bottom: 0.15rem;
    }
    .instr-table .cell-category {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .instr-table code {
      font-family: var(--mono);
      font-size: 0.8rem;
      color: var(--p-700);
    }
    .instr-table code.serial {
      background: var(--p-50);
      padding: 1px 6px;
      border-radius: 4px;
      white-space: nowrap;
    }

    .instr-notes {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }
    @media (max-width: 800px) { .instr-notes { grid-template-columns: 1fr; } }
    .instr-notes li {
      padding: 0.7rem 0.9rem;
      background: var(--bg-warm);
      border-left: 3px solid var(--p-500);
      border-radius: var(--r-sm);
      font-size: 0.82rem;
      color: var(--text);
      line-height: 1.5;
    }
    .instr-notes li strong { color: var(--ink); font-weight: 700; }

    /* ============ CALIBRATION ============ */
    .lab-calibration {
      background: var(--bg-warm);
      border-bottom: 1px solid var(--line);
    }
    .cal-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }
    .cal-list li {
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: 1.25rem;
      padding: 1.25rem 1.5rem;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
      align-items: start;
    }
    @media (max-width: 540px) {
      .cal-list li { grid-template-columns: 1fr; gap: 0.5rem; }
    }
    .cal-num {
      font-family: var(--mono);
      font-size: 1.6rem;
      font-weight: 800;
      color: var(--p-300);
      line-height: 1;
    }
    .cal-text h3 {
      margin: 0 0 0.4rem;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--ink);
    }
    .cal-text p {
      margin: 0;
      line-height: 1.6;
      color: var(--text);
      font-size: 0.92rem;
    }
    .cal-text p strong { color: var(--ink); font-weight: 600; }

    /* ============ STANDARDS ============ */
    .lab-standards {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }
    .std-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
    }
    @media (max-width: 900px) { .std-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .std-grid { grid-template-columns: 1fr; } }
    .std-grid li {
      padding: 1rem 1.1rem;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-radius: var(--r);
    }
    .std-code {
      font-family: var(--mono);
      font-size: 0.85rem;
      font-weight: 800;
      color: var(--p-700);
      background: var(--p-50);
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      margin-bottom: 0.5rem;
    }
    .std-name {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.4;
      margin-bottom: 0.4rem;
    }
    .std-use {
      margin: 0;
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.5;
    }

    /* ============ ACCREDITATION ============ */
    .lab-accreditation {
      background: var(--bg-alt);
      border-bottom: 1px solid var(--line);
    }
    .accred-status-bar {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      padding: 1.25rem;
      background: var(--bg);
      border: 1px solid var(--p-200);
      border-radius: var(--r-lg);
      margin-bottom: 2rem;
    }
    @media (max-width: 720px) { .accred-status-bar { grid-template-columns: 1fr; } }
    .accred-status-current,
    .accred-status-target,
    .accred-status-timeline {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
    .accred-status-label {
      font-family: var(--mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
    }
    .accred-status-current strong { color: var(--amber); font-size: 1.05rem; font-weight: 800; }
    .accred-status-target strong { color: var(--p-700); font-size: 1.05rem; font-weight: 800; }
    .accred-status-timeline strong { color: var(--ink); font-size: 1.05rem; font-weight: 800; }

    .accred-timeline {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: relative;
    }
    .accred-timeline::before {
      content: "";
      position: absolute;
      left: 23px;
      top: 22px;
      bottom: 22px;
      width: 2px;
      background: var(--line);
    }
    .accred-step {
      display: grid;
      grid-template-columns: 50px 1fr;
      gap: 1rem;
      align-items: start;
      position: relative;
    }
    .accred-step-marker {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--bg);
      border: 2px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      z-index: 1;
    }
    .accred-step-marker svg { width: 22px; height: 22px; }
    .accred-step-done .accred-step-marker {
      background: var(--green);
      border-color: var(--green);
      color: #fff;
    }
    .accred-step-in-progress .accred-step-marker {
      background: var(--amber);
      border-color: var(--amber);
      color: #fff;
    }
    .accred-step-planned .accred-step-marker {
      background: var(--bg);
      border-color: var(--line);
      color: var(--muted-2);
    }
    .accred-step-body {
      padding: 1rem 1.25rem;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--r);
      flex: 1;
    }
    .accred-step-year {
      font-family: var(--mono);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--p-700);
      font-weight: 700;
      margin-bottom: 0.25rem;
    }
    .accred-step-title {
      margin: 0 0 0.35rem;
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink);
    }
    .accred-step-text {
      margin: 0;
      font-size: 0.88rem;
      color: var(--text);
      line-height: 1.55;
    }

    .accred-why {
      padding: 1.5rem;
      background: var(--bg);
      border: 1px solid var(--line);
      border-left: 4px solid var(--p-500);
      border-radius: var(--r);
      margin-bottom: 1rem;
    }
    .accred-why h3 {
      margin: 0 0 0.85rem;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--ink);
    }
    .accred-why ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .accred-why ul li {
      position: relative;
      padding-left: 1.5rem;
      line-height: 1.55;
      color: var(--text);
      font-size: 0.92rem;
    }
    .accred-why ul li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--green);
      font-weight: 800;
    }
    .accred-why ul li strong { color: var(--ink); font-weight: 600; }

    .accred-honest {
      padding: 1.25rem 1.5rem;
      background: var(--amber-bg);
      border: 1px solid rgba(180, 83, 9, 0.2);
      border-radius: var(--r);
    }
    .accred-honest-label {
      display: inline-block;
      font-family: var(--mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--amber);
      font-weight: 700;
      margin-bottom: 0.4rem;
    }
    .accred-honest p {
      margin: 0;
      line-height: 1.6;
      color: var(--text);
      font-size: 0.92rem;
    }
    .accred-honest p strong { color: var(--amber); font-weight: 700; }

    /* ============ CATEGORIES ============ */
    .lab-categories {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }
    .cat-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.85rem;
    }
    @media (max-width: 880px) { .cat-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .cat-grid { grid-template-columns: 1fr; } }
    .cat-grid > li {
      padding: 1.5rem;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
    }
    .cat-grid h3 {
      font-size: 1rem;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.015em;
      margin-bottom: 0.85rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px dashed var(--line);
    }
    .cat-grid ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .cat-grid ul li {
      padding-left: 1.1rem;
      position: relative;
      font-size: 13.5px;
      color: var(--ink-soft);
      line-height: 1.5;
    }
    .cat-grid ul li::before {
      content: "→";
      position: absolute;
      left: 0;
      color: var(--p-600);
      font-weight: 700;
    }

    /* ============ LIMITS ============ */
    .lab-limits {
      background: var(--amber-bg);
      border-bottom: 1px solid var(--line);
    }
    .lab-limits .eyebrow { color: var(--amber); }
    .limits-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .limits-list li {
      display: grid;
      grid-template-columns: 32px 1fr;
      gap: 1rem;
      padding: 1rem 1.25rem;
      background: #fff;
      border: 1px solid rgba(180, 83, 9, 0.18);
      border-radius: var(--r);
      align-items: center;
    }
    .limit-ic {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--amber-bg);
      color: var(--amber);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .limit-ic svg { width: 16px; height: 16px; }
    .limits-list span {
      font-size: 14px;
      color: var(--ink-soft);
      line-height: 1.55;
    }

    /* ============ ACCESS ============ */
    .lab-access {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }
    .access-table-wrap {
      overflow-x: auto;
      border: 1px solid var(--line);
      border-radius: var(--r);
      margin-bottom: 1.5rem;
    }
    .access-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
      min-width: 720px;
    }
    .access-table thead th {
      padding: 0.85rem 1rem;
      background: var(--bg-warm);
      text-align: left;
      font-family: var(--mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--p-700);
      font-weight: 700;
      border-bottom: 1px solid var(--line);
    }
    .access-table tbody td {
      padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--line-soft);
      vertical-align: top;
      color: var(--text);
