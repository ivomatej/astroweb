---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../../components/page/PageBreadcrumbs.astro";
import JobOfferView from "../../components/job/JobOfferView.astro";
import { jobs, getJobBySlug } from "../../data/jobs";

export function getStaticPaths() {
  return jobs.map((j) => ({ params: { slug: j.slug } }));
}

const { slug } = Astro.params;
const job = getJobBySlug(slug!);
if (!job) return Astro.redirect("/kariera/");
---

<BaseLayout
  title={`${job.title} | Kariéra Recenzer.cz`}
  description={job.summary}
>
  <PageBreadcrumbs
    items={[
      { href: "/", label: "Recenzer" },
      { href: "/kariera/", label: "Kariéra" },
      { label: job.title },
    ]}
  />

  <JobOfferView job={job} relatedJobs={jobs} />
</BaseLayout>
