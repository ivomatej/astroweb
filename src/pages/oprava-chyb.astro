---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";
import StatStrip from "../components/page/StatStrip.astro";

const stats2025 = [
  { value: "342", label: "hlášení od čtenářů" },
  { value: "289", label: "potvrzených oprav" },
  { value: "32 h", label: "průměrná doba opravy" },
  { value: "100 %", label: "veřejně zaznamenáno" },
];

const errorTypes = [
  { value: "fact", label: "Nesprávný fakt nebo údaj" },
  { value: "price", label: "Zastaralá cena nebo dostupnost" },
  { value: "link", label: "Nefunkční nebo špatný odkaz" },
  { value: "spec", label: "Špatný parametr produktu" },
  { value: "gram", label: "Gramatická nebo stylistická chyba" },
  { value: "other", label: "Něco jiného" },
];

const process = [
  {
    num: "01",
    title: "Přijetí hlášení",
    text: "Hlášení nám dorazí e-mailem nebo formulářem. Automaticky vám pošleme potvrzení s číslem případu.",
  },
  {
    num: "02",
    title: "Triage do 4 hodin",
    text: "V pracovní době zařadíme hlášení do priority — kritická (nesprávná data o bezpečnosti) řešíme okamžitě, drobné překlepy v dávce.",
  },
  {
    num: "03",
    title: "Ověření a oprava",
    text: "Autor původního článku ověří fakt z minimálně 2 nezávislých zdrojů. Opravu provedeme do 48 hodin u kritických chyb, do 5 dnů u drobných.",
  },
  {
    num: "04",
    title: "Zveřejnění v historii revizí",
    text: "Opravu nikdy nemažeme — vždy ji zveřejníme v sekci Historie revizí článku s datem, popisem změny a (pokud chcete) poděkováním vám.",
  },
];

const recentFixes = [
  {
    date: "2026-05-12",
    article: "Nejlepší pračky 2026: TOP 7",
    type: "Cena",
    change: "Cena Bosch Serie 8 aktualizována z 19 990 Kč na 21 590 Kč (nárůst po dovozu).",
    reporter: "Martin K.",
  },
  {
    date: "2026-05-08",
    article: "Aku brusky 2026: jak vybrat",
    type: "Spec",
    change: "Hmotnost Makita DGA504 opravena z 2,4 kg na 2,2 kg (bez baterie).",
    reporter: "Anonymní čtenář",
  },
  {
    date: "2026-04-30",
    article: "Zimní pneumatiky 205/55 R16",
    type: "Fakt",
    change: "Brzdná dráha Continental WinterContact opravena ze 38,2 m na 39,1 m (přepočet).",
    reporter: "Jakub N. (garant)",
  },
  {
    date: "2026-04-22",
    article: "Jak vybrat aku vrtačku",
    type: "Odkaz",
    change: "Nefunkční odkaz na Heureku nahrazen aktuální URL.",
    reporter: "Eva B.",
  },
  {
    date: "2026-04-15",
    article: "Aku sekačky 2026",
    type: "Spec",
    change: "Hlučnost Stihl RMA 235 doplněna o měření při ždímání (chyběla).",
    reporter: "Petr D.",
  },
];

const required = [
  {
    title: "Odkaz na článek",
    text: "Nejlepe URL přímo na sekci, kde je problém — pomocí kotvy v adrese.",
  },
  {
    title: "Popis problému",
    text: "Co konkrétně je nesprávné. Pokud máte aktuálnější informaci, přiložte zdroj.",
  },
  {
    title: "Váš kontakt (volitelný)",
    text: "Pokud chcete být informováni o opravě a případně se podepsat pod změnu.",
  },
];

const lastUpdated = "2026-04-15";
---

<BaseLayout
  title="Nahlásit chybu — Recenzer"
  description="Našli jste chybu v článku? Nahlaste nám ji. Opravy řešíme do 48 hodin u kritických chyb a vždy zveřejníme v Historii revizí."
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Nahlásit chybu" }]} />

  <PageHero
    eyebrow="Editorial standards · opravy"
    eyebrowIcon="check"
    title="Našli jste<br/><em>chybu v článku?</em>"
    subtitle="Nikdo nepíše bez chyb — a my je rádi opravujeme. Veškeré opravy zveřejňujeme v <strong>Historii revizí</strong> článku, abyste vždy věděli, co se kdy změnilo."
  />

  <StatStrip label="Co jsme opravili v roce 2025" stats={stats2025} />

  <!-- Form -->
  <section class="ox-form-section">
    <div class="inner">
      <header class="form-head">
        <p class="eyebrow">Formulář</p>
        <h2>Nahlásit chybu</h2>
        <p class="lead">
          Stačí pár řádků. Pokud máte spěchající otázku nebo příliš dlouhý popis, napište nám přímo na <a href="mailto:opravy@recenzer.cz">opravy@recenzer.cz</a>.
        </p>
      </header>

      <form class="ox-form" method="post" action="/api/oprava-chyb" novalidate>
        <label class="field">
          <span>Odkaz na článek *</span>
          <input
            type="url"
            name="article_url"
            required
            placeholder="https://recenzer.cz/clanek/aku-brusky/"
          />
        </label>

        <label class="field">
          <span>Typ chyby *</span>
          <select name="error_type" required>
            <option value="">Vyberte typ</option>
            {errorTypes.map((e) => <option value={e.value}>{e.label}</option>)}
          </select>
        </label>

        <label class="field">
          <span>Popis problému *</span>
          <textarea
            name="description"
            rows="6"
            required
            placeholder="Co konkrétně je nesprávné? Pokud máte aktuálnější údaj, uveďte zdroj…"
          ></textarea>
        </label>

        <div class="grid-2">
          <label class="field">
            <span>Vaše jméno (volitelné)</span>
            <input type="text" name="name" autocomplete="name" placeholder="Anonymní hlášení je v pořádku" />
          </label>
          <label class="field">
            <span>E-mail (volitelný)</span>
            <input type="email" name="email" autocomplete="email" placeholder="Pro zaslání potvrzení o opravě" />
          </label>
        </div>

        <label class="consent">
          <input type="checkbox" name="public_credit" />
          <span>Souhlasím s případným <strong>poděkováním v Historii revizí</strong> článku (jen křestní jméno + iniciála příjmení).</span>
        </label>

        <div class="form-actions">
          <button type="submit" class="btn-primary">
            Odeslat hlášení
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
        </div>
      </form>
    </div>
  </section>

  <!-- Process -->
  <section class="ox-process">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Proces</p>
        <h2>Co se s vaším hlášením stane</h2>
        <p class="lead">
          Čtyři kroky, kterými každé hlášení projde — od přijetí po veřejné zveřejnění opravy.
        </p>
      </header>
      <ol class="process-list">
        {
          process.map((p) => (
            <li>
              <span class="step-num">{p.num}</span>
              <div>
                <h3>{p.title}</h3>
                <p>{p.text}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Required -->
  <section class="ox-required">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Co od vás potřebujeme</p>
        <h2>Třicet vteřin a máme dost informací</h2>
        <p class="lead">
          Hlášení nemusí mít odbornou kvalitu — stačí, abychom dokázali najít problém. Detaily ověříme my.
        </p>
      </header>
      <ul class="req-grid">
        {
          required.map((r) => (
            <li>
              <div class="req-ic" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </div>
              <h3>{r.title}</h3>
              <p>{r.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Direct email -->
  <section class="ox-email">
    <div class="inner">
      <div class="email-card">
        <div>
          <p class="eyebrow">Přímý e-mail</p>
          <h2>Pokud nechcete formulář</h2>
          <p>Napište nám přímo. Klidně i bez konkrétního článku — pokud cítíte, že něco není v pořádku, dáme tomu prostor.</p>
        </div>
        <div class="email-actions">
          <a href="mailto:opravy@recenzer.cz" class="btn-primary">
            opravy@recenzer.cz
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <span class="email-sla">Pracovní dny do 24 h · víkend do 72 h</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent fixes -->
  <section class="ox-recent">
    <div class="inner">
      <header class="section-head">
        <p class="eyebrow">Transparentnost</p>
        <h2>Poslední opravy</h2>
        <p class="lead">
          Posledních 5 oprav, které jsme zveřejnili v článcích. Plný chronologický archiv najdete na stránce <a href="/opravy/">/opravy/</a>.
        </p>
      </header>
      <ol class="recent-list">
        {
          recentFixes.map((f) => (
            <li>
              <div class="recent-meta">
                <time datetime={f.date}>{f.date}</time>
                <span class:list={["recent-type", `tone-${f.type.toLowerCase()}`]}>{f.type}</span>
              </div>
              <h3>{f.article}</h3>
              <p class="recent-change">{f.change}</p>
              <p class="recent-reporter">Nahlásil: <strong>{f.reporter}</strong></p>
            </li>
          ))
        }
      </ol>
      <div class="ox-recent-cta">
        <a href="/opravy/" class="ox-archive-link">
          Otevřít kompletní archiv oprav
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="ox-related">
    <div class="inner">
      <div class="related-card">
        <h2>O procesu oprav</h2>
        <p>
          Naše pravidla pro fact-checking, ověřování zdrojů a editoriální transparentnost.
        </p>
        <div class="end-actions">
          <a href="/redakcni-zasady/" class="btn-primary">Redakční zásady</a>
          <a href="/eticky-kodex/" class="btn-ghost">Etický kodex</a>
          <a href="/overovani-faktu/" class="btn-ghost">Ověřování faktů</a>
          <a href="/metodika/" class="btn-ghost">Metodika</a>
        </div>
      </div>
      <p class="ox-meta">
        Platnost od <strong>2016</strong>, poslední aktualizace procesu <time datetime={lastUpdated}>{lastUpdated}</time>.
      </p>
    </div>
  </section>

  <style>
    .inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: clamp(2rem, 4vw, 3rem) var(--gutter);
    }

    .section-head {
      max-width: 65ch;
      margin: 0 0 2rem;
    }

    .form-head {
      max-width: 56ch;
      margin: 0 auto 2rem;
      text-align: center;
    }

    .eyebrow {
      font-family: var(--mono);
      font-size: 11.5px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--p-700);
      font-weight: 700;
      margin: 0 0 0.5rem;
    }

    .section-head h2,
    .form-head h2 {
      font-size: clamp(1.5rem, 3vw, 2.1rem);
      font-weight: 800;
      letter-spacing: -0.025em;
      color: var(--ink);
      line-height: 1.2;
      margin-bottom: 0.6rem;
    }

    .section-head .lead,
    .form-head .lead {
      font-size: 15px;
      line-height: 1.6;
      color: var(--muted);
      margin: 0;
    }

    .section-head .lead :global(strong) { color: var(--ink); font-weight: 700; }
    .section-head .lead :global(a) { color: var(--p-700); text-decoration: underline; }
    .form-head .lead :global(a) { color: var(--p-700); text-decoration: underline; }

    /* Form */
    .ox-form-section {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }

    .ox-form {
      max-width: 680px;
      margin: 0 auto;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-radius: var(--r-xl);
      padding: clamp(1.5rem, 3vw, 2rem);
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    @media (max-width: 560px) { .grid-2 { grid-template-columns: 1fr; } }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .field > span {
      font-size: 12.5px;
      font-weight: 600;
      color: var(--ink);
    }

    .field input,
    .field select,
    .field textarea {
      padding: 0.7rem 0.85rem;
      border: 1px solid var(--line);
      border-radius: var(--r);
      font: inherit;
      font-size: 14.5px;
      color: var(--ink);
      background: #fff;
    }

    .field textarea {
      resize: vertical;
      min-height: 130px;
    }

    .field input:focus-visible,
    .field select:focus-visible,
    .field textarea:focus-visible {
      outline: none;
      border-color: var(--p-500);
      box-shadow: 0 0 0 3px rgba(122, 79, 227, 0.15);
    }

    .consent {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.55;
    }

    .consent input[type="checkbox"] {
      margin-top: 3px;
      accent-color: var(--p-700);
    }

    .consent strong { color: var(--ink); font-weight: 700; }

    .form-actions {
      display: flex;
      justify-content: flex-end;
    }

    .btn-primary,
    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.75rem 1.25rem;
      border-radius: var(--r);
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      border: 1px solid transparent;
      font-family: inherit;
    }

    .btn-primary {
      background: var(--p-700);
      color: #fff;
      border-color: var(--p-700);
    }

    .btn-primary:hover,
    .btn-primary:focus-visible {
      background: var(--p-800);
      border-color: var(--p-800);
      color: #fff;
    }

    .btn-primary svg { width: 14px; height: 14px; }

    .btn-ghost {
      background: #fff;
      color: var(--ink);
      border-color: var(--line);
    }

    .btn-ghost:hover,
    .btn-ghost:focus-visible {
      border-color: var(--p-400);
      color: var(--p-700);
    }

    /* Process */
    .ox-process {
      background: var(--bg-warm);
      border-bottom: 1px solid var(--line);
    }

    .process-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.85rem;
    }

    @media (max-width: 720px) { .process-list { grid-template-columns: 1fr; } }

    .process-list li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 1.25rem;
      padding: 1.5rem;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
    }

    .step-num {
      font-family: var(--mono);
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--p-700);
      line-height: 1;
    }

    .process-list h3 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 0.3rem;
    }

    .process-list p {
      font-size: 14px;
      line-height: 1.6;
      color: var(--muted);
      margin: 0;
    }

    /* Required */
    .ox-required {
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }

    .req-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.85rem;
    }

    @media (max-width: 720px) { .req-grid { grid-template-columns: 1fr; } }

    .req-grid li {
      padding: 1.5rem;
      background: var(--bg-warm);
      border: 1px solid var(--line);
      border-top: 3px solid var(--green);
      border-radius: var(--r-lg);
    }

    .req-ic {
      width: 40px;
      height: 40px;
      border-radius: 11px;
      background: var(--green-bg);
      color: var(--green);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.85rem;
    }

    .req-ic svg { width: 20px; height: 20px; }

    .req-grid h3 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 0.35rem;
    }

    .req-grid p {
      font-size: 13.5px;
      line-height: 1.6;
      color: var(--muted);
      margin: 0;
    }

    /* Email */
    .ox-email {
      background: var(--p-50);
      border-bottom: 1px solid var(--line);
    }

    .email-card {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 2rem;
      align-items: center;
      max-width: 880px;
      margin: 0 auto;
    }

    @media (max-width: 780px) { .email-card { grid-template-columns: 1fr; } }

    .email-card h2 {
      font-size: clamp(1.4rem, 2.5vw, 1.85rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 0.5rem;
    }

    .email-card p {
      font-size: 15px;
      color: var(--ink-soft);
      margin: 0;
      line-height: 1.6;
    }

    .email-actions {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      align-items: flex-start;
    }

    .email-sla {
      font-size: 12.5px;
      color: var(--muted);
    }

    /* Recent */
    .ox-recent {
      background: var(--bg-warm);
      border-bottom: 1px solid var(--line);
    }

    .recent-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .recent-list li {
      padding: 1.25rem 1.5rem;
      background: #fff;
      border: 1px solid var(--line);
      border-left: 3px solid var(--p-500);
      border-radius: var(--r);
    }

    .recent-meta {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      margin-bottom: 0.5rem;
      flex-wrap: wrap;
    }

    .recent-meta time {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
    }

    .recent-type {
      font-family: var(--mono);
      font-size: 10.5px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 4px;
    }

    .recent-type.tone-cena { background: var(--amber-bg); color: var(--amber); }
    .recent-type.tone-spec { background: var(--p-50); color: var(--p-700); }
    .recent-type.tone-fakt { background: var(--red-bg); color: var(--red); }
    .recent-type.tone-odkaz { background: var(--green-bg); color: var(--green); }

    .recent-list h3 {
      font-size: 14.5px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 0.4rem;
    }

    .recent-change {
      font-size: 13.5px;
      line-height: 1.55;
      color: var(--ink-soft);
      margin: 0 0 0.4rem;
    }

    .recent-reporter {
      font-size: 12px;
      color: var(--muted-2);
      margin: 0;
    }

    .recent-reporter strong {
      color: var(--ink-soft);
      font-weight: 600;
    }

    .ox-recent-cta {
      margin-top: 1.5rem;
      text-align: center;
    }

    .ox-archive-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 1.4rem;
      background: var(--p-700);
      color: #fff;
      border-radius: var(--r);
      font-weight: 700;
      font-size: 0.92rem;
      text-decoration: none;
      transition: background 0.15s ease;
    }

    .ox-archive-link:hover { background: var(--p-800); color: #fff; }
    .ox-archive-link svg { width: 14px; height: 14px; }

    /* Related */
    .ox-related { background: var(--bg); }

    .related-card {
      max-width: 760px;
      margin: 0 auto;
      padding: 2.25rem 2rem;
      background: var(--p-50);
      border: 1px solid rgba(99, 50, 204, 0.18);
      border-radius: var(--r-xl);
      text-align: center;
    }

    .related-card h2 {
      font-size: clamp(1.4rem, 2.5vw, 1.85rem);
