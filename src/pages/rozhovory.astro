---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBreadcrumbs from "../components/page/PageBreadcrumbs.astro";
import PageHero from "../components/page/PageHero.astro";
import { getAllInterviews } from "../data/interviews";
import { allPeople } from "../data/people";

const interviews = getAllInterviews();

function person(slug: string) {
  return allPeople.find((p) => p.slug === slug);
}

function formatCzechDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
}
---

<BaseLayout
  title="Rozhovory s odborníky a garanty | Recenzer.cz"
  description={`${interviews.length} rozhovorů s odborníky z různých oborů — řemeslníci, technici, lékaři. Hloubkové Q&A o tom, co se nedozvíte z manuálu ani z marketingu.`}
>
  <PageBreadcrumbs items={[{ href: "/", label: "Recenzer" }, { label: "Rozhovory" }]} />

  <PageHero
    eyebrow="Rozhovory s odborníky"
    eyebrowIcon="info"
    title="Pohled<br/><em>z první ruky</em>"
    subtitle={`${interviews.length} rozhovorů s lidmi, kteří v oboru reálně pracují. Žádné PR fráze, žádné marketingové brožury — jen reálné zkušenosti řemeslníků, techniků a lékařů.`}
  />

  <section class="int-list">
    <div class="inner">
      <ul class="int-grid">
        {
          interviews.map((i) => {
            const expert = person(i.intervieweeSlug);
            return (
              <li class="int-card">
                <div class="int-avatar-wrap">
                  <div class="int-avatar">{expert?.initials ?? "EX"}</div>
                  <span class="int-cat">{i.category}</span>
                </div>
                <div class="int-body">
                  <header>
                    <span class="int-eyebrow">Rozhovor</span>
                    <time datetime={i.publishedAt}>{formatCzechDate(i.publishedAt)}</time>
                  </header>
                  <h2>
                    <a href={`/rozhovory/${i.slug}/`}>{i.title}</a>
                  </h2>
                  <p class="int-perex">{i.perex}</p>
                  <footer>
                    {expert && (
                      <span class="int-expert">
                        <strong>{expert.name}</strong>
                        <span>{expert.role}</span>
                      </span>
                    )}
                    <span class="int-reading">{i.readingTimeMin} min</span>
                    <a href={`/rozhovory/${i.slug}/`} class="int-link">
                      Číst rozhovor
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <line x1="5" y1="12" x2="19" y2="12" />
                        <polyline points="12 5 19 12 12 19" />
                      </svg>
                    </a>
                  </footer>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  <style>
    .inner { max-width: var(--max-w); margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--gutter); }
    .int-list { background: var(--bg-warm); }
    .int-grid {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 1rem;
    }
    .int-card {
      display: grid; grid-template-columns: 140px 1fr; gap: 2rem;
      padding: 1.75rem 2rem; background: var(--bg);
      border: 1px solid var(--line); border-radius: var(--r-lg);
      border-left: 4px solid var(--p-500);
      transition: transform 0.15s ease, border-color 0.15s ease;
    }
    @media (max-width: 700px) { .int-card { grid-template-columns: 1fr; gap: 1rem; } }
    .int-card:hover { transform: translateY(-2px); }

    .int-avatar-wrap {
      display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
    }
    .int-avatar {
      width: 120px; height: 120px; border-radius: 50%;
      background: linear-gradient(135deg, var(--p-100), var(--p-200));
      color: var(--p-700);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--sans); font-weight: 800; font-size: 2rem;
      letter-spacing: -0.02em;
    }
    @media (max-width: 700px) { .int-avatar { width: 80px; height: 80px; font-size: 1.5rem; } }
    .int-cat {
      font-family: var(--mono); font-size: 0.7rem;
      text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--muted); padding: 0.2rem 0.55rem;
      background: var(--bg-warm); border-radius: 4px; font-weight: 700;
    }

    .int-body header {
      display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.7rem;
    }
    .int-eyebrow {
      font-family: var(--mono); font-size: 0.7rem;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--p-700); font-weight: 700;
      padding: 0.2rem 0.55rem; background: var(--p-50); border-radius: 99px;
    }
    .int-body time {
      font-family: var(--mono); font-size: 0.78rem; color: var(--muted);
    }

    .int-body h2 {
      margin: 0 0 0.7rem; font-size: clamp(1.2rem, 2.4vw, 1.5rem);
      font-weight: 800; color: var(--ink); letter-spacing: -0.015em; line-height: 1.3;
    }
    .int-body h2 a {
      color: var(--ink); text-decoration: none;
      border-bottom: 1px dashed var(--p-300);
    }
    .int-body h2 a:hover { color: var(--p-700); border-bottom-style: solid; }
    .int-perex {
      margin: 0 0 1.1rem; font-size: 0.95rem;
      line-height: 1.6; color: var(--text);
    }

    .int-body footer {
      display: flex; flex-wrap: wrap; gap: 0.5rem 1rem;
      align-items: center; padding-top: 0.85rem;
      border-top: 1px dashed var(--line);
    }
    .int-expert {
      display: inline-flex; flex-direction: column; gap: 0.1rem;
    }
    .int-expert strong { color: var(--ink); font-weight: 700; font-size: 0.92rem; }
    .int-expert span { font-size: 0.78rem; color: var(--muted); }
    .int-reading {
      font-family: var(--mono); font-size: 0.78rem; color: var(--muted);
    }
    .int-link {
      margin-left: auto; display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.55rem 1rem; background: var(--p-700); color: #fff;
      border-radius: var(--r-sm); font-size: 0.88rem; font-weight: 700;
      text-decoration: none; transition: background 0.15s ease;
    }
    .int-link:hover { background: var(--p-800); color: #fff; }
    .int-link svg { width: 12px; height: 12px; }
  </style>
</BaseLayout>
